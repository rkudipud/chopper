{
  "$schema": "chopper/feature/v1",
  "name": "fev_fm_lite",
  "domain": "fev_formality",
  "description": "Lite Formality flow: adds the fev_fm_lite task as a lightweight alternative to the full RTL-to-gate flow. Used for quick equivalence checks that do not require the full APR netlist. Directly reflects fev_fm_lite.stack.",
  "metadata": {
    "owner": "fev-team",
    "tags": ["fev", "lite", "rtl2gate"]
  },
  "flow_actions": [
    {
      "action": "add_stage_after",
      "name": "fev_fm_lite",
      "reference": "fev_fm_rtl2rtl",
      "load_from": "",
      "command": "-xt vw Ifev_fm_shell -B BLOCK -T fev_fm_lite",
      "exit_codes": [0, 3, 5],
      "steps": [
        "source vars.tcl",
        "source prepare_fev_formality.tcl",
        "source default_fm_procs.tcl",
        "iproc_source -file addon_fm_procs.tcl -optional",
        "iproc_source -file project_fm_procs.tcl -optional",
        "setup_formality_env",
        "run_formality_verify"
      ]
    },
    {
      "action": "add_stage_after",
      "name": "promote_fev_fm_lite",
      "reference": "fev_fm_lite",
      "load_from": "fev_fm_lite",
      "command": "vw $ward/global/snps/fev_formality/promote.tcl -B BLOCK -T fev_fm_lite -force",
      "dependencies": ["fev_fm_lite"],
      "steps": [
        "promote_outputs"
      ]
    }
  ]
}
