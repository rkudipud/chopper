sub ProcDiff {
  my ($filename0, $filename1, $procname) = @_;
  if (!(-d "/tmp/procdiff.$ENV{USER}")) {
    system("mkdir /tmp/procdiff.$ENV{USER}");
  }
  my $abbrev0 = basename($filename0);
  my $abbrev1 = basename($filename1);

  my $comments = "";
  my $start = "proc ";
  my $end = "}";
  my $fullstart = $start . "$procname";
  my $fullstartc;
  my $defineattr = "define_proc_attributes ";
  my $fullprocstart = $defineattr . "$procname";
  my $parseopt = "parseOpt::cmdSpec "; 
  my $parseoptstart = $parseopt . "$procname"; 
  my $parseoptstartc;
  my $fullprocstartc;
  my $curly_delta;
  my $def_func;
  my $open_count= 0;
  my $proccount;
  my $procattrcount;
  my $procparseoptcount;
  my $countingfile = 0;
  my $procfile = "";
  my $curly_count;
  my $quote_count;
  my $printout;

  if ((substr $procname, 0, 2) eq "::") {  
    $fullstartc = $start . substr $procname, 2;
    $fullprocstartc = $defineattr . substr $procname, 2;
    $parseoptstartc = $parseopt . substr $procname, 2;
  } else {
    $fullstartc = $start . "::" . $procname;
    $fullprocstartc = $defineattr . "::" . $procname;
    $parseoptstartc = $parseopt . "::" . $procname;
  }
 
  my $found = 0;
  # $$ or $PID adds the Process ID to the name of the temp file
  #adding the PID allows the code to run many times quickly without overwriting the other temporary files
  my $procfile0 = "/tmp/procdiff.$ENV{USER}/${abbrev0}_0.$$";
  my $procfile1 = "/tmp/procdiff.$ENV{USER}/${abbrev1}_1.$$";

  #Process files.
  my @files = ($filename0 , $filename1); 
  foreach  (@files) {
    my ($FOUT, $FIN, $line);
    $curly_count = 0;
    $quote_count = 0;
    $proccount = 0;
    $procattrcount = 0;
    $procparseoptcount = 0;
    $curly_count = 0;
    $quote_count = 0;
    $printout = 0;
    
    if ($countingfile == 0) {
        $procfile = $procfile0;  
    } else {
        $procfile = $procfile1; 
    }
    
    open($FOUT, '>', $procfile) or die "Error: Can't open file '$procfile' for writing!\n";
    open($FIN, '<', $_) or die "Error: Can't open file '$_' for reading!\n";
  
   
    while ($line = $FIN->getline()) {
         
      #This outputs the proc that you declared
      if ($line =~ m/^$start/) {
        if (($line =~ m/^\s*(::)?$fullstart\s+/) || ($line =~ m/^\s*(::)?$fullstartc\s+/))  {
          $found = 1;
          $proccount += 1;
          $printout = 1;
        } else {
        $comments = "";
        } 
      } 

      #This section is to check if there is a define_proc_attributes of parseOpt::cmdSpec in the file and output it
      if (($line =~ m/^\s*(::)?$fullprocstartc\s+/) || ($line =~ m/^\s*(::)?$fullprocstart\s+/) ||  ($line =~ m/^\s*(::)?$parseoptstart\s+/) || ($line =~ m/^\s*(::)?$parseoptstartc\s+/)  ) { 
         $procattrcount += 1;
         $printout = 1;
         print $FOUT "\n";
      }

      if ($printout == 1) {
         print $FOUT $line;
         $curly_count = &CurlyCount($line);
         $quote_count = &QuoteCount($line);
         while ( ( ($line=~/\s*\\|\{\s*$/) || ($curly_count > 0)   || ($quote_count % 2 != 0))  && ($line = <$FIN>)) {
            $curly_count  += &CurlyCount($line);
            $quote_count  += &QuoteCount($line);
            print $FOUT $line;
         }
         $printout = 0;
      } 
    
      #This checks if there are multiple definitions of the proc, define_proc_attributes or ParseOpt::cmdSpec
      if ($procattrcount > 1) {
         print STDERR "Error: $procname has multiple define_proc_attribute or parseOpt::cmdSpec definitions in $_!\n";
         $procattrcount = 1;
      }
      if ($proccount > 1) {
         print STDERR  "Error: $procname declared multiple times in $_!\n";
         $proccount = 1;
      }
    }
    close $FOUT;
    close $FIN;
  
    $found || die "Error: Can't find definition for procedure '$proc' in file '$_'!\n";
    $found = 0; 
    $countingfile +=1; 
  }

  #Workaround for tkdiff not being installed in SLES15.
  my $tkdiff_cmd = (`sysname` =~/SLES15/) ? "/p/dt/sde/tools/em64t_SLES15/syslibs/for_sles15/bin/tkdiff" : "tkdiff";

  if ($::ignore_whitespace) {
    system("$tkdiff_cmd -w $procfile0 $procfile1 > /dev/null &");
  } else {
    system("$tkdiff_cmd $procfile0 $procfile1 > /dev/null &");
  }
}
    
