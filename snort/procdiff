sub CurlyCount($) {
  my $line        = shift;
  my $line0       = $line;

  my $delta_count = 0;
  #Remove open braces, prefixed by backslashes, that shouldn't be counted.
  while ($line =~ /\{\\\{/) {
    $line =~s/\{\\\{/\{/;
  }
  while ($line =~ /([^\\])\\\{/) {
    $line =~s/([^\\])\\\{/$1/;
  } 
  while ($line =~ /\{/) {
    $delta_count++;
    $line =~s/^[^\{]*\{//;
  }

  #Remove closing braces, prefixed by backslashes, that shouldn't be counted.
  while ($line0 =~ /\}\\\}/) {
    $line0 =~s/\}\\\}/\}/;
  } 
  while ($line0 =~ /[^\\]\\\}/) {
    $line0 =~s/([^\\])\\\}/$1/;
  } 
  while ($line0 =~ /\}/) {
    $delta_count--;
    $line0 =~s/^[^\}]*\}//;
  }

  return $delta_count;
}

sub QuoteCount($) {
  my $line  = shift;

  #Performance optimization.
  if (!$line =~/\"/) {
    return  0;
  }

  #Ignore quotes embedded in obvious comment lines.
  $line =~s/^\s*#.*//;
  $line =~s/;\s*#.*/;/;

  #Don't count escaped quotes, but do count \\" combinations where a line extension (\) is included at the end of a string.
  while ($line =~/[^\\]\\\"/) {
    $line =~s/([^\\])\\\"/$1/;
  }

  my $quote_count = 0;
  while ($line =~/\"/) {
    $quote_count++;
    $line =~s/^[^\"]*\"//;
  }
  return  $quote_count;
}

