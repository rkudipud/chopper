{
  my $initialized         = 0;
  my $vendor_procs_ref;
  sub _CountVendorAbbrevProcMatches($) {
    my $pref  = shift;

    #Don't waste time looking for abbreviated forms of vendor commands      
    #unless they're enabled.                                                    
    if (!$vendor_checks_on) {
      return  0;
    }

    if (!$initialized) {
      $vendor_procs_ref = &_GetNonAbbrevVendorProcs();
      $initialized = 1;
    }

    my $num_abbrev_matches  = 0;
    #The ignore_list can also be used to cleanup bogus abbreviation matches.
    if (!(&_IsInList($pref, \@ignore_list))) {  
      foreach my $ven_proc (@{$vendor_procs_ref}) {
        #Count abbreviations only and not exact matches.
        if ((index($ven_proc, $$pref) == 0) && ($$pref ne $ven_proc)) {
          $num_abbrev_matches++;
        }
      }
    }

    #Is it an abbreviated form a of vendor command?  Technically to be a    
    #valid abbreviation, it must uniquely match 1 and only 1 vendor command.
    return $num_abbrev_matches;
  }
}

{
  my $initialized = 0;
  my $non_abbrev_custom_procs_ref;
  sub _CountCustomAbbrevProcMatches($) {
    my $pref  = shift;
    
    #Don't waste time looking for abbreviated forms of custom procedures unless 
    #the vendor checks are on, because vendor tools do auto proc completion.
    if (!$vendor_checks_on) {
      return  0;
    }

    if (!$initialized) {
      $non_abbrev_custom_procs_ref = &_GetNonAbbrevCustomProcs();
      $initialized = 1;
    }
    
    my $num_abbrev_matches  = 0;
    #The ignore_list can also be used to cleanup bogus abbreviation matches.
    if (!(&_IsInList($pref, \@ignore_list))) {  
      foreach my $custom_proc (@{$non_abbrev_custom_procs_ref}) {
        if (index($custom_proc, $$pref) == 0) {
          $num_abbrev_matches++;
        }
      }
    }

    #Is it an abbreviated form a of custom procedure?  Technically to be a valid
    #abbreviation, it must uniquely match 1 and only 1 custom procedure.        
    return $num_abbrev_matches;
  }
}

{
  my $initialized = 0;  #static variable
  sub _GetOptionsAndReadConfigFile() {
    print "#" . &_GetTime() . "> Entering &_GetOptionsAndReadConfigFile().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_GetOptionsAndReadConfigFile().\n" if $::DEBUG;
      return;
    }

    #Check options

    #Get the options from the user
    $Getopt::Long::ignorecase = 1;
    $Getopt::Long::autoabbrev = 1;
    $Getopt::Long::bundling   = 0;

    my $help    = 0;
    my %long_opts = (
      "help"                => \$help,
      "debug"               => \$DEBUG,
      "no_analysis"         => \$NOT_ANALYZE,
      "svn"                 => \$SVN,
      "p4"                  => \$P4,
      "prune"               => \$PRUNE,
      "prune_files_only"    => \$PRUNE_FILES_ONLY,
      "prune_parent_dir=s"  => \$PRUNE_PARENT_DIR,
      "optionfile=s"        => \$CONFIG_FILE,
      "config=s"            => \$CONFIG_FILE,
    );


    if (!&GetOptions(%long_opts)) { # Set variables from cmd line options.
      &PrintUsage();
      exit(1);
    }
    exec ("perldoc $0") if ($help);
    &PrintUsage("Could not open file $CONFIG_FILE") unless ( -e "$CONFIG_FILE" );

    #Addigional argument checking.
    if ($PRUNE && $PRUNE_FILES_ONLY) {
      die "Error: The -prune and -prune_files_only options cannot be used together!\n";
    }
    if (defined $PRUNE_PARENT_DIR) {
      -d $PRUNE_PARENT_DIR || die "Error: Path '$PRUNE_PARENT_DIR' isn't a valid directory!\n";
      $PRUNE || $PRUNE_FILES_ONLY || die "The -prune_parent_dir option must be combined with the -prune or -prune_files_only options!\n";
    }

    #Use realpath to form the config file's full path, otherwise the require command will fail if   
    #the config file isn't specified relative to one of the directories in the PATH variable.
    if (-f $CONFIG_FILE) {
        $CONFIG_FILE = realpath($CONFIG_FILE);
    }

    require $CONFIG_FILE;
    #The initialized flag must be set here to avoid an infinite recursion loop. 
    $initialized  = 1;

    #If applicable, make new .tcl files for rdt_proj
    if ($::RDT && !$NOT_ANALYZE) {
      &_MakeRdtprojFiles();
    }

    #Check configured paths and file extensions.
    &_GetAllFilesInPath();
  
    #Check configured top_of_tree paths.
    &_GetTopOfTreeFiles();
  
    #Check configured potential log procedure names.
    if (scalar @potential_log_proc_names == 0) {
      warn "Warning: No potential log procedure names specified.\n";
    }

    #Verify do not prune list.
    foreach my $obj (@do_not_prune_list) {
      if ($obj =~/\//) {
        die "(_GetOptionsAndReadConfig():16) "
        . "Error: Do not prune item '$obj' can't contain directory paths.\n";
      }
    }

    if ($PRUNE || $PRUNE_FILES_ONLY) { 
      print "Are you absolutely sure that you want to prune the code? (y/n) ";
      my $key = "";
      while (($key ne "n") && ($key ne "y")) {
        $key = getc;
      }

      if ($key eq "n") {
        print "Exiting...\n";
        print "#" . &_GetTime() 
          . "> Exiting  &_GetOptionsAndReadConfigFile().\n" if $::DEBUG;
        exit(0);
      }
    }

    print "#" . &_GetTime() . "> Exiting  &_GetOptionsAndReadConfigFile().\n" if $::DEBUG;
    return;
  }
}

sub _GetAbbrevProc($) {
  my $pref        = shift;
  my $abbrev_proc = $$pref;
  $abbrev_proc =~s/.*:://;
  return  $abbrev_proc;
}

sub _IsRegExpSafeProc($) {
  my $pref              = shift;
  return (!($$pref =~/[\$\/\\]/));
}

sub _GetRegExpSafeProc($) {
  my $pref              = shift;
  my $regexp_safe_proc = $$pref;
  while ($regexp_safe_proc =~/[\$\/\\\?]/) {
    $regexp_safe_proc  =~s/[\$\/\\\?]/\./;
  }
  return  $regexp_safe_proc;
}

sub _PrintDivider($) {
  my $fh  = shift;

  print $fh "\n- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \n\n";
}

sub _IsInList($$) {
  my $item_ref  = shift;
  my $list_ref  = shift;

  my $ret_val   = 0;
  foreach my $list_elem (@{$list_ref}) {
    if ($$item_ref eq $list_elem) {
      $ret_val  = 1;
    }
  }
  return $ret_val;
}

sub _GetAndNotList($$) {
  my $list0_ref = shift;
  my $list1_ref = shift;

  my @ret_list  = ();
  foreach my $list0_elem (@{$list0_ref}) {
    if (!(&_IsInList(\$list0_elem, $list1_ref))) {
      push(@ret_list, $list0_elem);
    }
  }

  return \@ret_list;
}

