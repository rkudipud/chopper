                print REPORT " $DO_NOT_PRUNE_STRING";
              }
              #Don't count each unique untracked file more than once.
              if (!(&_IsInList(\$sourced_file, \@files_not_tracked))) {
                push(@files_not_tracked, $sourced_file);
              }
            }
          }
        }
        if ($location_count == 0) {
          print REPORT "$UNDEFINED_STRING";
