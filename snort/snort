# INPUTS:      directory path                                                   
# OUTPUTS:     directory path                                                   
# DESCRIPTION: Given a directory path, this subroutine returns the directory    
#              path with the trailing forward slash stripped off if it existed. 
#-------------------------------------------------------------------------------
sub _ChompDir($) {
  my $dir_path_ref = shift;
  if ($$dir_path_ref =~/\/$/) {
    chop($$dir_path_ref);
  }
}

