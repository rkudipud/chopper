      return (\@ret_val);
    }
  
    #Is provided file abbreviated (ie., no path)?
    if (   (exists $files_abbrev{$$fref}{sources})
        || (exists $files_abbrev{$$fref}{procs_sources})) {
      my @ret_val = ();
      if (exists $files_abbrev{$$fref}{sources}) {
        foreach my $sourcee_file (@{$files_abbrev{$$fref}{sources}}) {
          push(@ret_val, $sourcee_file);
        }
      }
      if (exists $files_abbrev{$$fref}{procs_sources}) {
        foreach my $proc (keys %{$files_abbrev{$$fref}{procs_sources}}) {
