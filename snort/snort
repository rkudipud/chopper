# SUBROUTINE:  _GetValidLogProcNames                                            
# INPUTS:      none                                                             
# OUTPUTS:     list reference                                                   
# DESCRIPTION: This subroutine returns a list of Tcl procedures found in the    
#              paths that match the potential logging Tcl procedure names list. 
#-------------------------------------------------------------------------------
{
  my @valid_log_proc_names  = ();
  my $initialized = 0;  #Static variable.
  sub _GetValidLogProcNames() {
    print "#" . &_GetTime() . "> Entering &_GetValidLogProcNames().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_GetValidLogProcNames().\n" if $::DEBUG;
      return  \@valid_log_proc_names;  
    }

    &_FindAllTclProcs();

    foreach my $potential_log_proc_name (@potential_log_proc_names) {
      if (exists $procs{$potential_log_proc_name}) {
        push(@valid_log_proc_names, $potential_log_proc_name);
      }
    }
    
    #Add Tcl builtin log procs.
    my @builtin_log_proc_names = ("echo", "puts");
    foreach my $builtin_log_proc_name (@builtin_log_proc_names) { 
      if (!_IsInList(\$builtin_log_proc_name, \@valid_log_proc_names)) { 
        push(@valid_log_proc_names, $builtin_log_proc_name);
      }
    }

    $initialized  = 1;
    print "#" . &_GetTime() . "> Exiting  &_GetValidLogProcNames().\n" if $::DEBUG;
    return  \@valid_log_proc_names;  
  }
} 

sub _ExtractSourcedFileFromLine($) {
  my $lref    = shift;
  my $ret_val = ""; 
  
  #Also added support for the meta command <%source>.
  if (    (    (    ($$lref =~/source\s+/)
                 || ($$lref =~/<%source>\s+/))
            && !($$lref =~/#.*source\s+/)
            && !($$lref =~/set\s+source\s+/)
            && !($$lref =~/[,a-zA-Z0-9_\$\.-]source\s+/)
            && !($$lref =~/\s[a-zA-Z]+\s+source\s+/))
       || (    ($::RDT)
            && (     (    ($$lref =~/rdt_source_if_exists\s+/)
                       && !($$lref =~/#.*rdt_source_if_exists\s+/)
                       && !($$lref =~/parseOpt::cmdSpec\s+rdt_source_if_exists\s+/))
                 ||  (    ($$lref =~/source_pkg_file\s+/)
                       && !($$lref =~/#.*source_pkg_file\s+/)
                       && !($$lref =~/define_proc_(attributes|arguments)\s+source_pkg_file\s+/))
                 ||  ($$lref =~/rdt_tim_constr_ns::source_constraints_file\s+/)))
       || (    ($::CTH)
            && (    ($$lref =~/iproc_source\s+/)
                 && !($$lref =~/#.*iproc_source\s+/)
                 && !($$lref =~/define_proc_(attributes|arguments)\s+iproc_source\s+/)))
       || (    ($::CTH && $::CTH_iproc_source_distributed)
            && (    ($$lref =~/iproc_source_distributed\s+/)
                 && !($$lref =~/#.*iproc_source_distributed\s+/)
                 && !($$lref =~/define_proc_(attributes|arguments)\s+iproc_source_distributed\s+/)))
       || (    ($::CTH && $::CTH_stack_files)
            && ($$lref =~/(Ifc_shell|Ipt_shell)\s(.*\s)?-f(ile)?\s+[\/a-zA-Z0-9\.\-_]+/))) { 
    my $sourcee_file = $$lref;

    #Discard source command options.
    if ($sourcee_file =~/\-/) { 
        $sourcee_file =~s/\s-echo(\s|\]|;)/$1/;               #-echo
        $sourcee_file =~s/\s-echo$//;                         #-echo
        $sourcee_file =~s/\s-verbose(\s|\]|;)/$1/;            #-verbose
        $sourcee_file =~s/\s-verbose$//;                      #-verbose
        $sourcee_file =~s/\s-continue_on_error(\s|\]|;)/$1/;  #-continue_on_error
        $sourcee_file =~s/\s-continue_on_error$//;            #-continue_on_error
    }

    #Add support for this unusual Tcl construct found in sd_build2 pkgIndex.tcl files:
    #Example:    namespace eval :: [list source [file join $dir trace.tcl]]
    if ($sourcee_file =~/^\s*namespace eval :: \[list source \[file join /) {
        $sourcee_file =~s/^\s*namespace eval :: \[list //;    
        $sourcee_file =~s/\[file join (\S+)+ //;
        $sourcee_file =~s/\]\]\s*//;
    }

    #Discard rdt_source_if_exists command options.
    if ($::RDT) {
      if ($sourcee_file =~/rdt_tim_constr_ns::source_constraints_file/) {
        #Special handling for the rdt tool's ::rdt_tim_constr_ns::source_constraints_file procedure.
        #proc ::rdt_tim_constr_ns::source_constraints_file { fname logfile source_cmd {flags ""}} {}
        #Assumption: It doesn't return a value, so it won't be evaluated and assigned to a variable.
       
        #Discard the ::rdt_tim_constr_ns::source_constraints_file procedure.
        $sourcee_file =~s/^\s*(::)?rdt_tim_constr_ns::source_constraints_file\s//;

        #Discard the source_cmd and optional flags argument.
        $sourcee_file =~s/\s("source"|source)$//;
        $sourcee_file =~s/\s("source"|source);//;
        $sourcee_file =~s/\s("source"|source)\s.*//;
        $sourcee_file =~s/\s("rdt_source_if_exists"|rdt_source_if_exists)$//;
        $sourcee_file =~s/\s("rdt_source_if_exists"|rdt_source_if_exists);//;
        $sourcee_file =~s/\s("rdt_source_if_exists"|rdt_source_if_exists)\s.*//;
       
        #Discard the logfile argument.
        if ($sourcee_file =~/\[getvar\s+\S+\]/) {
          $sourcee_file =~s/(\[getvar\s+\S+\])\s+.*/$1/;
        } else {
          $sourcee_file =~s/(\S+)\s+\S+/$1/;
        }
      } elsif ($sourcee_file =~/rdt_source_if_exists\s/) {
        $sourcee_file =~s/\s-require(\s|\]|;)/$1/;          #-require
        $sourcee_file =~s/\s-require$//;                    #-require
        $sourcee_file =~s/\s-display(\s|\]|;)/$1/;          #-display
        $sourcee_file =~s/\s-display$//;                    #-display
        $sourcee_file =~s/\s-inclusive(\s|\]|;)/$1/;        #-inclusive
        $sourcee_file =~s/\s-inclusive$//;                  #-inclusive
        $sourcee_file =~s/\s-local(\s|\]|;)/$1/;            #-local
        $sourcee_file =~s/\s-local$//;                      #-local
        $sourcee_file =~s/\s-silent(\s|\]|;)/$1/;           #-silent
        $sourcee_file =~s/\s-silent$//;                     #-silent
      }
    }
    
    #Discard iproc_source command options.
    if ($::CTH) {
      if ($sourcee_file =~/iproc_source\s/) {
        $sourcee_file =~s/\s-optional(\s|\]|;)/$1/;         #-optional
        $sourcee_file =~s/\s-optional$//;                   #-optional
        $sourcee_file =~s/\s-use_hooks(\s|\]|;)/$1/;        #-use_hooks
        $sourcee_file =~s/\s-use_hooks$//;                  #-use_hooks
        $sourcee_file =~s/\s-verbose(\s|\]|;)/$1/;          #-verbose
        $sourcee_file =~s/\s-verbose$//;                    #-verbose
        $sourcee_file =~s/\s-quiet(\s|\]|;)/$1/;            #-quiet
        $sourcee_file =~s/\s-quiet$//;                      #-quiet
        $sourcee_file =~s/\s-display(\s|\]|;)/$1/;          #-display
        $sourcee_file =~s/\s-display$//;                    #-display
      }
    }
    if ($::CTH && $::CTH_iproc_source_distributed) {
      if ($sourcee_file =~/iproc_source_distributed\s/) {
        $sourcee_file =~s/\s-include_aprfc(\s|\]|;)/$1/;    #-include_aprfc
        $sourcee_file =~s/\s-include_aprfc$//;              #-include_aprfc
        $sourcee_file =~s/\s-optional(\s|\]|;)/$1/;         #-optional
        $sourcee_file =~s/\s-optional$//;                   #-optional
        $sourcee_file =~s/\s-serial_mode(\s|\]|;)/$1/;      #-serial_mode
        $sourcee_file =~s/\s-serial_mode$//;                #-serial_mode
        $sourcee_file =~s/\s-run_at_top(\s|\]|;)/$1/;       #-run_at_top
        $sourcee_file =~s/\s-run_at_top$//;                 #-run_at_top
        $sourcee_file =~s/\s-module_list\s+\S+$//;          #-module_list
        $sourcee_file =~s/\s-display(\s|\]|;)/$1/;          #-display
        $sourcee_file =~s/\s-display$//;                    #-display
        $sourcee_file =~s/\s-open_block(\s|\]|;)/$1/;       #-open_block
        $sourcee_file =~s/\s-open_block$//;                 #-open_block
      }
    }
    if ($::CTH && $::CTH_stack_files) {
      if ($sourcee_file =~/(Ifc_shell|Ipt_shell)\s(.*\s)?-f(ile)?\s+[\/a-zA-Z0-9\.\-_]+/) {
        $sourcee_file =~s/.*\s-f\s+//;  #Trim everything before the -f arg.
        $sourcee_file =~s/\s.*//;       #Trim everything after the filename.
      }
    }

    #Discard redirected stuff.
    $sourcee_file =~s/\s+>\s+.*//;

    #Substitute the project variable.
    $sourcee_file =~s/\[get_unix_variable PROJECT\]/hsx/;
    $sourcee_file =~s/\$\{proj\}/hsx/; 
    
    #Substitute the lib version variable.
    $sourcee_file =~s/\[get_unix_variable LIB_VER\]/2.5.CDR2.bmp.p3/;
   
    #Discard directory path information, but not Perl meta-language stuff.
    $sourcee_file =~s/.*[^<]\///;
    
    #Remove backslashes in the substring \[, \], and \..
    while ($sourcee_file =~/\\\[/) {
      $sourcee_file =~s/\\\[/\[/;
    }
    while ($sourcee_file =~/\\\]/) {
      $sourcee_file =~s/\\\]/\]/;
    }
    while ($sourcee_file =~/\\\./) {
      $sourcee_file =~s/\\\./\./;
    }
  
    #Substitute ${FUB} for any fub variable names.
    $sourcee_file =~s/\$\{fub\}/\${FUB}/;
    $sourcee_file =~s/\$fub/\${FUB}/;
    $sourcee_file =~s/\$\{fub_name\}/\${FUB}/;
    $sourcee_file =~s/\$\{fubname\}/\${FUB}/;
    $sourcee_file =~s/\[get_synopsys_variables\sdcsv_fub_name\]/\${FUB}/;
    $sourcee_file =~s/\$\{DESIGN_SPACE::top_design\}/\${FUB}/;
    $sourcee_file =~s/<fub>/\${FUB}/;
    $sourcee_file =~s/\$\{design_name\}/\${FUB}/;
    $sourcee_file =~s/\$\{pc_fubname\}/\${FUB}/;
   
    if ($::CTH) {
      if ($sourcee_file =~/^.*\[iproc_source\s+/) {
        $sourcee_file =~s/\]$//;
        $sourcee_file =~s/\];//;
      }
      $sourcee_file =~s/^.*iproc_source\s+-file\s+//;
    }
    if ($::CTH && $::CTH_iproc_source_distributed) {
      if ($sourcee_file =~/^.*\[iproc_source_distributed\s+/) {
        $sourcee_file =~s/\]$//;
        $sourcee_file =~s/\];//;
      }
      $sourcee_file =~s/^.*iproc_source_distributed\s+-file\s+//;
    }

    #Discard everything up to the sourcee. 
    $sourcee_file =~s/^.*source>?\s+//;

    if ($::RDT) {
      if ($sourcee_file =~/^.*\[rdt_source_if_exists\s+/) {
        $sourcee_file =~s/\]$//;
        $sourcee_file =~s/\];//;
      }
      $sourcee_file =~s/^.*rdt_source_if_exists\s+//;
      $sourcee_file =~s/^.*source_pkg_file\s+\S+\s+//;
    }
   
    #Remove all quotes.
    if ($sourcee_file =~/\"/) { 
      $sourcee_file =~s/\\n\"(;?)$/\"$1/;  #Corner-case: Remove trailing newline in generated code.
      while ($sourcee_file =~/\\\"/) {
        $sourcee_file =~s/\\\"//;
      }
      while ($sourcee_file =~/\"/) {
        $sourcee_file =~s/\"//;
      }
    }
    
    #Discard everything after the sourcee.
    foreach my $tcl_file_extension (@tcl_file_extensions) {
      my $regexp_tcl_file_extension = "\\" . $tcl_file_extension;
      $sourcee_file 
        =~s/$regexp_tcl_file_extension[\s;\}\]].*/$tcl_file_extension/; 
    }
    if ($sourcee_file =~/\{/) {
      $sourcee_file =~s/[;\"]$//;
    } else {
      $sourcee_file =~s/[;\"\}]$//;
    }
    $sourcee_file =~s/\s+$//; 
    if (!($sourcee_file =~/\[/)) {
      $sourcee_file =~s/\]$//;
      $sourcee_file =~s/\s+$//; 
    }
    chomp($sourcee_file);
    
    $sourcee_file =~s/^\s+//;
 
    #Discard particular corner-cases encountered that should be ignored.
    if (    !($sourcee_file =~/\\\$msg\\/)
         && ($REPORT_FILES_WITH_VARIABLE_NAMES || !($sourcee_file =~/^\$\S+$/)) 
         && !($sourcee_file =~/\s/)) {
      $ret_val  = $sourcee_file;
    }
  }

  return $ret_val;
}

sub _GetRegExpSafeString($) {
  my $regexp_safe_str     = shift;
 
  #Replace forward and back slashes with a dot.
  while ($regexp_safe_str =~/[\/\\]/) {
    $regexp_safe_str  =~s/\//\./;
    $regexp_safe_str  =~s/\\/\./;
  }

  #Replace parenthesis with a dot.
  while ($regexp_safe_str =~/[\(\)]/) {
    $regexp_safe_str  =~s/\(/\./;
    $regexp_safe_str  =~s/\)/\./;
  }
  
  #Add an escape character in front of brackets.
  $regexp_safe_str  =~s/^\[/\\\[/;
  $regexp_safe_str  =~s/^\]/\\\]/;
  while ($regexp_safe_str =~/[^\\][\[\]]/) {
    $regexp_safe_str  =~s/([^\\])\[/$1\\\[/;
    $regexp_safe_str  =~s/([^\\])\]/$1\\\]/;
  }
  
  #Add an escape character in front of curly braces.
  $regexp_safe_str  =~s/^\{/\\\{/;
  $regexp_safe_str  =~s/^\}/\\\}/;
  while ($regexp_safe_str =~/[^\\][\{\}]/) {
    $regexp_safe_str  =~s/([^\\])\{/$1\\\{/;
    $regexp_safe_str  =~s/([^\\])\}/$1\\\}/;
  }
  
  #Add an escape character in front of asterisks.
  $regexp_safe_str =~s/^\*/\\\*/;
  while ($regexp_safe_str =~/[^\\]\*/) {
    $regexp_safe_str =~s/([^\\])\*/$1\\\*/;
  }
  
  #Add an escape character in front of dollar signs.
  $regexp_safe_str =~s/^\$/\\\$/;
  while ($regexp_safe_str =~/[^\\]\$/) {
    $regexp_safe_str =~s/([^\\])\$/$1\\\$/;
  }

  return  $regexp_safe_str;
}

sub _ExtractSetVariableFromLine($) {
  my $line      = shift;
  my $line_copy = $line;
  my $var_name  = ""; 
  my $tcl_cmd   = ""; 

  #If the variable is an array, form its key, including a simple case where the key has parenthesis.
  my $array_key;
  if ($line =~/(lappend|append|set|unset)\s+[a-zA-Z0-9_\$:]+\(([^\(]+)\)/) {  
    $array_key = $2;
  } elsif ($line =~/(lappend|append|set|unset)\s+[a-zA-Z0-9_\$:]+\(([^\(]+\([^\(]+\)[^\(]*)\)/) {
    $array_key = $2;
  }

  #Except for ivar variables with simple keys that are used as part of the Cheetah flow, remove     
  #the array key which could contain embedded procedure calls or variables that confuse the regular 
  #expressions below.  
  if (defined($array_key)) {
    if (    !$::CTH
         || !($line =~/(lappend|append|set|unset)\s+(::)?ivar\(/)) {
      my $regexp_safe_array_key = &_GetRegExpSafeString($array_key);
      $line =~s/\($regexp_safe_array_key\)/\(\)/;
      $line =~s/\($regexp_safe_array_key\)/\(\)/;
    }
  }

  if ($line =~/(array set|array unset|lappend|append|set|unset)\s+[a-zA-Z0-9_()\$:,]+\s+/) {
    $tcl_cmd = $1;
    if (    ($tcl_cmd ne "unset")                                 #ignore unset
         && (1 || ($tcl_cmd ne "array set"))                      #ignore array set
         && (1 || ($tcl_cmd ne "array unset"))                    #ignore array unset
         && !($line =~/#.*${tcl_cmd}\s+[a-zA-Z0-9_()\$:,]+\s+/)   #ignore comments
         && !(    ($line =~/[,a-zA-Z0-9_\$\.-]${tcl_cmd}\s+/)     #ignore bogus matches
               && !($line =~/${tcl_cmd}\s+[a-zA-Z0-9_()\$:,]+${tcl_cmd}\s+/)) #variable names ending in set
         && !(    ($line =~/^[^\"]+\"[^\"]*${tcl_cmd}\s+/)        #ignore quoted hits
               && !($line =~/eval\s+\"[^\"]*${tcl_cmd}\s+/))) {
    
      #Discard everything that preceeds the variable name, but watch out for the
      #corner-case where the variable being set ends in "set."                  
      my $tcl_cmd_first_char;
      if ($tcl_cmd =~/^(.)/) {
        $tcl_cmd_first_char = $1;
      }

      while (!($line =~/^${tcl_cmd}\s/)) {
        $line =~s/^[^${tcl_cmd_first_char}]*${tcl_cmd_first_char}/${tcl_cmd_first_char}/;   #Discard everything up to the first 's'.
        if (!($line =~/^${tcl_cmd}\s/)) {
          $line =~s/^${tcl_cmd_first_char}//;
        }
      }  
      $line =~s/^${tcl_cmd}\s+//;

      #Discard everything after the variable name.
      $line =~s/\s.*//;
   
      #Append empty parenthesis if this is an array variable name missing a key.
      if (    (    !$::CTH 
                || ($line ne "ivar"))
           && (    ($tcl_cmd eq "array set")
                || ($tcl_cmd eq "array unset"))) {
        $line =~s/$/\(\)/;
      }

      #Now make the array index generic, except for ivar variables used with the Cheetah flow.
      $line =~s/\(\)/(\*)/; 
    
      $var_name = $line;
    }
  }

  print "_ExtractSetVariableFromLine($line_copy) = '$var_name'\n" if $::DEBUG;

  return $var_name;
}

{
  my $initialized = 0;
  sub _FindAllTclProcs() {
    print "#" . &_GetTime() . "> Entering &_FindAllTclProcs().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_FindAllTclProcs().\n" if $::DEBUG;
      return;
    }
 
    print "Caching all *.tcl files' contents...\n" if $::DEBUG; 

    #Grep through all *.tcl files in search of procedure definitions.
    my $tcl_files_ref = &_GetAllTclFilesInPath();
    my @grep_out = ();
    foreach my $tcl_file (@{$tcl_files_ref}) {
      print "FILE: $tcl_file\n" if $::DEBUG;
      open(IN, "<$tcl_file") || die "(_FindAllTclProcs():17) "
        . "Error: Can't open $tcl_file for reading!\n";
      while (<IN>) {
        if (    ($_ =~/^\s*proc\s/)
             || ($_ =~/^namespace\s+eval\s.*\s\{/)
             || ($_ =~/^[^#]*\si?define_proc_(attributes|arguments)\s+/)
             || ($_ =~/^i?define_proc_(attributes|arguments)\s+/)) {
          push(@grep_out, "$tcl_file:$_");
        } 
      }
    }
    
    %procs  = ();
    my $namespace = "";
    my $prev_file = "";
    foreach my $line (@grep_out) {
      #Extract the file from the grep and remove it. 
      my $file = $line;
      $file =~s/:.*//;
      $line =~s/^[^:]+://;
      #Clear namespace flag if we have changed files.
      if ($file ne $prev_file) {
        print "FILE: $file" if $::DEBUG;
        $namespace  = "";
        $prev_file  = $file;
      }
      my $define_proc_attributes = 0;
      if ($line =~/^namespace\s+eval\s.*\s\{/) {  #Did we hit a new namespace?
        #Don't record namespace if it's declared only for a single line.
        my ($curly_delta, $curly_found) = &_CurlyCount2($line);
        if (!($curly_found && ($curly_delta == 0))) {
          $namespace = &_ExtractNamespaceFromLine($line);
        } 
      } else {
        my $proc  = "";
        #Find define_proc_attributes calls but ignore strings containing "define_proc_attributes."
        if (     ($line =~/define_proc_(attributes|arguments)/) 
             && !($line =~/\Sidefine_proc_attributes/) 
             && !($line =~/[^\si]define_proc_(attributes|arguments)/)
             && !($line =~/define_proc_(attributes|arguments)\S/)
             && !($line =~/^\s*proc\s+i?define_proc_(attributes|arguments)/)) { 
          $define_proc_attributes = 1;
          #Note that if a given procedure has both a definition and a           
          #define_proc_attributes line, then the %procs hash will get           
          #initialized with the procedure twice.  That's the intended behavior. 
          $proc = &_GetDefineProcAttributesProcName($line);
          next if ($proc eq "");    #Handle the case where the proc is not listed on the define_proc_attributes line.
        } else {
          $proc = $line;
          $proc =~s/^\s*proc\s+//;  #Get rid of stuff preceeding the proc name.
          $proc =~s/\s+{.*$//;      #Get rid of stuff proceeding the proc name.
          $proc =~s/\s+$//;         #Get rid of stuff proceeding the proc name.
          $proc =~s/\s+[^\]]*$//;   #Get rid of stuff proceeding the proc name.
          chomp($proc);
        }

        #We're only grepping for procedure definitions and namespace lines.  If 
        #a namespace was previously open in the file and a procedure is defined 
        #afterwards, we have no good way of determining whether it is defined in
        #the namespace or not (unless of course, the procedure name contains a  
        #namespace delimiter). So rather than assuming one or the other, instead
        #try both and clean up the mess later with the _ProcGarbageCollector    
        #subroutine.                                                            
        if (($namespace ne "") && !($proc =~/::/)) {
          my $speculative_proc  = $namespace."::".$proc;
          $procs{$speculative_proc}{exists}       = 1;
          $procs{$speculative_proc}{is_ven_proc}  = 0;
          $procs{$speculative_proc}{is_builtin}   = 0;
          $procs{$speculative_proc}{is_custom}    = 1;
          $procs{$speculative_proc}{speculative}  = 1;
          $procs{$proc}{speculative}              = 1;
          print "PROC: $speculative_proc #speculative\n" if $::DEBUG;
        }
        $proc =~s/^:://;    #Get rid of global namespace override prefix.
        $procs{$proc}{exists}       = 1;
        $procs{$proc}{is_ven_proc}  = 0;
        $procs{$proc}{is_builtin}   = 0;
        $procs{$proc}{is_custom}    = 1;
        if ($DEBUG) {
          print "PROC: $proc";
          if ($define_proc_attributes) {
            print " #define_proc_attributes";
          }
          print "\n";
        }
      }
    }

    #Now add all Tcl Builtin and vendor non-Builtin procs from vendor tools.
    &_PopulateVendorProcsHash();

    #Mark custom procs that also have vendor or custom abbreviated names.
    foreach my $proc (keys %procs) {
      if ($procs{$proc}{is_custom}) {
        my $num_ven_abbrev_matches  = &_CountVendorAbbrevProcMatches(\$proc);
        if ($num_ven_abbrev_matches > 0) { 
          if ($num_ven_abbrev_matches == 1) { 
            $procs{$proc}{ven_abbrev} = 1;
          } else {
            $procs{$proc}{ven_ambigu} = 1;
          }
        } 
      }
    }

    #Now grep through all *.tcl files only in search of procedure calls.  The   
    #intention here is to find those few remaining procedures that are called   
    #but aren't defined anywhere.  THIS CHECK ISN'T INTENDED TO BE 100% PERFECT 
    #either and may miss a few procs.  For example, Perl files that emit Tcl    
    #code aren't examined. 
    print "BEGIN...\n" if $::DEBUG;
    foreach my $tcl_file (@{$tcl_files_ref}) {
      open(FILE, "< $tcl_file") || die "(_FindAllTclProcs():18) "
        . "Error: Can't open $tcl_file for reading!\n";
      print "FILE=$tcl_file\n" if $::DEBUG;
      my $ignore_first_iter   = 0;
      my $open_count          = 0; 
      my $ignore_open_count   = -1; 
      my $quote_count         = 0; 
      my $namespace           = "";
      my $namespace_level     = -1;
      my $multiline_comment   = 0;

      while (my $line = <FILE>) {
        #Ignore define_proc_attributes calls that often span multiple lines.
        if (    ($line =~/^[^#]*define_proc_(attributes|arguments)\s+/)
             && !($line =~/^\s*proc\s+i?define_proc_(attributes|arguments)/)) {
          my $curly_count = &_CurlyCount($line);
          my $quote_count = &_QuoteCount($line);
          while (    (    ($line=~/\s*\\|\{\s*$/) 
                       || ($curly_count > 0)
                       || ($quote_count % 2 != 0))
                  && ($line = <FILE>)) {
            $curly_count  += &_CurlyCount($line);
            $quote_count  += &_QuoteCount($line);
          }
          #This is a corner-case fix for files ending in a trailing backslash   
          #(ie. no newline) that is part of a define_proc_attributes call.      
          if (!defined $line) {
              last;
          }
        } elsif ($line =~/^namespace\s+eval\s.*\s\{/) {  #new namespace?
          #Don't record namespace if it's declared only for a single line.
          my ($curly_delta, $curly_found) = &_CurlyCount2($line);
          if (!($curly_found && ($curly_delta == 0))) {
            $namespace        = &_ExtractNamespaceFromLine($line);
            $namespace_level  = $open_count;
          } 
          $open_count += $curly_delta;
        } else {
          my $first_iter  = 1; 
        
          #This is a hack to make the current line look more obviously like
          #a comment if it is part of a multi-line comment.                
          if ($multiline_comment) {
              $line =~s/^/#/;
          } elsif (    ($line =~/^#/) 
                    || (    ($line =~/[^\\]#/)
                         && !($line =~/[{\"].*#.*[{\"]/))) { 
              $multiline_comment = 1;
          }

          my $mod_line    = $line; 
          chomp($mod_line); 
          $mod_line =~s/#.*//;
          
          $open_count += &_CurlyCount($line);
          
          #Should the namespace be reset?
          if ($open_count <= $namespace_level) {
            $namespace        = ""; 
            $namespace_level  = -1;
          }

          #Reset ignore count if we've gone below it.
          if ($open_count < $ignore_open_count) {
            $ignore_open_count = -1;
          }

          my $quote_delta  = &_QuoteCount($line);

          #Ignore line if we're in the middle of a multiline set or quote.
          if (    ($open_count != $ignore_open_count)
               && (    ($quote_count % 2 == 0) 
                    || ($quote_delta > 0))) { 
            #Try to do something intelligent when there is only one quote.
            if ($quote_delta == 1) {
              if ($quote_count % 2 == 0) {
                $mod_line =~s/\".*$//;
              } else {
                $mod_line =~s/^.*\"//;
              }
            }

            #Keep scanning across the line looking for all procedure calls.
            while (    (!$ignore_first_iter && $first_iter)
                    || ($mod_line =~/[\s{]\[/)) {
              if ($ignore_first_iter || !$first_iter) {
                #Remove all characters in the line up to the next '[' character 
                #that could precede another procedure call, discarding any other
                #bogus combinations involving '['.                              
               
                my $loop_again;
                do {
                  $loop_again = 0;
                 
                  #If the '[' character is not preceeded by a space or a '{',   
                  #then it must not be a procedure call.                        
                  if ($mod_line =~/^[^\[]*[^\s^\{]\[/) {
                    $mod_line =~s/^[^\[]*[^\s^\{]\[//;
                    $loop_again = 1;
                  } 

                  #Ignore the string match regexp case.
                  if ($mod_line =~/^string\s+match\s\{\[[a-zA-Z0-9_]+\]\}\s+/) {
                    $mod_line =~s/^string\s+match\s\{\[[a-zA-Z0-9_]+\]\}\s+//;
                    $loop_again = 1;
                    if (!($mod_line =~/^\s*\[/)) {
                      $mod_line =~s/^[^\]]*\]\s*\}//;
                    }
                  } 
                } while ($loop_again);

                #Get rid of everything up to the next procedure call.
                $mod_line =~s/^[^\[]*[\s{]*\[//;  
              }
              if (    ($mod_line =~/^\s*(::)?([a-zA-Z0-9_]+::)*[a-zA-Z0-9_]+/)
                   && (    !($mod_line =~/^\s*[a-zA-Z0-9_]+\s*[{}=\\]/)
                        || ($mod_line =~/^\s*[a-zA-Z0-9_]+\s*\{\s*[a-zA-Z0-9_]+\s*\}/))
                   && !($mod_line =~/^\s*[a-zA-Z0-9_]+\s*-\s/) #switch case #1
                   && !($mod_line =~/^\s*[a-zA-Z0-9_]+\s*-$/)  #switch case #2
                   && !($mod_line =~/^\s*default\s*\{/)        #switch case #3
                   && !($mod_line =~/^\s*[a-zA-Z0-9_]+\s+[a-zA-Z0-9_]+:\s/)
                   && !($mod_line =~/^\s*[a-zA-Z0-9_]+\(/)
                   && !($mod_line =~/^\s*[0-9]+\s/) #is a number not a proc
                   && !($mod_line =~/^\s*pdi\s/)) { #Cadence-ism
                my $called_proc  = $mod_line;
                $called_proc =~s/^\s*//;  #Discard whitespace before word.
                $called_proc =~s/[\s})\";\]]+.*$//;
                $called_proc =~s/^\[//;
                $called_proc =~s/^:://;   #Discard global scope prefix.
               
                #Only proceed if it is a new procedure that isn't a Tcl builtin 
                #and doesn't contain any special characters.  Also don't report 
                #Perl keywords masquerading as procedure calls, even if they are
                #custom procedures defined, as being called by templates because
                #the templates contain embedded Perl.                           
                if (    !(exists $ven_procs{Builtins}{$called_proc})
                     && !(exists $procs{$called_proc})
                     && !(    ($namespace ne "") 
                           && (exists $procs{$namespace."::".$called_proc}))
                     && !($called_proc =~/[\*\{\}\[\]\$\/\\;-]/)
                     && !(    ($tcl_file =~/\/template_[a-zA-Z0-9_]+\.tcl/)
                           && (_IsInList(\$called_proc, \@perl_keywords)))) { 
                  my $num_ven_abbrev_matches  
                    =  &_CountVendorAbbrevProcMatches(\$called_proc);
                  if (    ($called_proc eq "max")
                       || ($called_proc eq "min")) {
                    $procs{$called_proc}{exists}      = 1;
                    $procs{$called_proc}{is_ven_proc} = 0;
                    $procs{$called_proc}{is_builtin}  = 1;
                    $procs{$called_proc}{is_custom}   = 0;
                  } elsif ($num_ven_abbrev_matches > 0) {
                    $procs{$called_proc}{exists}      = 1;
                    $procs{$called_proc}{is_ven_proc} = 1;
                    $procs{$called_proc}{is_builtin}  = 0;
                    $procs{$called_proc}{is_custom}   = 0;
                    if ($num_ven_abbrev_matches == 1) {
                      $procs{$called_proc}{ven_abbrev}  = 1;
                      print "FOUND PROC: $called_proc (vendor abbrev)\n" if $::DEBUG;
                    } else {
                      $procs{$called_proc}{ven_ambigu} = 1;
                      print "FOUND PROC: $called_proc (vendor ambigu)\n" if $::DEBUG;
                    }
                  } else {   
                    #Note that the following line is deliberately called      
                    #before the %procs hash is initialized with the new       
                    #called procedure found.  If the line proceeds the hash   
                    #initialization, there is a race condition the very first 
                    #time that _CountCustomAbbrevProcMatches() is called.  In 
                    #that case, an abbreviated custom procedure call would be 
                    #incorrectly marked as an ambiguous custom abbreviation.  
                    my $num_cus_abbrev_matches  
                      =  &_CountCustomAbbrevProcMatches(\$called_proc);
                       
                    $procs{$called_proc}{exists}      = 1;
                    $procs{$called_proc}{is_ven_proc} = 0;
                    $procs{$called_proc}{is_builtin}  = 0;
                    $procs{$called_proc}{is_custom}   = 1;
                    if ($num_cus_abbrev_matches > 0) {
                      if ($num_cus_abbrev_matches == 1) {
                        $procs{$called_proc}{cus_abbrev}  = 1;
                        print "FOUND PROC: $called_proc (custom abbrev)\n" if $::DEBUG;
                      } else {
                        $procs{$called_proc}{cus_ambigu} = 1;
                        print "FOUND PROC: $called_proc (custom ambigu)\n" if $::DEBUG;
                      }
                    } else {
                      print "FOUND PROC: $called_proc\n" if $::DEBUG;
                    }

                    if (defined $files_abbrev{$called_proc}) {
                        die "(_FindAllTclProcs():19) "
                            . "Error: The file '$called_proc' cannot also be a procedure!\n";
                    }
                  }
                }
              }
              $first_iter         = 0;
            }

            #If we're entering a multiline set, ignore whats between braces.
            if (    ($line =~/^\s*array\s+set\s+[:a-zA-Z0-9_]+\s+\{\s*$/)
                 || ($line =~/^\s*set\s+[:a-zA-Z0-9_]+\s+\{\s*$/)
                 || ($line =~/^\s*switch\s.*\s\{\s*$/)) {
              $ignore_open_count  = $open_count;
            }
          }
          $quote_count  += $quote_delta;
        }
        #If the line will be continued on the next line, disregard the first  
        #word on the next line (as a potential procedure call).               
        if ($line =~/\\$/) {
          $ignore_first_iter  = 1;
        } else {
          $ignore_first_iter  = 0;
          $multiline_comment  = 0;
        }
      }
    }

    print "END.\n" if $::DEBUG;
    $initialized  = 1;
    print "#" . &_GetTime() . "> Exiting  &_FindAllTclProcs().\n" if $::DEBUG;
    return;
  }
}

{
  my $initialized = 0;  #static variable
  sub _FindTclProcDefsAndCalcUsage() {
    print "#" . &_GetTime() . "> Entering &_FindTclProcDefsAndCalcUsage().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_FindTclProcDefsAndCalcUsage().\n" if $::DEBUG;
      return;
    }

    &_FindAllTclProcs();

    #Read all the files' contents into 1 gigantic, temporary hash.
    my %contents  = ();
    my $all_files_ref = &_GetAllFilesInPath();
    foreach my $file (@{$all_files_ref}) {
      open(FILE, "< $file") || die "(_FindTclProcDefsAndCalcUsage():19) "
        . "Error: Can't open $file for reading!\n";
      my @file_contents = ();
      while (my $line = <FILE>) {
        #Discard blank and comment lines to reduce memory footprint.
        if (&_IsNonBlankLine($line)) {
          #Collapse multiple splaces into one space to reduce memory footprint. 
          while ($line =~/\s\s+/) {
            $line =~s/\s\s+/ /;
          }
          #Eliminate end-of-line character to reduce memory footprint.
          chomp($line);
          push(@file_contents, $line);
        }
      }
      $contents{$file}  = \@file_contents;
      my $file_contents_ref = \@{$contents{$file}};
    }

    #Find all usages and definitions of each procedure, ignoring bogus matches. 
    foreach my $proc (sort (keys %procs)) {
      print "PROC=$proc\n" if $::DEBUG;
     
      my @outer_grep = ();
      
      foreach my $file (@{$all_files_ref}) {
        my $file_contents_ref = \@{$contents{$file}};
        foreach my $line (@{$file_contents_ref}) {
          if ((index($line, $proc) != -1) || ($proc =~/[:\/\\]/)) { #performance optimization
            if (&_IsProcFoundInLine(\$proc, \$line, 1)) {
              push(@outer_grep, "$file:$line"); 
            }
          }
        }
      }

      my %definitions = ();
      my %file_usage  = ();
      foreach my $line (@outer_grep) {
        print "|--LINE=$line\n" if $::DEBUG;
        
        chomp($line); 
        #Extract the file from the grep and remove it. 
        my $file = $line;
        $file =~s/:.*//;
        $line =~s/^[^:]+://;
        
        if ($line =~/^\s*proc\s/) {
          if (exists $definitions{$file}) {
            my $index           = 1;
            my $file_plus_index = "";
            do {
              $index++;
              $file_plus_index = $file."(".$index.")";
            } while ((exists $definitions{$file_plus_index}));
            $definitions{$file_plus_index} = $UNDEF;
          } else {
            $definitions{$file} = $UNDEF;
          }
          print "|--DEF?: $proc ==> $file\n" if $::DEBUG;
        } else {
          #If the file is a non-Tcl file, we'll need to record the fact that the
          #procedure is being called here. (Note that if the file is a Tcl file,
          #this step already gets covered by the _AnalyzeTclProcDefinitions and 
          #_AnalyzeNonProcTclCode subroutines.)                                 
          if (!(&_IsTclFile(\$file))) {
            #Don't report these Perl keywords masquerading as procedure calls,  
            #even if they are custom procedures defined.                        
            if (!(    ($file =~/\.pl$/)
                   && (_IsInList(\$proc, \@perl_keywords)))) {
              #Add this file to the callee procedure's caller list.
              if (!(exists $procs{$proc}{callers})) {
                my %caller_procs = ();
                $caller_procs{$file} = 1;
                $procs{$proc}{callers} = \%caller_procs;
              } else {
                my $caller_procs_ref = \%{$procs{$proc}{callers}};
                $caller_procs_ref->{$file} = 1;
              }

              #Add the procedure to this file's callee list.
              if (!(exists $files{$file}{proc_callees})) {
                my %procs_called      = ();
                $procs_called{$proc}  = 1;
                $files{$file}{proc_callees} = \%procs_called;
              } else {
                my $proc_callees_ref        = \%{$files{$file}{proc_callees}};
                $proc_callees_ref->{$proc}  = 1;
              }
              
              $file_usage{$file}++;
            }
          } else {
            #Don't report these Perl keywords masquerading as procedure calls,  
            #even if they are custom procedures defined.                        
            if (!(    ($file =~/\/template_[a-zA-Z0-9_]+\.tcl/)
                   && (_IsInList(\$proc, \@perl_keywords)))) {
              $file_usage{$file}++;
            }
          }
        }
      }
      my $total_usage   = 0;
      foreach my $key (keys %file_usage) {
        $total_usage += $file_usage{$key};
      }
      if ($total_usage > $max_proc_usage) {
        $max_proc_usage = $total_usage; 
      }
      
      $procs{$proc}{definitions}  = \%definitions;
      $procs{$proc}{file_usage}   = \%file_usage;
      $procs{$proc}{total_usage}  = $total_usage;
    }

    $initialized  = 1;
    print "#" . &_GetTime() . "> Exiting  &_FindTclProcDefsAndCalcUsage().\n" if $::DEBUG;
    return;
  }
}

#-------------------------------------------------------------------------------
# SUBROUTINE:  _GenTclProcReport                                                
# INPUTS:      custom_not_vendor_procs, filename                                   
# OUTPUTS:     none                                                             
# DESCRIPTION: This subroutine generates a report of all vendor or custom Tcl 
#              procedures found, including: description, definition location,   
#              callees, callers, which vendor tools apply, and overall usage. 
#              In addition, it performs a few checks (ex: multiple definitions) 
#              and generates warning messages if a check fails.  The procedures 
#              are ordered from highest to lowest overall usage.                
#-------------------------------------------------------------------------------
sub _GenTclProcReport($$$) {
  my $custom_not_vendor_procs  = shift;  #Report custom procedure or vendor commands?
  my $report_dead_code_too  = shift; 
  my $abbrev_filename       = shift; 
  print "#" . &_GetTime() . "> Entering &_GenTclProcReport("
    . "$custom_not_vendor_procs, $report_dead_code_too, " . "$abbrev_filename).\n" 
    if $::DEBUG;

  &_Initialize(); 
  &_CalcPrunedUsage();
  
  my $filename  = $report_dead_code_too
    ? "$REPORTS_DIR\/$ALL_DIR\/$abbrev_filename"
    : "$REPORTS_DIR\/$PRUNED_DIR\/$abbrev_filename";
  print "Information: Writing file '$filename'.\n";

  my @procs_dead                = ();
  my @procs_dead_callee         = ();
  my @procs_no_def_callee       = ();
  my @procs_ven_abbrev_callee   = ();
  my @procs_ven_ambigu_callee   = ();
  my @procs_cus_abbrev_callee   = ();
  my @procs_cus_ambigu_callee   = ();
  my @procs_one_usage           = ();
  my @procs_zero_usage          = ();
  my @procs_medium_usage        = ();
  my @procs_high_usage          = ();
  my @procs_sans_description    = (); 
  my @procs_sans_defs           = (); 
  my @procs_identical_defs      = ();
  my @procs_different_defs      = ();
  my @procs_sans_namespace      = ();
  my @procs_recursive           = ();
  my @procs_multi_defs          = ();
  my @procs_with_sourcing       = ();
  my @procs_tool_cond           = ();
  my @procs_proj_cond           = ();
  my @procs_fubp_code           = ();
  my @procs_lib_hardcode        = ();
  my @procs_DC_compatible       = ();
  my @procs_ICC_compatible      = ();
  my @procs_ICC2_compatible     = ();
  my @procs_FC_compatible       = ();
  my @procs_PT_compatible       = ();
  my @procs_genus_compatible    = ();
  my @procs_innovus_compatible  = ();
  my @procs_incompatible        = ();
  my @procs_getenv              = ();
  my @procs_setenv              = ();
  my @procs_ven_coll            = ();
  my @procs_ven_abbrev_coll     = ();
  my @procs_ven_ambigu_coll     = ();
  my @procs_builtin_coll        = ();
  my @procs_short_definition    = ();
  my @procs_generic             = ();
  my @procs_var_builtin_coll    = ();
  my @procs_var_ven_coll        = ();
  my @procs_mislabeled          = ();
  my @procs_proj_name           = ();
  my @procs_embedded_procs      = ();
  my @procs_do_not_prune        = ();
  my @procs_uneven_suppress     = ();

  my $num_procs                 = 0;

  my @procs_to_report           = ();
  foreach my $proc (keys %procs) {
    if (    (     ($custom_not_vendor_procs)
               && ($procs{$proc}{is_custom})
               && !(exists $procs{$proc}{cus_ambigu})
               && !(exists $procs{$proc}{cus_abbrev}))
         || (     !($custom_not_vendor_procs)
               && ($procs{$proc}{is_ven_proc})
               && !(exists $procs{$proc}{ven_ambigu})
               && !(exists $procs{$proc}{ven_abbrev}))) {
      if (    $report_dead_code_too
           || !(&_IsDead(\$proc))
           || (&_IsDoNotPrune(\$proc))) {
        push(@procs_to_report, $proc);
      } 
    }
  }
  my $usage_key     = $report_dead_code_too ? "total_usage" : "pruned_usage";
  my $usage_target  = $report_dead_code_too ? 0 : 1; 

  open(REPORT, "> $filename") || die "(_GenTclProcReport():20) "
    . "Error: Can't open $filename for writing!\n";

  print REPORT "This report can generate any of the following warnings:\n"
    . "-------------------------------------------------------\n";

  my $warnings  = "";
  if ($custom_not_vendor_procs) {
    if ($vendor_checks_on) {
      $warnings =
          "This procedure is only called once.\n"
        . "This procedure isn't used anywhere.\n"
        . "This procedure never gets executed.\n"
        . "This procedure has no definition.\n"
        . "This procedure is defined * times (identical definitions).\n"
        . "This procedure is defined * times (different definitions).\n"
        . "This procedure name is used with/without a namespace.\n"
        . "This procedure has an embedded procedure definition.\n"
        . "This procedure is sourcing Tcl files.\n" 
        . "This procedure has a recursive call back to itself.\n" 
        . "This procedure is executed but has a callee that isn't.\n"
        . "This procedure is executed but has a callee with no definition.\n"
        . "This procedure name collides with a Tcl builtin procedure name.\n"
        . "This procedure sets a variable colliding with a Tcl builtin "
        . "procedure name.\n"

        . "This procedure has a project-specific switch.\n"
        . "This procedure has fubp-related code.\n"
        . "This procedure has library hardcoding.\n"
        . "This procedure accesses an environment variable.\n"
        . "This procedure sets an environment variable.\n"
        . "This procedure has a project in its name.\n"
        . "This procedure is labeled incorrectly in log files.\n"

        . "This procedure has no define_proc_attribute description.\n"
        . "This procedure has a callee that is a vendor abbreviated "
        . "command.\n"
        . "This procedure has a callee that is a vendor ambiguous command "
        . "abbreviation.\n"
        . "This procedure has a callee that is a custom abbreviated "
        . "procedure.\n"
        . "This procedure has a callee that is a custom ambiguous procedure "
        . "abbreviation.\n"
        . "This procedure isn't compatible with DC or ICC.\n"
        . "This procedure has unmatched (un)suppress_message calls.\n"
        . "This procedure has a vendor tool-specific switch.\n"
        . "This procedure name collides with a vendor command name.\n"
        . "This procedure name collides with a vendor abbreviated "
        . "command.\n"
        . "This procedure name is a vendor ambiguous command "
        . "abbreviation.\n"
        . "This procedure sets a variable colliding with a vendor "
        . "command name.\n"
        . "This procedure is DC-incompatible and defined/used "
        . "in a dc*.tcl file.\n"
        . "This procedure is ICC-incompatible and defined/used "
        . "in a icc*.tcl file.\n"
        . "This procedure is ICC-compatible and defined in a dc*.tcl file.\n"
        . "This procedure is DC-compatible and defined in a icc*.tcl file.\n";
    } else { 
      $warnings =
          "This procedure is only called once.\n"
        . "This procedure isn't used anywhere.\n"
        . "This procedure never gets executed.\n"
        . "This procedure has no definition.\n"
        . "This procedure is defined * times (identical definitions).\n"
        . "This procedure is defined * times (different definitions).\n"
        . "This procedure name is used with/without a namespace.\n"
        . "This procedure has an embedded procedure definition.\n"
        . "This procedure is sourcing Tcl files.\n" 
        . "This procedure has a recursive call back to itself.\n" 
        . "This procedure is executed but has a callee that isn't.\n"
        . "This procedure is executed but has a callee with no definition.\n"
        . "This procedure name collides with a Tcl builtin procedure name.\n"
        . "This procedure sets a variable colliding with a Tcl builtin "
        . "procedure name.\n"
        
        . "This procedure has a project-specific switch.\n"
        . "This procedure has fubp-related code.\n"
        . "This procedure has library hardcoding.\n"
        . "This procedure accesses an environment variable.\n"
        . "This procedure sets an environment variable.\n"
        . "This procedure has a project in its name.\n"
        . "This procedure is labeled incorrectly in log files.\n"
    }
  } else {   
    $warnings =
        "This procedure isn't compatible with DC or ICC.\n"
      . "This procedure is DC-incompatible and defined/used "
      . "in a dc*.tcl file.\n"
      . "This procedure is ICC-incompatible and defined/used "
      . "in a icc*.tcl file.\n"
      . "This procedure is only called once.\n";
  }
  my $i = 1;
  foreach my $warning (split "\n", $warnings) {
    printf REPORT "%2d. $warning\n", ($i++);
  }
  
  &_PrintDivider(*REPORT);

  my %temp_report = ();

  #Print out procedures, sorted by descending usage.
  my $current_usage = $max_proc_usage;
  while ($current_usage >= $usage_target) {
    foreach my $proc (sort @procs_to_report) {
      my $proc_usage = $procs{$proc}{$usage_key};
      if ($proc_usage == $current_usage) {
        my $is_ven_proc = $procs{$proc}{is_ven_proc};
        my $is_custom   = $procs{$proc}{is_custom};
        if (    ($is_custom && $custom_not_vendor_procs)
             || ($is_ven_proc && !$custom_not_vendor_procs && ($proc_usage>0))) {
          print REPORT "Proc: " . &GetFormalName($proc);
          my $is_dead_proc = &_IsDead(\$proc);
          if ($is_dead_proc) {
            print REPORT " $DEAD_STRING";
            push(@procs_dead, $proc);
          }
          if (&_IsDoNotPrune(\$proc)) {
            print REPORT " $DO_NOT_PRUNE_STRING";
            push(@procs_do_not_prune, $proc);
          }
          if (exists $procs{$proc}{ven_abbrev}) {
            print REPORT "\nWarning: This procedure name collides with a "
              . "vendor abbreviated command.";
            push(@procs_ven_abbrev_coll, $proc);
          }
          if (exists $procs{$proc}{ven_ambigu}) {
            print REPORT "\nWarning: This procedure name is a vendor "
              . "ambiguous command abbreviation.";
            push(@procs_ven_ambigu_coll, $proc);
          }
          if (&_HasProjectInName(\$proc)) {
            print REPORT "\nWarning: This procedure has a project in its name.";
            push(@procs_proj_name, $proc);
          } 
          print REPORT "\n";
          
          my %definitions           = %{$procs{$proc}{definitions}};
          my %file_usage            = %{$procs{$proc}{file_usage}};
          my $DC_compatible         = 1; 
          my $ICC_compatible        = 1; 
          my $ICC2_compatible       = 1; 
          my $FC_compatible         = 1; 
          my $PT_compatible         = 1; 
          my $genus_compatible      = 1; 
          my $innovus_compatible    = 1; 
          my $dc_file_definition    = 0;
          my $dc_file_usage         = 0;
          my $icc_file_definition   = 0;
          my $icc_file_usage        = 0;
          $num_procs++;

          if ($custom_not_vendor_procs) {
            #Generate report for custom procedures only.
            my $defs_count            = 0;
            my $definitions_differ    = 0; 
            my $first_definition      = "";
            my $definition_found      = 0; 
            my $is_tool_conditional   = (exists $procs{$proc}{tool_cond});
            my $is_proj_conditional   = (exists $procs{$proc}{proj_cond});
            my $has_embedded_proc     = (exists $procs{$proc}{embedded_proc});
            my $has_fubp_code         = (exists $procs{$proc}{fubp_code});
            my $has_lib_code          = (exists $procs{$proc}{lib_hardcode});
            my $has_uneven_suppress   = (exists $procs{$proc}{uneven_suppress});
            my $is_getenv             = (exists $procs{$proc}{getenv});
            my $is_setenv             = (exists $procs{$proc}{setenv});
            my $is_mislabeled         = (exists $procs{$proc}{mislabel});
            my $is_recursive          = 0;
            my $has_dead_callee       = 0;
            my $has_no_def_callee     = 0;
            my $has_ven_abbrev_callee = 0;
            my $has_ven_ambigu_callee = 0;
            my $has_cus_abbrev_callee = 0;
            my $has_cus_ambigu_callee = 0;
            my $is_builtin            = $procs{$proc}{is_builtin};

            my $called_sans_namespace = 0; 
            if ($proc =~/[^:]::/) {
              my $local_proc_name = $proc;
              $local_proc_name =~s/^.*:://;
              $called_sans_namespace = (exists $procs{$local_proc_name});
            }

            #Print out procedure's definition files.
            foreach my $definition_file (sort keys %definitions) {
              if (    $report_dead_code_too
                   || !(&_IsDead(\$definition_file))
                   || (&_IsDoNotPrune(\$definition_file))) {
                print REPORT "|--definition: $definition_file";
                if (&_IsDead(\$definition_file)) {
                  print REPORT " $DEAD_STRING";
                }
                if (&_IsDoNotPrune(\$definition_file)) {
                  print REPORT " $DO_NOT_PRUNE_STRING";
                }
                print REPORT "\n";

                $defs_count++;
                if (    ($definition_file =~/\/dc[a-zA-Z_]*\.tcl$/) 
                     || ($definition_file =~/\/template_dc[a-zA-Z_]*\.tcl$/)) {
                  $dc_file_definition = 1;
                } elsif 
                   (    ($definition_file =~/\/icc[a-zA-Z_]*\.tcl$/) 
                     || ($definition_file =~/\/template_icc[a-zA-Z_]*\.tcl$/)) {
                  $icc_file_definition = 1;
                }

                if ($defs_count == 1) {
                  $first_definition  = $definitions{$definition_file};
                  if ($first_definition ne $UNDEF) {
                    $definition_found = 1; 
                  }
                } else {
                  my $current_definition  = $definitions{$definition_file};
                  if ($current_definition ne $first_definition) {
                    $definitions_differ = 1; 
                  }
                }
              } 
            }
            if ($defs_count == 0) {
              print REPORT "|--definition: $NA_STRING\n";
              print REPORT "Warning: This procedure has no definition.\n";
              push(@procs_sans_defs, $proc);
              printf REPORT "|--length: $UNDEFINED_STRING\n";
            } else {
              printf REPORT "|--length: %d ", $procs{$proc}{length};
              if ((scalar keys %definitions) > 1) {
                print REPORT "(average)";
              }
              if ($procs{$proc}{length} <= $SHORT_DEFINITION) {
                push(@procs_short_definition, $proc);
              }
              print REPORT "\n";
            }

            if ($defs_count > 1) {
              print REPORT "Warning: This procedure is defined ";
              print REPORT "$defs_count times ";
              push(@procs_multi_defs, $proc);
              if ($definitions_differ) { 
                print REPORT "(different definitions).\n";
                push(@procs_different_defs, $proc);
              } else {
                print REPORT "(identical definitions).\n";
                push(@procs_identical_defs, $proc);
              }
            }

            if ($called_sans_namespace) {
              print REPORT "Warning: This procedure name is used ";
              print REPORT "with/without a namespace.\n";
              push(@procs_sans_namespace, $proc);
            }

            if ($has_embedded_proc) { 
              print REPORT "Warning: This procedure has "
                . "an embedded procedure definition.\n";
              push(@procs_embedded_procs, $proc);
            }
            if ($is_proj_conditional) { 
              print REPORT 
                "Warning: This procedure has a project-specific switch.\n";
              push(@procs_proj_cond, $proc);
            }
            if ($has_fubp_code) { 
              print REPORT "Warning: This procedure has fubp-related code.\n";
              push(@procs_fubp_code, $proc);
            }
            if ($has_lib_code) { 
              print REPORT 
                "Warning: This procedure has library hardcoding.\n";
              push(@procs_lib_hardcode, $proc);
            }
            if ($is_getenv) { 
              print REPORT 
                "Warning: This procedure accesses an environment variable.\n";
              push(@procs_getenv, $proc);
            }
            if ($is_setenv) { 
              print REPORT 
                "Warning: This procedure sets an environment variable.\n";
              push(@procs_setenv, $proc);
            }
            if ($is_ven_proc) {
              print REPORT "Warning: This procedure name collides with a "
                . "vendor command name.\n";
              push(@procs_ven_coll, $proc);
            } elsif ($is_builtin) {
              print REPORT 
                "Warning: This procedure name collides with a Tcl builtin "
                . "procedure name.\n";
              push(@procs_builtin_coll, $proc);
            }
            if ($is_mislabeled) {
              print REPORT "Warning: This procedure is labeled incorrectly "
                . "in log files.\n";
              push(@procs_mislabeled, $proc);
            }

            #Print out procedure's description.
            if ($vendor_checks_on) {
              print REPORT "|--description: ";
              if (exists $procs{$proc}{description}) {
                print REPORT $procs{$proc}{description} . "\n";
              } elsif ($defs_count == 0) {
                print REPORT "$UNDEFINED_STRING\n";
              } else {
                print REPORT "$NA_STRING\n";
                print REPORT "Warning: This procedure has no define_proc_attribute description.\n";
                push(@procs_sans_description, $proc);
              }
            }

            #Print out procedure's variables set/unset.
            if (exists $procs{$proc}{vars_set}) {
              print REPORT "|--(set) variables: ";
              my $vars_set          = \%{$procs{$proc}{vars_set}};
              my $var_count         = 0;
              my $var_builtin_coll  = 0;
              my $var_ven_coll      = 0;
              foreach my $var_name (sort keys %{$vars_set}) {
                print REPORT "\n   |--$var_name";  
                $var_count++;
                if (exists $procs{$var_name}) {
                  if (exists $procs{$var_name}{is_builtin}) {
                    if ($procs{$var_name}{is_builtin} == 1) {
                      print REPORT " (Tcl builtin) ";  
                      $var_builtin_coll  = 1;
                    }
                  } else {
                    warn 
                      "Warning: \$procs{$var_name}{is_builtin} is undefined.\n";
                  }
                  if (exists $procs{$var_name}{is_ven_proc}) {
                    if ($procs{$var_name}{is_ven_proc} == 1) {
                      my $ven_bucket_name = &_GetVendorProcBucketName($var_name);
                      print REPORT " (Vendor $ven_bucket_name command)";
                      $var_ven_coll = 1;
                    }
                  } else {
                    warn 
                      "Warning: \$procs{$var_name}{is_ven_proc} is undefined.\n";
                  }
                }
              }
              if ($defs_count == 0) {
                print REPORT "$UNDEFINED_STRING";
              } elsif ($var_count == 0) {
                print REPORT "$NA_STRING";
              }
              print REPORT "\n";
              if ($var_builtin_coll) {
                push(@procs_var_builtin_coll, $proc); 
                print REPORT "Warning: This procedure sets a variable "
                  . "colliding with a Tcl builtin procedure name.\n";
              }
              if ($var_ven_coll && $vendor_checks_on) {
                push(@procs_var_ven_coll, $proc); 
                print REPORT "Warning: This procedure sets a variable "
                  . "colliding with a vendor command name.\n"
              }
            }

            #Print out procedure's callee procs.
            print REPORT "|--callees: ";
            my $callee_count  = 0;
            my $generic_proc        = 1; 
            if (exists $procs{$proc}{callees}) {
              my $callee_procs      = \%{$procs{$proc}{callees}};
              my $custom_count      = 0;
              my $vendor_count    = 0;
              my $builtin_count     = 0;

              #Organize callee procedures into custom, vendor, and builtins.
              my %custom_callees    = (); 
              my %ven_proc_callees  = (); 
              my %builtin_callees   = (); 
              foreach my $callee_proc (keys %{$callee_procs}) {
                if ($procs{$callee_proc}{is_custom}) {
                  $custom_callees{$callee_proc} = 1;
                  $generic_proc                 = 0; 
                }
                if ($procs{$callee_proc}{is_ven_proc}) {
                  $ven_proc_callees{$callee_proc} = 1;
                  $generic_proc                 = 0; 
                } 
                if ($procs{$callee_proc}{is_builtin}) {
                  $builtin_callees{$callee_proc} = 1;
                }
                $callee_count++;
              }
              if ($callee_count == 0) {
                $generic_proc                 = 0; 
              }
              
              #List custom procedure callees first.
              foreach my $callee_proc (sort keys %custom_callees) {
                $custom_count++;
                print REPORT "\n   |--" . &GetFormalName($callee_proc);  
                if (exists $procs{$callee_proc}{cus_ambigu}) {
                  print REPORT " $CUSTOM_AMBIG_STRING";
                } elsif (exists $procs{$callee_proc}{cus_abbrev}) {
                  print REPORT " $CUSTOM_ABBREV_STRING";
                } elsif(scalar keys %{$procs{$callee_proc}{definitions}} == 0) {
                  print REPORT " ($UNDEFINED_STRING)";
                  $has_no_def_callee  = 1;
                }

                if (&_IsDead(\$callee_proc)) {
                  print REPORT " $DEAD_STRING";
                  $has_dead_callee = 1;
                }
                if (&_IsDoNotPrune(\$callee_proc)) {
                  print REPORT " $DO_NOT_PRUNE_STRING";
                }
                if ($callee_proc eq $proc) {
                  print REPORT " (recursive)";
                  $is_recursive = 1;
                }
                
                if (exists $procs{$callee_proc}{cus_abbrev}) {
                  $has_cus_abbrev_callee  = 1;
                }
                if (exists $procs{$callee_proc}{cus_ambigu}) {
                  $has_cus_ambigu_callee  = 1;
                }
              }
              
              
              #List vendor command callees next.
              foreach my $callee_proc (sort keys %ven_proc_callees) {
                if (    ($vendor_count == 0) 
                     && ($custom_count > 0)) {
                  print REPORT "\n   |";  
                }
                $vendor_count++;
                print REPORT "\n   |--$callee_proc"; 
                if (exists $procs{$callee_proc}{ven_ambigu}) {
                  print REPORT " $VENDOR_AMBIG_STRING";
                } else {
                  my $ven_bucket_name = &_GetVendorProcBucketName($callee_proc);
                  print REPORT " (Vendor $ven_bucket_name command)";
                  if (!($ven_bucket_name =~/DC/)) {
                    $DC_compatible  = 0;
                  }
                  if (    !($ven_bucket_name =~/ICC$/)
                       && !($ven_bucket_name =~/ICC-only/)
                       && !($ven_bucket_name =~/ICC\//)) {
                    $ICC_compatible   = 0;
                  }
                  if (!($ven_bucket_name =~/ICC2/)) {
                    $ICC2_compatible  = 0;
                  }
                  if (!($ven_bucket_name =~/FC/)) {
                    $FC_compatible  = 0;
                  }
                  if (!($ven_bucket_name =~/PT/)) {
                    $PT_compatible  = 0;
                  }
                  if (!($ven_bucket_name =~/genus/)) {
                    $genus_compatible  = 0;
                  }
                  if (!($ven_bucket_name =~/innovus/)) {
                    $innovus_compatible  = 0;
                  }
                }
                if (exists $procs{$callee_proc}{ven_abbrev}) {
                  $has_ven_abbrev_callee  = 1;
                }
                if (exists $procs{$callee_proc}{ven_ambigu}) {
                  $has_ven_ambigu_callee  = 1;
                }
              }

              #Finally list Tcl builtin callees.
              foreach my $callee_proc (sort keys %builtin_callees) {
                if (    ($builtin_count == 0) 
                     && (    ($custom_count   > 0)
                          || ($vendor_count > 0))) {
                  print REPORT "\n   |";  
                }
                $builtin_count++;
                print REPORT "\n   |--$callee_proc (Tcl builtin)";  
              }
            }

            if ($defs_count == 0) {
              print REPORT "$UNDEFINED_STRING";
            } elsif ($callee_count == 0) {
              print REPORT "$NA_STRING";
            }
            print REPORT "\n";

            if ($vendor_checks_on) {
              print REPORT 
                "|--Vendor tool compatibility: ";
              if ($defs_count == 0) {
                print REPORT "$UNDEFINED_STRING\n";
              } else { 
                my $str         = "";
                if ($::DC && $DC_compatible) {
                  $str = "DC";
                }
                if ($::ICC && $ICC_compatible) {
                  if ($str ne "") {$str .= "/";}
                  $str .= "ICC";
                }
                if ($::ICC2 && $ICC2_compatible) {
                  if ($str ne "") {$str .= "/";}
                  $str .= "ICC2";
                }
                if ($::FC && $FC_compatible) {
                  if ($str ne "") {$str .= "/";}
                  $str .= "FC";
                }
                if ($::PT && $PT_compatible) {
                  if ($str ne "") {$str .= "/";}
                  $str .= "PT";
                }
                if ($::genus && $genus_compatible) {
                  if ($str ne "") {$str .= "/";}
                  $str .= "genus";
                }
                if ($::innovus && $innovus_compatible) {
                  if ($str ne "") {$str .= "/";}
                  $str .= "innovus";
                }
                if (    ($str ne "")
                     && !($str =~/\//)
                     && (($::DC + $::ICC + $::ICC2 + $::FC + $::PT + $::genus + $::innovus) > 1)) {
                  $str .= "-only";
                }
                if ($str eq "") {
                  $str = $NA_STRING;
                }
                
                print REPORT "$str\n";
                
                if ($DC_compatible) {
                  push(@procs_DC_compatible, $proc);
                }
                if ($ICC_compatible) {
                  push(@procs_ICC_compatible, $proc);
                }
                if ($ICC2_compatible) {
                  push(@procs_ICC2_compatible, $proc);
                }
                if ($FC_compatible) {
                  push(@procs_FC_compatible, $proc);
                }
                if ($PT_compatible) {
                  push(@procs_PT_compatible, $proc);
                }
                if ($genus_compatible) {
                  push(@procs_genus_compatible, $proc);
                }
                if ($innovus_compatible) {
                  push(@procs_innovus_compatible, $proc);
                }
                if (    !$DC_compatible
                     && !$ICC_compatible
                     && !$ICC2_compatible
                     && !$FC_compatible
                     && !$PT_compatible
                     && !$genus_compatible
                     && !$innovus_compatible
                     && !($defs_count == 0)) {
                  print REPORT "Warning: This procedure isn't "
                    . "compatible with " . &_GetVendorToolNames() . ".\n";
                  push(@procs_incompatible, $proc);
                }
              }

              if ($has_uneven_suppress) { 
                print REPORT "Warning: This procedure has unmatched "
                  . "(un)suppress_message calls.\n";
                push(@procs_uneven_suppress, $proc);
              }
              if ($generic_proc) {
                print REPORT 
                  "Information: This procedure is generic, calling Tcl builtins only.\n";
                push(@procs_generic, $proc);
              }
              if ($is_tool_conditional) { 
                print REPORT "Warning: This procedure has a "
                  . "vendor tool-specific switch.\n";
                push(@procs_tool_cond, $proc);
              }
              if ($has_ven_abbrev_callee) { 
                print REPORT "Warning: This procedure has a callee that is a "
                  . "vendor abbreviated command.\n";
                push(@procs_ven_abbrev_callee, $proc);
              }
              if ($has_ven_ambigu_callee) { 
                print REPORT "Warning: This procedure has a callee that is a "
                  . "vendor ambiguous command abbreviation.\n";
                push(@procs_ven_ambigu_callee, $proc);
              }
              if ($has_cus_abbrev_callee) { 
                print REPORT "Warning: This procedure has a callee that is a "
                  . "custom abbreviated procedure.\n";
                push(@procs_cus_abbrev_callee, $proc);
              }
              if ($has_cus_ambigu_callee) { 
                print REPORT "Warning: This procedure has a callee that is a "
                  . "custom ambiguous procedure abbreviation.\n";
                push(@procs_cus_ambigu_callee, $proc);
              }
            }

            if ($is_recursive) { 
              print REPORT "Warning: This procedure has a "
                . "recursive call back to itself.\n";
              push(@procs_recursive, $proc);
            }
            if (!$is_dead_proc && $has_dead_callee) { 
              print REPORT "Warning: This procedure is executed but has a "
                . "callee that isn't.\n";
              push(@procs_dead_callee, $proc);
            }
            if (!$is_dead_proc && $has_no_def_callee) { 
              print REPORT "Warning: This procedure is executed but has a "
                . "callee with no definition.\n";
              push(@procs_no_def_callee, $proc);
            }

            #Print out procedure's sourced files.
            print REPORT "|--sourcees: ";
            my $tracked_sourcee_count     = 0;
            my $not_tracked_sourcee_count = 0;
            if (exists $procs{$proc}{sourcees}) {
              my $sourced_files = \%{$procs{$proc}{sourcees}};
              #List sourcees that are tracked first.
              foreach my $sourcee (sort keys %{$sourced_files}) {
                if (&_IsSourceFileTracked(\$sourcee)) {
                  $tracked_sourcee_count++;
                  print REPORT "\n   |--$sourcee";  
                  if (&_IsDead(\$sourcee)) {
                    print REPORT " $DEAD_STRING";
                    $has_dead_callee = 1;
                  }
                  if (&_IsDoNotPrune(\$sourcee)) {
                    print REPORT " $DO_NOT_PRUNE_STRING";
                  }
                }
              }
              #Next list sourcees that aren't tracked.
              foreach my $sourcee (sort keys %{$sourced_files}) {
                if (!(&_IsSourceFileTracked(\$sourcee))) {
                  if (    ($not_tracked_sourcee_count == 0) 
                       && ($tracked_sourcee_count > 0)) {
                    print REPORT "\n   |";  
                  }
                  $not_tracked_sourcee_count++;
                  print REPORT "\n   |--$sourcee";  
                  if (&_IsDead(\$sourcee)) {
                    print REPORT " $DEAD_STRING";
                    $has_dead_callee = 1;
                  }
                  if (&_IsDoNotPrune(\$sourcee)) {
                    print REPORT " $DO_NOT_PRUNE_STRING";
                  }
                  print REPORT " $NOT_TRACKED_STRING";
                } 
              }
            }
            my $sourcee_count 
              = $tracked_sourcee_count + $not_tracked_sourcee_count;
            if ($defs_count == 0) {
              print REPORT "$UNDEFINED_STRING";
            } elsif ($sourcee_count == 0) {
              print REPORT "$NA_STRING";
            }
            print REPORT "\n";
            if ($sourcee_count > 0) {
              push(@procs_with_sourcing, $proc);
              print REPORT "Warning: This procedure is sourcing Tcl files.\n";
            }
          } else {
            #Generate report for vendor command only.
            my $reduced_bucket_name = &_GetVendorProcBucketName($proc);
            print REPORT "|--definition: ";
            print REPORT "(Vendor $reduced_bucket_name command)\n";
            if (!($reduced_bucket_name =~/DC/)) {
              $DC_compatible = 0;
            }
            if (    !($reduced_bucket_name =~/ICC$/)
                 && !($reduced_bucket_name =~/ICC-only/)
                 && !($reduced_bucket_name =~/ICC\//)) {
              $ICC_compatible = 0;
            }
            if (!($reduced_bucket_name =~/ICC2/)) {
              $ICC2_compatible  = 0;
            }
            if (!($reduced_bucket_name =~/FC/)) {
              $FC_compatible  = 0;
            }
            if (!($reduced_bucket_name =~/PT/)) {
              $PT_compatible  = 0;
            }
            if (!($reduced_bucket_name =~/genus/)) {
              $genus_compatible  = 0;
            }
            if (!($reduced_bucket_name =~/innovus/)) {
              $innovus_compatible  = 0;
            }

            if (    !$DC_compatible
                 && !$ICC_compatible
                 && !$ICC2_compatible
                 && !$FC_compatible
                 && !$PT_compatible
                 && !$genus_compatible
                 && !$innovus_compatible) {
              print REPORT "Warning: This procedure isn't "
                . "compatible with " . &_GetVendorToolNames() . ".\n";
              push(@procs_incompatible, $proc);
            } else {
              if ($DC_compatible) {
                push(@procs_DC_compatible, $proc);
              }
              if ($ICC_compatible) {
                push(@procs_ICC_compatible, $proc);
              }
              if ($ICC2_compatible) {
                push(@procs_ICC2_compatible, $proc);
              }
              if ($FC_compatible) {
                push(@procs_FC_compatible, $proc);
              }
              if ($PT_compatible) {
                push(@procs_PT_compatible, $proc);
              }
              if ($genus_compatible) {
                push(@procs_genus_compatible, $proc);
              }
              if ($innovus_compatible) {
                push(@procs_innovus_compatible, $proc);
              }
            }
          }

          #Print out procedure's caller procs.
          print REPORT "|--callers: ";
          my $caller_count  = 0;
          if (exists $procs{$proc}{callers}) {
            my $callers = \%{$procs{$proc}{callers}};
            foreach my $caller (sort keys %{$callers}) {
              if (    $report_dead_code_too
                   || !(&_IsDead(\$caller))
                   || (&_IsDoNotPrune(\$caller))) {
