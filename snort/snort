sub _ReplaceCommasWithSpaces($) {
  my $line = shift;

  $line =~s/^\s+//;

  while ($line =~/,\s+/) {
    $line =~s/,\s+/ /;
  }
  
  while ($line =~/\s\s+/) {
    $line =~s/\s\s+/ /;
  }

  return $line;
}

sub PruneCode($) {
  my $prune_files_only = shift;

  my $abbrev_filename = $REPORT_PRUNE_ACTUAL;

  print "#" . &_GetTime() . "> Entering &PruneCode($prune_files_only).\n" if $::DEBUG;
  
  &_GetOptionsAndReadConfigFile();
  my $filename  = "$REPORTS_DIR\/$abbrev_filename";
  print "Information: Writing file '$filename'.\n";
  open(REPORT, "> $filename") 
    || die "(PruneCode():38) Error: Can't open $filename for writing!\n";

  my $proc_report = "$REPORTS_DIR\/$ALL_DIR\/$REPORT_CUSTOM_PROCS";
  (-f $proc_report) 
    || die "(PruneCode():39) Error: Can't open $proc_report for reading!\n";
  #Get the list of procs to be pruned.
  my $grep_out        = `grep \"$PROCS_NOT_EXECUTED_HEADER\" $proc_report`;
  $grep_out           =~s/^$PROCS_NOT_EXECUTED_HEADER//;
  chomp($grep_out);
  $grep_out           = &_ReplaceCommasWithSpaces($grep_out);
  
  #Strip off :: prefix. 
  $grep_out =~s/^:://;
  while ($grep_out =~/\s::/) {
    $grep_out =~s/\s::/ /;
  }

  my @dead_procs      = split " ", $grep_out;
  $grep_out           = `grep \"$PROCS_DO_NOT_PRUNE_HEADER\" $proc_report`;
  $grep_out           =~s/^$PROCS_DO_NOT_PRUNE_HEADER//;
  chomp($grep_out);
  $grep_out           = &_ReplaceCommasWithSpaces($grep_out);
  my @no_prune_procs  = split " ", $grep_out;
  my @prune_procs     = @{_GetAndNotList(\@dead_procs, \@no_prune_procs)};

  print "#" . &_GetTime() . "> Procs to prune = @prune_procs\n" if $::DEBUG;

  my $file_report  = "$REPORTS_DIR\/$ALL_DIR\/$REPORT_SOURCE_FILES";
  (-f $file_report) 
    || die "(PruneCode():40) Error: Can't open $file_report for reading!\n";
  #Get the list of files to be pruned.
  $grep_out           = `grep \"$FILES_NOT_EXECUTED_HEADER\" $file_report`;
  $grep_out           =~s/^$FILES_NOT_EXECUTED_HEADER//;
  chomp($grep_out);
  $grep_out           = &_ReplaceCommasWithSpaces($grep_out);
  my @dead_files      = split " ", $grep_out;
  $grep_out           = `grep \"$FILES_DO_NOT_PRUNE_HEADER\" $file_report`;
  $grep_out           =~s/^$FILES_DO_NOT_PRUNE_HEADER//;
  chomp($grep_out);
  $grep_out           = &_ReplaceCommasWithSpaces($grep_out);
  my @no_prune_files  = split " ", $grep_out;
  my @prune_files     = @{_GetAndNotList(\@dead_files, \@no_prune_files)};

  my $total_lines_before  = 0;
  my $total_lines_after   = 0;

  foreach my $tcl_file (@{&_GetAllTclFilesInPath()}) {
    if (!($tcl_file =~/\/template_[a-zA-Z0-9_]+\.tcl/)) {
      my $abbrev_tcl_file = &_GetAbbrevFile(\$tcl_file);
      $file_all_abbrev{$abbrev_tcl_file} = 1;
      print REPORT "Processing $tcl_file";
      my $num_lines_before  = `grep -c ^ $tcl_file`;
      my $num_lines_after   = $num_lines_before;
   
      #If a file is in the do_not_prune list, don't allow pruning of either the 
      #file itself or its procedures defined.                                   
      if (!&_IsInList(\$abbrev_tcl_file, \@no_prune_files)) { 
        if (&_IsInList(\$abbrev_tcl_file, \@prune_files)) {
          if (    (!defined $::PRUNE_PARENT_DIR)
               || (index(realpath($tcl_file),realpath($::PRUNE_PARENT_DIR)) >= 0)) {
            &_PruneFile($tcl_file);
            $num_lines_after  = 0;
          }
        } else {
          if (    !$prune_files_only
               && ((!defined $::PRUNE_PARENT_DIR)
                    || (index(realpath($tcl_file),realpath($::PRUNE_PARENT_DIR)) >= 0))) {
            &_PruneProcDefsFromFile(\@prune_procs, $tcl_file);
            $num_lines_after  = `grep -c ^ $tcl_file`;
          }
        }
      }

      my $num_pruned_lines  = $num_lines_before - $num_lines_after;
      if ($num_pruned_lines > 0) { 
        my $pcnt_pruned_lines = ($num_lines_before > 0) 
          ? (100.0 * $num_pruned_lines / $num_lines_before) : 0;
        print  REPORT " -> $num_pruned_lines lines "; 
        printf REPORT "(%3.1f", $pcnt_pruned_lines;
        print REPORT "%) pruned";
      } 
      print REPORT ".\n";
      $total_lines_after  += $num_lines_after; 
      $total_lines_before += $num_lines_before; 
    }
  }

  my $total_pruned_lines  = $total_lines_before - $total_lines_after;
  my $pcnt_pruned_lines   = ($total_lines_before > 0)
    ? (100.0 * $total_pruned_lines / $total_lines_before) : 0;
  printf REPORT "%d (%3.1f", $total_pruned_lines, $pcnt_pruned_lines;
  print REPORT "%) of $total_lines_before total lines "
    . "were pruned from Tcl files.\n";
    
  print "#" . &_GetTime() . "> Exiting  &PruneCode($prune_files_only).\n" if $::DEBUG;
  return;
}

sub GetFormalName($) {
  my $name = shift;
  if ($name =~/^[^:]+::/) {
      $name = "::$name";
  }
  return $name;
}

sub PrintUsage($) {
  my $msg = shift;
  if ($msg) {
    print STDERR "Error: $0: $msg\n";
  }
  print "Usage: $0 [-?h] [-optionfile|-config <file.pl>]\n";
  exit 0;
}

#main()
&_GetOptionsAndReadConfigFile();
ReportAll() if (!$NOT_ANALYZE);
PruneCode(0) if $PRUNE;
PruneCode(1) if $PRUNE_FILES_ONLY;
__END__

=head1 NAME

snort -- Given paths to Tcl code, Snort performs a static analysis to identify dead code, call trees, heavily used code, etc.

=head1 SYNOPSIS

snort -optionfile|-config <file.pl>

=head1 DESCRIPTION

Snort looks in the provided option file to identify where all the Tcl code can be found and which files are the top-of-tree applications (as opposed to library code).  Snort is a static Tcl code analyzer that was originally written to study the converged RLS flow inherited for Poulson.  Snort is a Perl program which takes Tcl source code as input, performs a static analysis, and generates several useful reports for a variety of applications, including: code debug & traversal, code cleanup, porting legacy code to a new project, and automated dead code removal (requires a separate, back-end tool).  Snort has many vendor- and RLS-specific checks, however, it was written generally enough to be applied to any Tcl code.

=head1 OPTIONS

=over

=item B<-?>|B<-h>

Print the command's usage string or this man page

=item B<-prune>

If specified, this option prunes all dead files and procedures out of source Tcl files.  Since this option will modify the source code, a keystroke acknowledgement is required for safety.  This option cannot be combined with the -prune_files_only option.

=item B<-prune_files_only>

If specified, this option prunes all dead files out of source Tcl files.  Since this option will modify the source code, a keystroke acknowledgement is required for safety.  This option cannot be combined with the -prune option.

=item B<-prune_parent_dir> <dir>

Must be combined with the -prune or -prune_files_only options.  When specified, only those files under this parent directory will be pruned. Files outside of this parent directory will not be pruned.

=item B<-no_analysis>

This option can be combined with the -prune or -prune_files_only options to skip the analysis step and save time if snort was previously applied to the source code.

=item B<-svn>

When combined with the -prune or -prune_files_only option, this performs the pruning in a svn-compatible way.

=item B<-p4>

When combined with the -prune or -prune_files_only option, this performs the pruning in a p4-compatible way.

=item B<-optionfile|-config> <file.pl>

This indicates which configuration option file to load.  By default, it will load a file named "config.pl" if found in the current directory.

The option file is a Perl file that set the @path and @top_of_tree_paths arrays as well as several optional variables.  The list of variables are described below:

our @paths = ( "fullpath to all directories and/or Tcl filenames to search");  THIS ARRAY IS REQUIRED!  Shell wildcards are okay.

our @top_of_tree_paths = ( "full path to all top-of-tree application filenames for the application");  THIS ARRAY IS REQUIRED!  Shell wildcards are okay.

our @tcl_file_extensions = ("valid extensions for Tcl files to look at");  Defaults to (".tcl");

our @non_tcl_file_extensions = ("valid extensions for non-Tcl files to look at");  Defaults to ();

our @do_not_prune_list = ("Tcl files and/or procedures that should not be pruned, regardless if they are marked as being dead"); Defaults to ();

our @ignore_list = ("Tcl files and/or procedures that should be ignored altogether in the analysis"); Defaults to ();

our @potential_log_proc_names = ("names of known print procedures");  This is a hint the helps Snort distinguish procedures named in log statements from actual procedure calls.  Defaults to ().

our @reserved_procs_files = ( "fullpath directories to text files containing reserved Tcl procedure names for the application.");  Defaults to ("$snort_utils_dir/tcl_builtins.txt");

our $REPORTS_DIR = "place to create report directory";  Defaults to "./reports".

our $vendor_checks_on = enables vendor tool-specific checks;  If enabled, the @reserved_proc_files array is ignored.   Defaults to 0.

=back

=head1 UNSUPPORTED

embedded namespaces (ie., namespace defined either within a namespace or procedure definition)

embedded procedures within another procedure definition (flagged as warnings but not otherwise tracked.)

package requires

Object-Oriented Tcl (*.itcl)

=head1 KNOWN DEFECTS

If a procedure has multiple definitions, some of which are dead, the ./reports/pruned/report.custom_procs will still show callees from the dead definitions.

