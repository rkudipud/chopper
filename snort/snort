      printf REPORT 
        "   %4d (%4.1f", $num_procs_sans_namespace,
        $pcnt_procs_sans_namespace;
      print REPORT "%) with names used with/without a namespace.\n";

      printf REPORT 
        "   %4d (%4.1f", $num_procs_embedded_procs, $pcnt_procs_embedded_procs;
      print REPORT "%) with embedded procedure definitions.\n";
      
      printf REPORT "   %4d (%4.1f",
        $num_procs_short_definition, $pcnt_procs_short_definition;
      print REPORT "%) with definitions <=$SHORT_DEFINITION lines.\n";
      
      printf REPORT "   %4d (%4.1f",
        $num_procs_generic, $pcnt_procs_generic;
      print REPORT "%) that call Tcl builtins only.\n\n";
    
      
      
      print REPORT "   Miscellaneous checks:\n";
      printf REPORT
        "   %4d (%4.1f", $num_procs_with_sourcing, $pcnt_procs_with_sourcing;
      print REPORT "%) that are sourcing Tcl files.\n";
      
      printf REPORT
        "   %4d (%4.1f", $num_procs_recursive, $pcnt_procs_recursive;
      print REPORT "%) with a recursive call back to itself.\n";
      
      printf REPORT
        "   %4d (%4.1f", $num_procs_dead_callee, $pcnt_procs_dead_callee;
      print REPORT "%) are executed but have callees that aren't.\n";
      
      printf REPORT
        "   %4d (%4.1f", $num_procs_no_def_callee, $pcnt_procs_no_def_callee;
      print REPORT "%) are executed but have callees with no definition.\n";
      
      printf REPORT
        "   %4d (%4.1f", $num_procs_builtin_coll, $pcnt_procs_builtin_coll;
      print REPORT 
        "%) with names that collide with a Tcl builtin procedure name.\n";
      
      printf REPORT "   %4d (%4.1f",
        $num_procs_var_builtin_coll, $pcnt_procs_var_builtin_coll;
      print REPORT "%) that set variables colliding with a Tcl builtin "
        . "procedure name.\n\n";
 
      
      
      print REPORT "   RLS-specific checks:\n";
      printf REPORT
        "   %4d (%4.1f", $num_procs_proj_cond, $pcnt_procs_proj_cond;
      print REPORT "%) with a project-specific switch.\n";
      printf REPORT
        "   %4d (%4.1f", $num_procs_fubp_code, $pcnt_procs_fubp_code;
      print REPORT "%) with fubp-related code.\n";
      printf REPORT
        "   %4d (%4.1f", $num_procs_lib_hardcode, $pcnt_procs_lib_hardcode;
      print REPORT "%) that have library hardcoding.\n";
      printf REPORT
        "   %4d (%4.1f", $num_procs_getenv, $pcnt_procs_getenv;
      print REPORT "%) that access an environment variable.\n";
      printf REPORT
        "   %4d (%4.1f", $num_procs_setenv, $pcnt_procs_setenv;
      print REPORT "%) that set an environment variable.\n";
      printf REPORT
        "   %4d (%4.1f", $num_procs_proj_name, $pcnt_procs_proj_name;
      print REPORT "%) with a project in their name.\n";
      printf REPORT
        "   %4d (%4.1f", $num_procs_mislabeled, $pcnt_procs_mislabeled;
      print REPORT "%) that are labeled incorrectly in log files.\n";
    }
    print REPORT "\n";

    if ($vendor_checks_on) {
      print REPORT "   Vendor-specific checks:\n";
      if ($custom_not_vendor_procs) {
        printf REPORT "   %4d (%4.1f",
          $num_procs_sans_description, $pcnt_procs_sans_description;
        print REPORT "%) with no description.\n";
      } 
      if ($::DC) {
        printf REPORT
          "   %4d (%4.1f", $num_procs_DC_compatible, $pcnt_procs_DC_compatible;
        print REPORT "%) are DC-compatible.\n";
      }
      if ($::ICC) {
        printf REPORT
          "   %4d (%4.1f", $num_procs_ICC_compatible, $pcnt_procs_ICC_compatible;
        print REPORT "%) are ICC-compatible.\n";
      }
      if ($::ICC2) {
        printf REPORT
          "   %4d (%4.1f", $num_procs_ICC2_compatible, $pcnt_procs_ICC2_compatible;
        print REPORT "%) are ICC2-compatible.\n";
      }
      if ($::FC) {
        printf REPORT
          "   %4d (%4.1f", $num_procs_FC_compatible, $pcnt_procs_FC_compatible;
        print REPORT "%) are FC-compatible.\n";
      }
      if ($::PT) {
        printf REPORT
          "   %4d (%4.1f", $num_procs_PT_compatible, $pcnt_procs_PT_compatible;
        print REPORT "%) are PT-compatible.\n";
      }
      if ($::genus) {
        printf REPORT
          "   %4d (%4.1f", $num_procs_genus_compatible, $pcnt_procs_genus_compatible;
        print REPORT "%) are genus-compatible.\n";
      }
      if ($::innovus) {
        printf REPORT
          "   %4d (%4.1f", $num_procs_innovus_compatible, $pcnt_procs_innovus_compatible;
        print REPORT "%) are innovus-compatible.\n";
      }
      printf REPORT "   %4d (%4.1f",
        $num_procs_incompatible, $pcnt_procs_incompatible;
      print REPORT "%) aren't compatible with " . &_GetVendorToolNames() . ".\n";
    
      if ($custom_not_vendor_procs) {
        printf REPORT "   %4d (%4.1f",
          $num_procs_uneven_suppress, $pcnt_procs_uneven_suppress;
        print REPORT "%) with unmatched suppress_message calls.\n";
        printf REPORT
          "   %4d (%4.1f", $num_procs_tool_cond, $pcnt_procs_tool_cond;
        print REPORT "%) with a vendor tool-specific switch.\n";
        printf REPORT
          "   %4d (%4.1f", $num_procs_ven_coll, $pcnt_procs_ven_coll;
        print REPORT 
          "%) with names that collide with vendor command names.\n";
        printf REPORT "   %4d (%4.1f",
          $num_procs_ven_abbrev_coll, $pcnt_procs_ven_abbrev_coll;
        print REPORT "%) with names that collide with vendor abbreviated "
          . "commands.\n";
        printf REPORT "   %4d (%4.1f",
          $num_procs_ven_ambigu_coll, $pcnt_procs_ven_ambigu_coll;
        print REPORT "%) with names that are vendor ambiguous command "
          .  "abbreviations.\n";
        printf REPORT
          "   %4d (%4.1f", $num_procs_var_ven_coll, $pcnt_procs_var_ven_coll;
        print REPORT "%) that set variables colliding with a vendor "
          . "command name.\n";
        printf REPORT "   %4d (%4.1f", $num_procs_ven_abbrev_callee,
          $pcnt_procs_ven_abbrev_callee;
        print REPORT 
          "%) have callees that are vendor abbreviated commands.\n";
        printf REPORT "   %4d (%4.1f", $num_procs_ven_ambigu_callee,
          $pcnt_procs_ven_ambigu_callee;
        print REPORT "%) have callees that are vendor ambiguous command "
          . "abbreviations.\n";
        printf REPORT "   %4d (%4.1f", $num_procs_cus_abbrev_callee,
          $pcnt_procs_cus_abbrev_callee;
        print REPORT 
          "%) have callees that are custom abbreviated procedures.\n";
        printf REPORT "   %4d (%4.1f", $num_procs_cus_ambigu_callee,
          $pcnt_procs_cus_ambigu_callee;
        print REPORT "%) have callees that are custom ambiguous procedure "
          . "abbreviations.\n";
      }

      print REPORT "\n";
    }
  }

  print "#" . &_GetTime() . "> Exiting  &_GenTclProcReport("
    . "$custom_not_vendor_procs, $report_dead_code_too, " . "$filename).\n" if $::DEBUG;
  close REPORT;
}

{
  my $initialized  = 0;  #static variable
  sub _PopulateVendorProcsHash() {
    print "#" . &_GetTime() . "> Entering &_PopulateVendorProcsHash().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_PopulateVendorProcsHash().\n" if $::DEBUG;
      return;
    }

    my @vendor_command_files             = ();

    if ($::DC) {
      push(@vendor_command_files, "$snort_utils_dir/DC_commands.txt");
      push(@vendor_command_files, "$snort_utils_dir/DC-T_commands.txt");
    }
    if ($::ICC) {
      push(@vendor_command_files, "$snort_utils_dir/ICC_commands.txt");
      push(@vendor_command_files, "$snort_utils_dir/ICC_gui_commands.txt");
    }
    if ($::ICC2) {
      push(@vendor_command_files, "$snort_utils_dir/ICC2_commands.txt");
      push(@vendor_command_files, "$snort_utils_dir/ICC2_gui_commands.txt");
    }
    if ($::FC) {
      push(@vendor_command_files, "$snort_utils_dir/FC_commands.txt");
      push(@vendor_command_files, "$snort_utils_dir/FC_gui_commands.txt");
    }
    if ($::PT) {
      push(@vendor_command_files, "$snort_utils_dir/PT_commands.txt");
      push(@vendor_command_files, "$snort_utils_dir/PT_multi_scenario_commands.txt");
      push(@vendor_command_files, "$snort_utils_dir/PT_gui_commands.txt");
    }
    if ($::genus) {
      push(@vendor_command_files, "$snort_utils_dir/genus_commands.txt");
    }
    if ($::innovus) {
      push(@vendor_command_files, "$snort_utils_dir/innovus_commands.txt");
    }

    if ($vendor_checks_on) {
      #Step through each of the expected vendor command files, and generate   
      #any required files that don't already exist.                             
      foreach my $filename (@vendor_command_files) {
        unless (-e $filename) {
          system("mkdir -p /tmp/$ENV{USER}");
          my $temp_tcl_file = "/tmp/$ENV{USER}/temp.tcl"; 
          print "Warning: Creating $filename...\n";
          if ($filename =~/DC(-T)?_commands.txt$/) {
            #---------------------------- Design Compiler Topographical ----------------------------
            #Choose the newest version of Design Compiler available. 
            #Added a workaround for a bad version installation.
            my $dc_shell_script = (split "\n", `ls /p/hdk/cad/designcompiler/?-*/bin/dc_shell | grep -v V-2023.12-SP4`)[-1];
            -x $dc_shell_script
              || die "Error: The dc_shell script '$dc_shell_script' is invalid!.\n";
            if ($filename =~/DC_commands.txt$/) {
              system("echo \"redirect -file $filename {help *}; exit 0\" > $temp_tcl_file");
              system("$dc_shell_script -f $temp_tcl_file");
            } elsif ($filename =~/DC-T_commands.txt$/) {
              system("echo \"redirect -file $filename {help *}; exit 0\" > $temp_tcl_file");
              system("$dc_shell_script -topographical_mode -f $temp_tcl_file");
            }
            system("rm -f command.log");
          } elsif ($filename =~/ICC(_gui)?_commands.txt$/) {
            #------------------------------------ IC Compiler --------------------------------------
            #Choose the newest version of IC Compiler available. 
            my $icc_shell_script = (split "\n", `ls /p/hdk/cad/iccompiler/?-*/bin/icc_shell`)[-1];
            -x $icc_shell_script
              || die "Error: The icc_shell script '$icc_shell_script' is invalid!\n";
            if ($filename =~/ICC_commands.txt$/) {
              system("echo \"redirect -file $filename {help *}; exit 0\" > $temp_tcl_file");
              system("$icc_shell_script -f $temp_tcl_file");
            } elsif ($filename =~/ICC_gui_commands.txt$/) {
              system("echo \"redirect -file $filename {help *}; exit 0\" > $temp_tcl_file");
              system("$icc_shell_script -gui -f $temp_tcl_file");
            }
            system("rm -f icc_output.txt command.log");
          } elsif ($filename =~/ICC2(_gui)?_commands.txt$/) {
            #----------------------------------- IC Compiler 2 -------------------------------------
            #Choose the newest version of IC Compiler II available. 
            my $icc2_shell_script = (split "\n", `ls /p/hdk/cad/iccompilerII/?-*/bin/icc2_shell`)[-1];
            -x $icc2_shell_script
              || die "Error: The icc2_shell script '$icc2_shell_script' is invalid!\n";
            if ($filename =~/ICC2_commands.txt$/) {
              system("echo \"redirect -file $filename {help *}; exit 0\" > $temp_tcl_file");
              system("$icc2_shell_script -f $temp_tcl_file");
            } elsif ($filename =~/ICC2_gui_commands.txt$/) {
              system("echo \"redirect -file $filename {help *}; exit 0\" > $temp_tcl_file");
              system("$icc2_shell_script -gui -f $temp_tcl_file");
            }
            system("rm -f icc2_output.txt icc2_command.log");
          } elsif ($filename =~/FC(_gui)?_commands.txt$/) {
            #----------------------------------- Fusion Compiler -----------------------------------
            system("which fc_shell > /dev/null") == 0
              || die "Error: The fc_shell script is not on path!\n";
            if ($filename =~/FC_commands.txt$/) {
              system("echo \"redirect -file $filename {help *}; exit 0\" > $temp_tcl_file");
              system("fc_shell -fe -f $temp_tcl_file");
            } elsif ($filename =~/FC_gui_commands.txt$/) {
              system("echo \"redirect -file $filename {help *}; exit 0\" > $temp_tcl_file");
              system("fc_shell -gui -fe -f $temp_tcl_file");
            }
            system("rm -f fc_output.txt fc_command.log");
          } elsif ($filename =~/PT(_[a-z]+)*_commands.txt$/) {
            #-------------------------------------- PrimeTime --------------------------------------
            system("which pt_shell > /dev/null > /dev/null") == 0
              || die "Error: The pt_shell script is not on path!\n";
            if ($filename =~/PT_commands.txt$/) {
              system("echo \"redirect -file $filename {help *}; exit 0\" > $temp_tcl_file");
              system("pt_shell -f $temp_tcl_file");
            } elsif ($filename =~/PT_multi_scenario_commands.txt$/) {
              system("echo \"redirect -file $filename {help *}; exit 0\" > $temp_tcl_file");
              system("pt_shell -multi_scenario -f $temp_tcl_file");
            } elsif ($filename =~/PT_gui_commands.txt$/) {
              system("echo \"redirect -file $filename {help *}; exit 0\" > $temp_tcl_file");
              system("pt_shell -gui -f $temp_tcl_file");
            }
            system("rm -f pt_shell_command.log");
          } elsif ($filename =~/genus_commands.txt$/) {
            #---------------------------------------- Genus ----------------------------------------
            system("which genus > /dev/null > /dev/null") == 0
              || die "Error: The genus script is not on path!\n";
            system("echo \"redirect $filename {help -command *}; exit 0\" > $temp_tcl_file");
            system("genus -f $temp_tcl_file");
            #Bug fix: Workaround for the fact that the sh command doesn't show up in the list.
            system("echo \"  sh:                   # Executes a command in a child process.\" >> $filename");
            system("rm -f genus.log genus.cmd");
          } elsif ($filename =~/innovus_commands.txt$/) {
            #--------------------------------------- Innovus ---------------------------------------
            system("which innovus > /dev/null > /dev/null") == 0
              || die "Error: The innovus script is not on path!\n";
            #It is not necessary to maintain separate gui and non-gui innovus command lists, since
            #the commands are the same.
            system("echo \"redirect $filename {help *}; exit 0\" > $temp_tcl_file");
            system("innovus -no_gui -disable_user_startup -files $temp_tcl_file");
            system("rm -f innovus.log* innovus.cmd* pegasus_ui_gui.log*");
          } 
        }
      }
      foreach my $filename (@vendor_command_files) {
        push(@reserved_procs_files, $filename);
      }
    }

    #Populate the vendor commands hash, organized by tool (ex: DC, ICC).
    foreach my $filename (@reserved_procs_files) {
      print "\nExtracting commands from $filename\n\n" if $::DEBUG;
      open(FILE, "< $filename") or die "(_PopulateVendorProcsHash():21) "
        . "Error: Can't open $filename for reading!\n";
      
      my $file_description  = "Builtins";
      if ($filename =~/DC/) {
        $file_description  = "DC";
      } elsif ($filename =~/ICC_/) {
        $file_description  = "ICC";
      } elsif ($filename =~/ICC2_/) {
        $file_description  = "ICC2";
      } elsif ($filename =~/FC_/) {
        $file_description  = "FC";
      } elsif ($filename =~/PT_/) {
        $file_description  = "PT";
      } elsif ($filename =~/genus/) {
        $file_description  = "genus";
      } elsif ($filename =~/innovus/) {
        $file_description  = "innovus";
      }

      if ($file_description eq "Builtins") {
        #The tcl_builtins.txt file was written out in the legacy format (ie., old way).
        my $is_builtin_proc = 0;
        my $skip_section    = 0;
        while (my $line = <FILE>) {
          if (!($line =~/> help$/)) {  #Ignore initial help line
            #Have we encountered a new category of procedure names?
            if ($line =~/:$/) {
              if ($line =~/^Builtins:/) {
                $is_builtin_proc = 1;
                $skip_section    = 0;
              #} elsif ($line =~/^Procedures:/) {
              #  $skip_section    = 1;
              } else {
                $is_builtin_proc = 0;
                $skip_section    = 0;
              }
            } elsif (!$skip_section) {
              $line =~s/^ //;               #Get rid of indentation.
              while ($line =~/,/) {         #Get rid of all commas.
                $line =~s/,//; 
              }
              my @words = split(" ", $line); 
              foreach my $word (@words) {
                #Procedures containing underscores in the Builtins section aren't 
                #core Tcl commands.  They are Vendor-specific Tcl commands.   
                if ($word =~/_/) {
                  $ven_procs{$file_description}{$word} = 1;
                } else {
                  #The source command is most definitely a Tcl Builtin.
                  if ($word eq "source") {
                    print "REGISTERING: $word (Builtins)\n" if $::DEBUG;
                    $ven_procs{Builtins}{$word} = 1;
                  } elsif ($is_builtin_proc) {
                    print "REGISTERING: $word (Builtins)\n" if $::DEBUG;
                    $ven_procs{Builtins}{$word} = 1;
                  } else {
                    print "REGISTERING: $word ($file_description)\n" if $::DEBUG;
                    $ven_procs{$file_description}{$word} = 1;
                  }
                }
                $ven_procs{All}{$word} = 1;
              }
            }
          }
        }
      } else {
        #Support the new help command output format for Synopsys tools (ie., new way).
        my $is_builtin_proc = 0;
        while (my $line = <FILE>) {
          if (!($line =~/> help/) && !($line =~/^$/)) {  #Ignore initial help line and blank lines.
            chomp($line);
            if (($file_description eq "genus") || ($file_description eq "innovus")) {
                if ($line=~/^\S/) { #Discard lines that aren't indented.
                    next;
                }
                $line =~s/\s+#.*//; #Discard comments.
                $line =~s/://; #Discard trailing colon after command names.
                if ($line =~/^$/) { #Skip lines that don't contain command names.
                    next;
                }
            }
            my @words = split(" ", $line); 
            my $command = $words[0]; 
            if ((defined($words[2])) && ($words[2] eq "Builtin")) {      
              print "REGISTERING: $command (Builtins)\n" if $::DEBUG;
              $ven_procs{Builtins}{$command} = 1;
            } else {
              print "REGISTERING: $command ($file_description)\n" if $::DEBUG;
              $ven_procs{$file_description}{$command} = 1;
            }
            $ven_procs{All}{$command} = 1;
          }
        }

        #Discard Synopsys commands that are simple abbreviations for convenience.
        foreach my $command (@::ignore_synopsys_abbrev_commands) {
          if (exists $ven_procs{$file_description}{$command}) { 
            my $is_abbreviated_command = 0;
            foreach my $command1 (keys %{$ven_procs{$file_description}}) {
              if ((index($command1, $command) == 0) && ($command1 ne $command)) {
                $is_abbreviated_command = 1;
              }
            } 
            if ($is_abbreviated_command) {
              print "DELETING (abbreviated): $command ($file_description)\n" if $::DEBUG;
              delete $ven_procs{$file_description}{$command};
              #Only delete the All reference if all other vendor tools aren't using it.
              if (    !(exists $ven_procs{DC}{$command})
                   && !(exists $ven_procs{ICC}{$command})
                   && !(exists $ven_procs{ICC2}{$command})
                   && !(exists $ven_procs{FC}{$command})
                   && !(exists $ven_procs{PT}{$command})
                   && !(exists $ven_procs{genus}{$command})
                   && !(exists $ven_procs{innovus}{$command})) {
                print "DELETING (abbreviated): $command\n" if $::DEBUG;
                delete $ven_procs{All}{$command};
              }
            }
          }
        }
      }
    }
   
    foreach my $ven_proc (keys %{$ven_procs{All}}) {
      if (!(exists $ven_procs{Builtins}{$ven_proc})) {
        if ($vendor_checks_on) {  #Only add vendor commands if they're enabled.
          $procs{$ven_proc}{exists}       = 1;
          $procs{$ven_proc}{is_ven_proc}  = 1;
          $procs{$ven_proc}{is_builtin}   = 0;
        }
      } else {
        $procs{$ven_proc}{exists}       = 1;
        $procs{$ven_proc}{is_ven_proc}  = 0;
        $procs{$ven_proc}{is_builtin}   = 1;
      }
      #Don't clobber the custom flag if it was already defined.  It's possible  
      #that a custom procedure can collide with a vendor or builtin command name.
      if (exists $procs{$ven_proc}) { 
        if (!(exists $procs{$ven_proc}{is_custom})) { 
          $procs{$ven_proc}{is_custom}    = 0;
        }
      }
    }

    #Add the Tcl builtins else and elseif manually.
    $procs{else}{exists}        = 1;
    $procs{else}{is_ven_proc}   = 0;
    $procs{else}{is_builtin}    = 1;
    
    $procs{elseif}{exists}      = 1;
    $procs{elseif}{is_ven_proc} = 0;
    $procs{elseif}{is_builtin}  = 1;

    $initialized  = 1;
    print "#" . &_GetTime() . "> Exiting  &_PopulateVendorProcsHash().\n" if $::DEBUG;
    return;
  }
}

sub PrintSynopsysProcGvimSyntax($) {
  my $filename  = shift;
 
  open(REPORT, "> $filename") || die "(PrintSynopsysProcGvimSyntax():22) "
    . "Error: Can't open $filename for writing!\n";

  &_PopulateVendorProcsHash();

  #Print out syntax info that can be added to a ~/.vim/syntax/tcl.vim file. 
  foreach my $section (sort keys %ven_procs) {
    if ($section ne "All") {
      my $line_header = "syn keyword tclSpecial         ";
      if ($section eq "Builtins") {
        print REPORT "\n\" Core Tcl Commands\n";
        $line_header = "syn keyword tclStatement       ";
      } else {  
        print REPORT "\n\" $section Tcl Commands\n";
      }
      my $print_line = $line_header;
      foreach my $proc (sort keys %{$ven_procs{$section}}) {
        if (((length $print_line) + (length $proc)) > 99) {
          print REPORT "$print_line\n";
          $print_line = $line_header;
        }
        $print_line = $print_line." $proc";
      }
      print REPORT "$print_line\n";
    }
  }
}

{
  my %bucketNames = (); #static variable
  sub _GetVendorProcBucketName($) {
    my $proc            = shift;

    #Has the bucket already been determined before and cached?
    my $key = "$proc";
    if (exists $bucketNames{$key}) {
      return $bucketNames{$key};
    }
   
    my $abbrev      = 0;
    if (exists $procs{$proc}{ven_abbrev}) {
      $abbrev                 = 1;
      my $ven_abbrev_proc     = $proc;
      my $vendor_procs_ref  = &_GetNonAbbrevVendorProcs();
      my $num_abbrev_matches  = 0;  
      foreach my $ven_proc (@{$vendor_procs_ref}) {
        #Count abbreviations only and not exact matches.
        if ((index($ven_proc, $ven_abbrev_proc) == 0) && ($ven_abbrev_proc ne $ven_proc)) {
          $num_abbrev_matches++;
          $proc = $ven_proc;
        }
      }
      if ($num_abbrev_matches != 1) {
        print STDERR "Error: Couldn't find non-abbreviated vendor command for "
          . "$ven_abbrev_proc!\n";
        exit(1);
      }
    }

    my $ret_val         = "";
    my $usage_bit_mask  = 0;
    if (exists $ven_procs{DC}{$proc}) {
      $usage_bit_mask += 1;
      $ret_val = "DC";
    }
    if (exists $ven_procs{ICC}{$proc}) {
      $usage_bit_mask += 2;
      if ($ret_val ne "") {$ret_val .= "/";}
      $ret_val .= "ICC";
    }
    if (exists $ven_procs{ICC2}{$proc}) {
      $usage_bit_mask += 4;
      if ($ret_val ne "") {$ret_val .= "/";}
      $ret_val .= "ICC2";
    }
    if (exists $ven_procs{FC}{$proc}) {
      $usage_bit_mask += 8;
      if ($ret_val ne "") {$ret_val .= "/";}
      $ret_val .= "FC";
    }
    if (exists $ven_procs{PT}{$proc}) {
      $usage_bit_mask += 16;
      if ($ret_val ne "") {$ret_val .= "/";}
      $ret_val .= "PT";
    }
    if (exists $ven_procs{genus}{$proc}) {
      $usage_bit_mask += 32;
      if ($ret_val ne "") {$ret_val .= "/";}
      $ret_val .= "genus";
    }
    if (exists $ven_procs{innovus}{$proc}) {
      $usage_bit_mask += 64;
      if ($ret_val ne "") {$ret_val .= "/";}
      $ret_val .= "innovus";
    }

    if (    ($ret_val ne "")
         && !($ret_val =~/\//)
         && (($::DC + $::ICC + $::ICC2 + $::FC + $::PT + $::genus + $::innovus) > 1)) {
      $ret_val .= "-only";
    }

    if ($usage_bit_mask == 0) {
      print STDERR "Error: Unexpected usage_bit_mask value = $usage_bit_mask for procedure = '$proc'!\n";
    }
  
    if ($abbrev) {
      $ret_val = "abbreviated, " . $ret_val;
    }
    $bucketNames{$key}  = $ret_val;

    return  $ret_val;
  }
}

################################################################################
#void = _ParseTclSourceFile($file_name);                                        
#                                                                               
#Parse file is used whenever a file is sourced. It goes through each line of the
#file searching for a proc declaration. When it finds one it counts curly braces
#to find the end of the function.  After the end of the function is found, it   
#then searches for the define_proc_attributes function in order to try to find  
#the info for the function.  Any non-comment lines that are not part of a       
#function are collected.  After the file has been parsed, these lines are then  
#passed to the code parser and treated as regular code.                         
################################################################################
sub _ParseTclSourceFile($) {
  my $file            = shift;
  print "#" . &_GetTime() . "> Entering &_ParseTclSourceFile($file).\n" if $::DEBUG;
  
  my $file_key        = "";
  my $open_count      = 0;      #Number of curly braces that are currently open.
  my $namespace       = ""; 
  my $namespace_level = -1;
  my $proc            = "";
  my $proc_level      = -1;
  my %procs_found     = ();
  my $defs_ref        = {};
  my $num_lines       = 0;
  $other_code{$file}  = "";

  $files{$file}{proc_definitions} = [];

  open(IN, "<$file") || die "(_ParseTclSourceFile():23) "
    . "Error: Can't open $file for reading!\n";
  
  #Step through entire file.
  my $first_line              = 1;
  if (stat($file)->mode & 0111) {
    $files{$file}{executable} = 1;
  }
  
  while (<IN>) {
    print "OC=$open_count, NS=$namespace, NL=$namespace_level, PR=$proc, PL=$proc_level, LINE0=$_" if $::DEBUG;
    study;

    if (    ($first_line)
         && (    ($_ =~/^#!\s*\/usr\/bin\/env\s+tclsh/)
              || ($_ =~/^#!\s*\/usr\/bin\/tclsh/)
              || ($_ =~/^#!\s*\/usr\/intel\/bin\/tclsh/)
              || ($_ =~/^#!\s*\/usr\/local\/bin\/tclsh/))) {
      print "File $file is a unix script.\n" if $::DEBUG;
      $files{$file}{unix_script} = 1; 
    }
    $first_line = 0;

    #Set namespace only if we're not already inside of a procedure or namespace.
    if (    ($_ =~/^namespace\s+eval\s.*\s\{/) 
         && ($proc eq "")
         && ($namespace eq "")) {
      #Don't bother recording namespace if it's declared only for a single line.
      my ($curly_delta, $curly_found) = &_CurlyCount2($_);
      if (!($curly_found && ($curly_delta == 0))) {
        $namespace        = &_ExtractNamespaceFromLine($_);
        $namespace_level  = $open_count;
      } 
      $open_count += $curly_delta;
      $other_code{$file}  .= $_;
      $num_lines++;   #This is a non-blank line.
    } elsif (    (m/^\s*proc\s+([^\s^\(^\[]+)\s/i) #Start of procedure definition?
              && ($proc eq "")) {
      #Form the procedure's full name and then add it to the hash.
      $proc = &_GetFullProcName($namespace, $1); 

      push(@{$files{$file}{proc_definitions}}, $proc);

      $proc_level = $open_count;
      my ($curly_delta, $curly_found) = &_CurlyCount2($_);
      $open_count += $curly_delta;
      
      $num_lines++;   #This is a non-blank line.
      
      $file_key = $file;
      if (!(exists $procs_found{$proc})) {
        $procs_found{$proc} = 1;
      } else {
        $procs_found{$proc}++;
        $file_key .= "(" . $procs_found{$proc} . ")";  #Add unique suffix.
      }
      $defs_ref = \%{$procs{$proc}{definitions}};
      if (!(exists $defs_ref->{$file_key})) {  #Sanity check.
        die "(_ParseTclSourceFile():24) Error: Can't cross-reference "
          . "procedure '$proc' against internal hash for $file_key.\n";
      } elsif ($defs_ref->{$file_key} ne $UNDEF) {
        die "(_ParseTclSourceFile():25) Error: Definition for '$proc' " 
          . "is already populated in internal hash for $file_key.\n";
      }
      print "DEFN: $proc => $file_key\n" if $::DEBUG;
      #If the procedure was marked speculative, mark it as being legit now.
      if (exists $procs{$proc}{speculative}) {
        $procs{$proc}{speculative} = 0;
      }

      $defs_ref->{$file_key} = "";  #Initialize definition.

      #Reset procedure if this was a 1-line definition.
      if ($curly_found && ($curly_delta == 0) && !($_ =~/\\$/)) {
        if ($_ =~/\{\s*\}\*$/) {  #Definition is assumed to be empty.
          warn 
            "Warning: Definition contents ignored for '$proc' in $file_key.\n";
        }
        $proc         = "";
        $proc_level   = -1;
      }
    } elsif (    ($namespace ne "")   #Inside of a namespace?
              || ($proc ne "")) {     #Inside of a procedure definition?
      if (m/^\s*proc\s+([^\s^\{^\(]+)/i) {
        $procs{$proc}{embedded_proc}  = 1;
      }

      #If we're already inside a procedure or namespace, count the curly braces.
      $open_count +=  &_CurlyCount($_);

      #Store the entire namespace or procedure definition, excluding comments   
      #and whitespace, except for last line.  Are we still in the definition?   
      if (    (    ($namespace ne "") 
                && ($open_count > $namespace_level)
                && ($proc eq ""))
           || (    ($proc ne "") 
                && ($open_count > $proc_level))) {
        my $reduced_code_line = $_;
        $reduced_code_line  =~s/^\s+//;   #Eliminate whitespace at start of line.
        $reduced_code_line  =~s/^#.*//;   #Eliminate comments at start of line.
        #Eliminate comments elsewhere in the line.
        if (    ($reduced_code_line =~/#.*$/) 
             && !($reduced_code_line =~/upvar.*#/)
             && !($reduced_code_line =~/\".*#/)) {
          $reduced_code_line    =~s/#.*$//;
        }
        #Replace all instances of whitespace with a single space each.
        while ($reduced_code_line =~/\s\s+/) { 
          $reduced_code_line    =~s/\s\s+/ /;
        } 
        while ($reduced_code_line =~/\t/) { 
          $reduced_code_line    =~s/\t/ /;
        } 
        $reduced_code_line    =~s/\s$//;
        chomp($reduced_code_line);
        #Add semicolon at the end of command lines as needed.
        if (    !($reduced_code_line =~/;$/)  
             && !($reduced_code_line =~/{$/)
             && !($reduced_code_line =~/}$/)
             && !($reduced_code_line =~/^$/)) {
          $reduced_code_line .= ";";
        }
        
        #Eliminate whitespace differences around relational operators in if clauses.
        if ($reduced_code_line =~/if\s+\{([^\}]+)\}\s+\{/) {
          my $expr  = $1;
          $expr =~s/^\s+//;
          $expr =~s/\s+$//;

          #Insert 1 space character on both sides of relational operators if needed (x3).
          #Note: The ordering of the relational operators below matters.
          if ($expr =~s/(\S)(==|<=|>=|!=|>|<)/$1 $2/) {
            if ($expr =~s/(\S)(==|<=|>=|!=|>|<)/$1 $2/) {
              $expr =~s/(\S)(==|<=|>=|!=|>|<)/$1 $2/;
            }
          }
          if ($expr =~s/(==|<=|>=|!=|>|<)(\S)/$1 $2/) {
            if ($expr =~s/(==|<=|>=|!=|>|<)(\S)/$1 $2/) {
              $expr =~s/(==|<=|>=|!=|>|<)(\S)/$1 $2/;
            }
          }
          
          #Use a standard 1 space character on either side of a relational operator (x2).
          if ($expr =~s/(\s+)(==|<=|>=|!=|>|<)/ $2/) {
            if ($expr =~s/(\s+)(==|<=|>=|!=|>|<)/ $2/) {
              $expr =~s/(\s+)(==|<=|>=|!=|>|<)/ $2/;
            }
          }
          if ($expr =~s/(==|<=|>=|!=|>|<)(\s+)/$1 /) {
            if ($expr =~s/(==|<=|>=|!=|>|<)(\s+)/$1 /) {
              $expr =~s/(==|<=|>=|!=|>|<)(\s+)/$1 /;
            }
          }

          #Corner-case undos
          $expr =~s/\\ (==|<=|>=|!=|>|<)/\\$1/;
          if ($expr =~s/(>|<) =/$1=/) {
            if ($expr =~s/(>|<) =/$1=/) {
              $expr =~s/(>|<) =/$1=/;
            }
          }

          $reduced_code_line =~s/if\s+\{([^\}]+)\}\s+\{/if \{$expr\} \{/;
        }

        #Eliminate blank lines.
        if (&_IsNonBlankLine($_)) { 
          $num_lines++;
          if ($proc ne "") {
            $defs_ref->{$file_key} .= $reduced_code_line . "\n";
          } else {
            $other_code{$file} .= $_;
          }
        } 
      } else {
        #If we made it here, we've exited the namespace or procedure definition.
        if (&_IsNonBlankLine($_)) { 
          $num_lines++;
        } 

        #Should the namespace be reset?
        if ($open_count <= $namespace_level) {
          $namespace        = ""; 
          $namespace_level  = -1;
        }

        #If we've just exited a procedure definition, then look for the optional
        #define_proc_attributes section.                                        
        my $prev_proc = $proc;

        #Reset the procedure, unconditionally.  If we just exited a namespace   
        #and not a procedure, this action is harmless.                          
        $proc         = "";
        $proc_level   = -1;
        $_            = <IN>;
        if ($DEBUG && defined $_) {
          print "OC=$open_count, NS=$namespace, NL=$namespace_level, PR=$proc, PL=$proc_level, LINE1=$_";
        }
        while ($_ && !m/^[^#]*define_proc_(attributes|arguments)\s+/ && !m/^\s*proc/) {
          my ($curly_delta, $curly_found) = &_CurlyCount2($_);
          #Set the namespace only if we're not already inside of a namespace.
          if (    ($_ =~/^namespace\s+eval\s.*\s\{/) 
               && ($namespace eq "")) {
            #Don't record namespace if it's declared only for a single line.
            if (!($curly_found && ($curly_delta == 0))) {
              $namespace        = &_ExtractNamespaceFromLine($_);
              $namespace_level  = $open_count;
            } 
            $other_code{$file}  .= $_;
            $num_lines++;   #This is a non-blank line.
          } else {
            #Current line is a non-procedure code line.

            #Inside the loop, lines which are not comments should be kept.
            if (&_IsNonBlankLine($_)) {
              $other_code{$file} .= $_;
              $num_lines++;
            }
          }
          $open_count += $curly_delta;
        
          #Should the namespace be reset?
          if ($open_count <= $namespace_level) {
            $namespace        = ""; 
            $namespace_level  = -1;
          }

          $_ = <IN>;
          if ($DEBUG && defined $_) {
            $open_count       = $UNDEFINED_STRING if (!defined $open_count);
            $namespace        = $UNDEFINED_STRING if (!defined $namespace);
            $namespace_level  = $UNDEFINED_STRING if (!defined $namespace_level);
            $proc             = $UNDEFINED_STRING if (!defined $proc);
            $proc_level       = $UNDEFINED_STRING if (!defined $proc_level);
            print "OC=$open_count, NS=$namespace, NL=$namespace_level, PR=$proc, PL=$proc_level, LINE2=$_";
            if ($_ eq "") {
              print "\n";
            } 
          }
        }

        #Check if end of file was reached.
        last if (!$_);
        
        if (&_IsNonBlankLine($_)) {
          $num_lines++;
        }
            
        #At this point, there should be a new proc or a define_proc_attributes. 
        if (m/^\s*proc\s+([^\s^\(^\[]+)\s/i) {
          #Form the procedure's full name and then add it to the hash.
          $proc = &_GetFullProcName($namespace, $1); 
          
          push(@{$files{$file}{proc_definitions}}, $proc);
         
          $proc_level = $open_count;
          my ($curly_delta, $curly_found) = &_CurlyCount2($_);
          $open_count += $curly_delta;

          $file_key = $file;
          if (!(exists $procs_found{$proc})) {
            $procs_found{$proc} = 1;
          } else {
            $procs_found{$proc}++;
            $file_key .= "(" . $procs_found{$proc} . ")";  #Add unique suffix.
          }
          $defs_ref = \%{$procs{$proc}{definitions}};
          if (!(exists $defs_ref->{$file_key})) {  #Sanity check.
            die "(_ParseTclSourceFile():26) Error: Can't cross-reference "
              . "procedure '$proc' against internal hash for $file_key.\n";
          } elsif ($defs_ref->{$file_key} ne $UNDEF) {
            die "(_ParseTclSourceFile():27) Error: Definition for '$proc' "
              . "is already populated in internal hash for $file_key.\n";
          }
          print "DEFN: $proc => $file_key\n" if $::DEBUG;
          #If the procedure was marked speculative, mark it as being legit now.
          if (exists $procs{$proc}{speculative}) {
            $procs{$proc}{speculative} = 0;
          }

          $defs_ref->{$file_key} = "";  #Initialize definition.
      
          #Reset procedure if this was a 1-line definition.
          if ($curly_found && ($curly_delta == 0) && !($_ =~/\\$/)) {
            if ($_ =~/\{\s*\}\*$/) {  #Definition is assumed to be empty.
              warn "Warning: Definition contents ignored for "
                . "'$proc' in $file_key.\n";
            }
            $proc         = "";
            $proc_level   = -1;
          }
        
        } else {
          #We're in a define_proc_attributes section.  Extract the procedure    
          #name, and get the entire define_proc_attributes definition read in.  
          $proc = &_GetDefineProcAttributesProcName($_);
          $proc = &_GetFullProcName($namespace, $proc);

          if ($proc ne $prev_proc) { 
            $other_code{$file} .= $_;
          }

          my $def_func      = $_;
          my $curly_count   = &_CurlyCount($_);
          $open_count       += $curly_count;
          while ((m/\s*\\\s*$/ || $curly_count > 0) && ($_ = <IN>)) {
            print "OC=$open_count, NS=$namespace, NL=$namespace_level, PR=$proc, PL=$proc_level, LINE3=$_" if $::DEBUG;
            my $curly_delta =  &_CurlyCount($_);
            $curly_count    +=  $curly_delta;
            $open_count     +=  $curly_delta;
            $def_func     .= $_;
            $num_lines++;
            if ($proc ne $prev_proc) { 
              $other_code{$file} .= $_;
            }
          }

          #Extract the procedure's description from the define_proc_attributes  
          #definition only if it matches the procedure that was just defined    
          #(if applicable).                                                     
          if ($proc eq $prev_proc) { 
            if ($def_func =~ m/-info "([^"]+)"/) {
              $procs{$proc}{description} = $1;
            }
          }

          $proc = "";
        }
      }

      #Otherwise pull the line into an other lines var.
    } else {
      #Current line is a non-procedure code line.
      $open_count +=  &_CurlyCount($_);
      if (&_IsNonBlankLine($_)) {
        $other_code{$file} .= $_;
        $num_lines++;
      }
    }
  }

  #Make sure that the file had the same number of opening and closing braces.
  if ($open_count != 0) {
    $files{$file}{uneven_braces} = 1;
  }

  my $num_proc_definitions  = scalar (keys %procs_found);
  if ($num_proc_definitions == 0) {
    $non_proc_violations{no_procs}{$file} = 0;
  }
  
  $files{$file}{length}  = $num_lines;
  
  print "#" . &_GetTime() . "> Exiting  &_ParseTclSourceFile($file).\n" if $::DEBUG;
  close IN;
}

{
  my @tcl_files   = (); #static variable
  my $initialized = 0;  #static variable
  sub _GetAllTclFilesInPath() {
    print "#" . &_GetTime() . "> Entering &_GetAllTclFilesInPath().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_GetAllTclFilesInPath().\n" if $::DEBUG;
      return \@tcl_files;
    }

    my $all_files_ref = &_GetAllFilesInPath();
    foreach my $file (@{$all_files_ref}) {
      if (&_IsTclFile(\$file)) { 
        push(@tcl_files, $file); 
      } 
    }
    
    $initialized  = 1;
    print "#" . &_GetTime() . "> Exiting  &_GetAllTclFilesInPath().\n" if $::DEBUG;
    return \@tcl_files;
  }
}

{
  my @all_files   = (); #static variable
  my $initialized = 0;  #static variable
  sub _GetAllFilesInPath() {
    print "#" . &_GetTime() . "> Entering &_GetAllFilesInPath().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_GetAllFilesInPath().\n" if $::DEBUG;
      return \@all_files;
    }

    my %paths_found         = ();
    my $file_extensions_ref = &_GetAllFileExtensions();

    foreach my $path (@paths) {

      #If there are multiple slashes in a row, often due to a config bug, replace them with just a  
      #single slash otherwise the same equivalent path could show up multiple times.
      while ($path =~/\/\/+/) {
        $path =~s/\/\/+/\//;
      }

      #Warn user and ignore duplicates if a path was specified more than once.
      if (exists $paths_found{$path}) {
        warn "Warning: Ignoring duplicate path '$path' found.\n";
      } else {
        $paths_found{$path} = 1;
        if (-f $path) {         #Is the path a file?
          my $abbrev_file = &_GetAbbrevFile(\$path);
          if (    !(&_IsInList(\$abbrev_file, \@ignore_list))
               && !(&_IsInList(\$path, \@ignore_list))
               && !(&_IsInList(\$path, \@all_files))) {
            print "Information: Processing file '$path'.\n"; 
            push(@all_files, $path);
          }
        } else {
          my @raw_ls_output = ();
          if (-d $path) {       #Is the path a directory?
            &_ChompDir(\$path);
            @raw_ls_output = `ls -d -- $path/*`;
          } else {              #The path has a wildcard.
            @raw_ls_output = `ls -d -- $path`;
          }
          foreach my $raw_ls_line (@raw_ls_output) {
            chomp($raw_ls_line); 
            if ($raw_ls_line =~/^ls:\s.*No\s/) {
              die "(_GetAllFilesInPath():28) Error: Invalid path '$path'!\n";
            }
              
            #Check list against configured file extensions.
            my $has_valid_extension = 0; 
            foreach my $file_extension (@{$file_extensions_ref}) {
              my $regexp_file_extension = "\\" . $file_extension;
              if ($raw_ls_line =~/$regexp_file_extension$/) {
                $has_valid_extension  = 1; 
              }
            }
            if ($has_valid_extension) {
              my $abbrev_file = &_GetAbbrevFile(\$raw_ls_line);
              if (    !(&_IsInList(\$abbrev_file, \@ignore_list))
                   && !(&_IsInList(\$raw_ls_line, \@ignore_list))
                   && !(&_IsInList(\$raw_ls_line, \@all_files))) {
                #Ignore files in the OBSOLETE directories.
                if (!($raw_ls_line =~/\/OBSOLETE\//)) {
                  print "Information: Processing file '$raw_ls_line'.\n"; 
                  push(@all_files, $raw_ls_line); 
                }
              }
            }
          }
        } 
      }
    }  

    my $top_of_tree_files_ref = &_GetTopOfTreeFiles();
    foreach my $top_of_tree_file (@{$top_of_tree_files_ref}) {
      
      #If there are multiple slashes in a row, often due to a config bug, replace them with just a  
      #single slash otherwise the same equivalent path could show up multiple times.
      while ($top_of_tree_file =~/\/\/+/) {
        $top_of_tree_file =~s/\/\/+/\//;
      }
      
      if (!(&_IsInList(\$top_of_tree_file, \@all_files))) {
        my $abbrev_file = &_GetAbbrevFile(\$top_of_tree_file);
        if (!(&_IsInList(\$abbrev_file, \@ignore_list))) {
          warn "Warning: Adding top-of-tree file '$top_of_tree_file' to paths.\n";
          print "Information: Processing file '$top_of_tree_file'.\n"; 
          push(@all_files, $top_of_tree_file); 
        }
      }
    }

    $initialized  = 1;
    print "#" . &_GetTime() . "> Exiting  &_GetAllFilesInPath().\n" if $::DEBUG;
    return \@all_files;
  }
}

{
  my @top_of_tree_files = (); #static variable
  my $initialized       = 0;  #static variable
  sub _GetTopOfTreeFiles() {
    print "#" . &_GetTime() . "> Entering &_GetTopOfTreeFiles().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_GetTopOfTreeFiles().\n" if $::DEBUG;
      return \@top_of_tree_files;
    }
    
    my $file_extensions_ref = &_GetAllFileExtensions();
    foreach my $top_of_tree_path (@top_of_tree_paths) {
      if (-f $top_of_tree_path) {   #Is the path a file?
        push(@top_of_tree_files, $top_of_tree_path);
      } else {
        my @raw_ls_output = ();
        if (-d $top_of_tree_path) { #Is the path a directory?
          &_ChompDir(\$top_of_tree_path);
          @raw_ls_output = `ls -d -- $top_of_tree_path/*`;
        } else {                    #The path has a wildcard.
          @raw_ls_output = `ls -d -- $top_of_tree_path`;
        }
        foreach my $raw_ls_line (@raw_ls_output) {
          chomp($raw_ls_line); 
          if ($raw_ls_line =~/^ls:\s.*No\s/) {
            die "(_GetTopOfTreeFiles():29) "
              . "Error: Invalid top-of-tree path '$top_of_tree_path'!\n";
          }
          
          #Check list against configured file extensions.
          my $has_valid_extension = 0; 
          foreach my $file_extension (@{$file_extensions_ref}) {
            my $regexp_file_extension = "\\" . $file_extension;
            if ($raw_ls_line =~/$regexp_file_extension$/) {
              $has_valid_extension  = 1; 
            }
          }
          if ($has_valid_extension) {
            push(@top_of_tree_files, $raw_ls_line); 
          }
        }
      }
    }  
      
    $initialized  = 1;
    print "#" . &_GetTime() . "> Exiting  &_GetTopOfTreeFiles().\n" if $::DEBUG;
    return \@top_of_tree_files;
  }
}

{
  my  $initialized            = 0;
  my  $top_of_tree_files_ref;
  sub _IsTopOfTreeFile($) {
    my  $fref = shift;

    if (!$initialized) { 
      $top_of_tree_files_ref  = &_GetTopOfTreeFiles();
      $initialized = 1;
    } 
  
    my  $ret_val  = 0;
    #First for non-abbreviated filename matches.
    if (($$fref =~/\//) && (&_IsInList($fref, $top_of_tree_files_ref))) {
      $ret_val = 1;
    } else {
      #Now look for abbreviated filename matches.
      foreach my $top_of_tree_file (@{$top_of_tree_files_ref}) {
        my $abbrev_top_of_tree_file = &_GetAbbrevFile(\$top_of_tree_file);
        if ($$fref eq $abbrev_top_of_tree_file) {
          $ret_val = 1;
        }
      }
    }
    
    return $ret_val;
  }
}

{
  my $initialized = 0;
  sub _MakeRdtprojFiles() {
    our (%flowprochash);
    our (%stageprochash);
    my ($FH_flows, $FH_stages, $FILE, $line, $word, @words, @flowcomments, @stagecomments);
    
    #make separate directory for new files containing the procs
    &_CreateReportsDirectory();
    mkpath("$REPORTS_DIR/$TCL_DIR") || die "(_MakeRdtprojFiles():1) "
      . "Error: Can't create directory $REPORTS_DIR\/$TCL_DIR!\n";
    my $flows_filename   = "$REPORTS_DIR/$TCL_DIR/flows.tcl";
    my $stages_filename  = "$REPORTS_DIR/$TCL_DIR/stages.tcl";

    if (scalar @::flow_setup_paths == 0) {
        warn "Warning: No flow setup paths defined.\n";
        return;
    }

    #create file handles
    open($FH_flows, '>', $flows_filename) or die "(_MakeRdtprojFiles():2) Could not open file $flows_filename $!\n";
    open($FH_stages, '>', $stages_filename) or die "(_MakeRdtprojFiles():3) Could not open file $stages_filename $!\n";

    #indicators to kep track of line numbers in the two output files
    my $flow_line_num  = 1; 
    my $stage_line_num = 1;
    
    #source stage file at the beginning of flow file
    print $FH_flows "source ".realpath($stages_filename) . "\n\n";
    $flow_line_num += 2;

    #initialize variables
    my @ignoreword  = (
      "[list",
      "[join",
      "[concat",
      "\\",
      "\"\\"
    );
    my $indent        = "    ";
    my $current_flow  = "";
    my $current_stage = "";
   
    my $flow_name     = "";
    my %flow_proc_guts_hash;
    my @flow_proc_guts_cache;
    my %stage_proc_guts_hash;
    my @stage_proc_guts_cache;

    foreach my $flowsetupfile (@::flow_setup_paths) {

      print "Information: Parsing RDT flow setup file '$flowsetupfile'.\n";

      open($FILE, '<', $flowsetupfile) or die "(_MakeRdtprojFiles():4) Could not open $flowsetupfile $!\n";

      print $FH_flows "# PARSING FILE: $flowsetupfile\n\n";
      $flow_line_num += 2;
      print $FH_stages "# PARSING FILE: $flowsetupfile\n\n";
      $stage_line_num += 2;

      my $curly_count       = 0;
      my $ignore_block      = 0; 
      my $curly_threshold   = 0;
      my $if_clause_line    = "";

      while ($line = $FILE->getline()) {
        #print "LINE=$line\n"; 
        #skip whole line if comment
        if ($line =~ m/^\#/) {
          next;
        }

        my $this_lines_curly_count = &_CurlyCount($line);

        #Simplifying assumption: Ignore the contents inside of if-clauses.
        if (($line =~/^\s*if\s/) && ($this_lines_curly_count > 0) && !$ignore_block) {
            $if_clause_line   = $line;
            print $FH_flows "# IF-CLAUSE IGNORED: $if_clause_line\n";
            $flow_line_num += 2;
            print $FH_stages "# IF-CLAUSE IGNORED: $if_clause_line\n";
            $stage_line_num += 2;
            
            $curly_threshold = $curly_count;
            $ignore_block    = 1;
            $curly_count     += $this_lines_curly_count;
            next; 
        }
        if ($ignore_block) {
            $curly_count     += $this_lines_curly_count;
            if ($curly_count <= $curly_threshold) {
                $ignore_block     = 0;
                $curly_threshold  = 0;
            }
            next;
        }
            
        $curly_count     += $this_lines_curly_count;

        if ($line =~/^\s*setvar\s+G_FLOW\s+(\S+)\s*$/) {
          if (($flow_name ne "") && ($flow_name ne $1)) {
            die "(_MakeRdtprojFiles():5) Error: Can't support >1 G_FLOW setting!\n";
          }
          $flow_name = $1;
        }

        #Make sure that [getvar G_FLOW_STAGES(floorplan)] calls like this are one word.
        while ($line =~/\[\s+/) {
          $line =~s/\[s+/\[/;
        }
        while ($line =~/getvar\s+/) {
          $line =~s/getvar\s+/getvar_/;
        }
        while ($line =~/\s+\]/) {
          $line =~s/\s+\]/\]/;
        }

        #In the case where we are assinging just [getvar G_FLOW_STAGES(*)] or [getvar G_STEPS(*)]   
        #directly to a variable with nothing else, wrap it up in quotes so that the interpreter     
        #below will correctly interpret the command as ending in the current line (and not spanning 
        #multiple lines.                                                                            
        if (($line =~/setvar\s/) && ($line =~/getvar_/)) {
          if (!($line =~/[\}\"\{]/)) {
            $line =~s/\[getvar_G_FLOW_STAGES\(([^)]+)\)\]/\"\[getvar_G_FLOW_STAGES\($1\)\]\"/;
            $line =~s/\[getvar_G_STEPS\(([^)]+)\)\]/\"\[getvar_G_STEPS\($1\)\]\"/;
          }    
        }

        #TODO: Add support for rdt_remove_step command.

        #Support for the rdt_add_step command.
        if ($line =~/^\s*rdt_add_step\s+(\S+)\s+(\S+)\s+(\S+)\s+(\S+)\s*$/) {
          my $stage     = $1;
          my $type      = $2;
          my $step      = $3;
          my $new_step  = $4;
         
          #Strip off all quotes.
          $stage =~s/\"//;
          $stage =~s/\"//;
          $type =~s/\"//;
          $type =~s/\"//;
          $step =~s/\"//;
          $step =~s/\"//;
          $new_step =~s/\"//;
          $new_step =~s/\"//;

          print $FH_stages "#PROCESSING: $line";
          $stage_line_num += 1;
            
          if (exists $stage_proc_guts_hash{$stage}) {
            my $new_line = "setvar G_STEPS($stage) \{";
            my @sub_words = @{$stage_proc_guts_hash{$stage}};
            foreach my $sub_word (@sub_words) {
              if ($sub_word eq $step) {
                if ($type eq "pre") {
                  $new_line .= " $new_step";
                  $new_line .= " $sub_word";
                } elsif ($type eq "post") {
                  $new_line .= " $sub_word";
                  $new_line .= " $new_step";
                } else {
                  die "(_MakeRdtprojFiles():6) Error: Unsupported rdt_add_step type '$type'!\n";
                }
              } else {
                $new_line .= " $sub_word";
              }
            }
            $new_line .= " }";
            $line = $new_line;
          } else {
            die "(_MakeRdtprojFiles():7) Error: Can't resolve rdt_add_step because there's no definition for G_STEPS($stage)!\n";
          }
        }

        #Handle the case where stage steps are specified using quotes with no spaces in between.
        $line =~s/(\S)\"$/$1 "/;
        $line =~s/(\S)\"$/$1 "/;
        $line =~s/\"(\S)/" $1/;
        $line =~s/\"(\S)/" $1/;

        @words = split(' ',$line);
        my $prev_word_was_setvar = 0;
        my $quote_count = 0;

        #Process each word in the current line.
        foreach my $outer_word (@words) {
          #print "|--WORD0=$outer_word\n";
          my @sub_words;
         
          if ($outer_word =~/getvar_G_FLOW_STAGES\(([^)]+)\)/) {
            #Case: Substitute the contents of [getvar G_FLOW_STAGES(*)].
            my $flow_name0 = $1;
            if ($flow_name0 eq "[getvar_G_FLOW]") {
                $flow_name0 = $flow_name;
            }
            if (exists $flow_proc_guts_hash{$flow_name0}) {
              @sub_words = @{$flow_proc_guts_hash{$flow_name0}};
              #Preserve the trailing quote if there was one, to mark the end of the list.
              if ($outer_word =~/\"$/) {
                  push(@sub_words, "\"");
              }
            } else {
              die "(_MakeRdtprojFiles():8) Error: Can't resolve '$outer_word' because there's no definition for G_FLOW_STAGES($flow_name0)!\n";
            }
          } elsif ($outer_word =~/getvar_G_STEPS\(([^)]+)\)/) {
            #Case: Substitute the contents of [getvar G_STEPS(*)].
            my $stage = $1;
            if (exists $stage_proc_guts_hash{$stage}) {
              @sub_words = @{$stage_proc_guts_hash{$stage}};
              #Preserve the trailing quote if there was one, to mark the end of the list.
              if ($outer_word =~/\"$/) {
                  push(@sub_words, "\"");
              }
            } else {
              die "(_MakeRdtprojFiles():9) Error: Can't resolve '$outer_word' because there's no definition for G_STEPS($stage)!\n";
            }
          } else {
            @sub_words = ( "$outer_word" );
          }
        
          #Process the current word or expanded words (if command substitution was performed).
          foreach my $word (@sub_words) {
            if ($current_flow ne "") {
              #Case: currently inside a G_FLOW_STAGES variable
              if (&_IsInList(\$word, \@ignoreword)) {
                next;
              }
              
              $word =~ s/^\{//;
              if (($word =~ s/\}$//) || ($word =~ s/\]$//) || ($word =~ s/\"$//)) {
                if ($word ne "") {  #Handle the case of a trailing "]" in a list construct.
                  print $FH_flows $indent."STAGE_".$word . "\n";
                  push(@flow_proc_guts_cache, $word);
                  $flow_line_num += 1;
                }
                print $FH_flows "\}" . "\n\n";  #End of flow procedure definition.
                @{$flow_proc_guts_hash{$current_flow}} = @flow_proc_guts_cache;
              
                my $printed_something = 0;
                foreach my $word (@flow_proc_guts_cache) {
                    if (!$printed_something) { 
                        print $FH_flows "#Implicit RDT call for FLOW_$current_flow.\n";
                        $flow_line_num  += 1;
                        $printed_something = 1;
                    } 
                    
                    print $FH_flows "rdt_source_if_exists PRE.${word}.tcl\n";
                    print $FH_flows "rdt_source_if_exists -inclusive ${word}.tcl\n";
                    print $FH_flows "rdt_source_if_exists POST.${word}.tcl\n";
                    $flow_line_num  += 3;
                }
                if ($printed_something) {
                    print $FH_flows "\n";
                    $flow_line_num  += 1;
                }

                #Save the closing line number of the flow procedure definition
                @{ $flowprochash{$current_flow} }[1] = $flow_line_num;
                $flow_line_num  += 2;
                $current_flow   = "";
              } elsif ($word ne "") {
                print $FH_flows $indent."STAGE_".$word . "\n";
                push(@flow_proc_guts_cache, $word);
                $flow_line_num += 1;
              }
            } elsif ($current_stage ne "") {
              #Case: currently inside a G_STEPS variable 
              if (&_IsInList(\$word, \@ignoreword)) {
                next;
              }
             
              if ($word =~/^\"$/) {
                $quote_count++;
              }

              $word =~ s/^\{//;
              if (    ($word =~ s/\}$//)
                   || ($word =~ s/\]$//)
                   || (($word =~ s/\"$//) && ($quote_count == 2))) {
                if ($word ne "") {  #Handle the case of a trailing "]" in a list construct.
                  print $FH_stages $indent.$word . "\n";
                  push(@stage_proc_guts_cache, $word);
                  $stage_line_num += 1;
                }
                print $FH_stages "\}" . "\n\n";
                @{$stage_proc_guts_hash{$current_stage}} = @stage_proc_guts_cache;
                
                #save the closing line number of the step
                @{ $stageprochash{$current_stage} }[1] = $stage_line_num;
                $stage_line_num += 2;
                $current_stage  = "";
              } elsif ($word ne "") {
                print $FH_stages $indent.$word . "\n";
                push(@stage_proc_guts_cache, $word);
                $stage_line_num += 1;
              }
            } elsif ($prev_word_was_setvar && $word =~ s/^G_FLOW_STAGES\((.*)\)/$1/) {
              #Case: At the start of a G_FLOW_STAGES variable
              #If that flow already exists in hash table, record its start/end line numbers so it can be commented out later
              if (exists $flowprochash{$word}) {
                push @flowcomments, [@{$flowprochash{$word}}[0],@{$flowprochash{$word}}[1]];
              }
              #Store line number of new proc
              @{ $flowprochash{$word} }[0] = $flow_line_num;
              print $FH_flows "proc FLOW_".$word." \{" . "\n";
              $flow_line_num        += 1;
              $current_flow         = $word;
              @flow_proc_guts_cache = ();
            } elsif ($prev_word_was_setvar && $word =~ s/^G_STEPS\((.*)\)/$1/) {
              #Case: At the start of a G_STEPS variable 
              #If that step exists in hash table, record its start/end line numbers so it can be commented out later
              if (exists $stageprochash{$word}) {
                push @stagecomments, [@{$stageprochash{$word}}[0],@{$stageprochash{$word}}[1]];
              } 
              #Store line number of new proc
              @{ $stageprochash{$word} }[0] = $stage_line_num;
              print $FH_stages "proc STAGE_".$word." \{" . "\n";
              $stage_line_num         += 1;
              $current_stage          = $word;
              $quote_count            = 0;   
              @stage_proc_guts_cache  = ();
            }
            #Mark when the previous word was "setvar". This is a necesary criterion for cases 3 and 4.
            if (($word eq "setvar") || ($word eq "set")) {
              $prev_word_was_setvar = 1;
            } else {
              $prev_word_was_setvar = 0;
            }
          }
        }
      }
    }
    
    print "Information: Generating file '$flows_filename'.\n"; 
    print "Information: Generating file '$stages_filename'.\n"; 

    #TODO: Handle the corner-case where a flow or stage is defined different ways conditionally.    
    #It would be better to keep both definitions around, in that case, for dead code recognition.   

    # Use command to comment out desired blocks of code
    foreach my $block (@flowcomments) {
      system("sed -i '".@{$block}[0].",".@{$block}[1]." s/^/#/' $flows_filename");
    }
    foreach my $block (@stagecomments) {
      system("sed -i '".@{$block}[0].",".@{$block}[1]." s/^/#/' $stages_filename");
    }
    close $FH_flows;
    close $FH_stages;

    my @original_file_contents  = ();
    open($FH_stages, '<', $stages_filename) or die "(_MakeRdtprojFiles():3) Could not open file $stages_filename $!\n";
    while (my $line = $FH_stages->getline()) {
      push(@original_file_contents, $line);
    }
    close $FH_stages;

    #Add calls to all possible PRE and POST hook procedure names to the generated stages.tcl file.
    #Any PRE and POST hook procedures that aren't used will be deleted as part of _ParseAllTclFilesInPath.
    open($FH_stages, '>', $stages_filename) or die "(_MakeRdtprojFiles():3) Could not open file $stages_filename $!\n";
    $current_stage = ""; 
    foreach my $line (@{original_file_contents}) {
      if ($line =~/^#/) {
        print $FH_stages $line;
      } elsif ($line =~/^proc STAGE_(\S+) /) {
        $current_stage = $1;
        print $FH_stages $line;
        print $FH_stages "    PRE_all_steps\n";
        print $FH_stages "    POST_all_steps\n";
      } elsif ($line =~/^\s+(\S+)/) {
        my $proc = $1;
        my $pre_hook_line1 = $line;
        $pre_hook_line1 =~s/$proc/PRE_$proc/;
        my $pre_hook_line2 = $line;
        $pre_hook_line2 =~s/$proc/PRE_${current_stage}_$proc/;
        my $post_hook_line1 = $line;
        $post_hook_line1 =~s/$proc/POST_${current_stage}_$proc/;
        my $post_hook_line2 = $line;
        $post_hook_line2 =~s/$proc/POST_$proc/;
        print $FH_stages $pre_hook_line1;
        print $FH_stages $pre_hook_line2;
        print $FH_stages $line;
        print $FH_stages $post_hook_line1;
        print $FH_stages $post_hook_line2;
      } else {
        print $FH_stages $line;
      }
    } 
    close $FH_stages;

    #exit(0);
  }
}

{
  my $initialized = 0;  #static variable
  sub _ParseAllTclFilesInPath() {
    print "#" . &_GetTime() . "> Entering &_ParseAllTclFilesInPath().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_ParseAllTclFilesInPath().\n" if $::DEBUG;
      return;
    }
  
    &_FindAllTclProcs();
    &_FindTclProcDefsAndCalcUsage();

    foreach my $tcl_file (@{&_GetAllTclFilesInPath()}) {
      &_ParseTclSourceFile($tcl_file);
    }
      
    $initialized  = 1;
    &_ProcGarbageCollector();

    print "#" . &_GetTime() . "> Exiting  &_ParseAllTclFilesInPath().\n" if $::DEBUG;
    return;
  }
}

{
  my $initialized = 0;  #static variable
  sub _ProcGarbageCollector() {
    print "#" . &_GetTime() . "> Entering &_ProcGarbageCollector().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_ProcGarbageCollector().\n" if $::DEBUG;
      return;
    }
    
    &_ParseAllTclFilesInPath();

    foreach my $proc (keys %procs) {
      #Delete speculative procedures defined with and without a namespace.
      if (exists $procs{$proc}{speculative}) {
        if ($procs{$proc}{speculative} == 1) {
          delete $procs{$proc};
          print "DELETE (speculative): $proc\n" if $::DEBUG;
        }
      }

      #Delete procedures that should be ignored.
      if (&_IsInList(\$proc, \@ignore_list)) {
        delete $procs{$proc};
        print "DELETE (ignored): $proc\n" if $::DEBUG;
      }
   
      #Delete procedures that could be implicitly called by RDT but don't exist.
      if ($::RDT) {
        if (($proc =~/^PRE_/) || ($proc =~/^POST_/)) {
          if (scalar keys %{$procs{$proc}{definitions}} == 0) {
            print "DELETE (implicit unused): $proc\n" if $::DEBUG;
            delete $procs{$proc};
          }
        }
      }
    }

    $initialized  = 1;
    print "#" . &_GetTime() . "> Exiting  &_ProcGarbageCollector().\n" if $::DEBUG;
    return;
  }
}

{
  my $initialized = 0;  #static variable
  sub _FileGarbageCollector() {
    print "#" . &_GetTime() . "> Entering &_FileGarbageCollector().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_FileGarbageCollector().\n" if $::DEBUG;
      return;
    }
 
    if ($::RDT) {
      #For each stage defined within a flow, RDT will implicitly source the files ${stage_name}.tcl,
      #PRE.${stage_name}.tcl, and/or POST.${stage_name}.tcl if they exist and can be found on path. 
      #To mimic this behavior, all such combinations are sourced in flows.tcl file so that Snort can
      #recognize that those files are implicitly sourced.  The following code cleans up any files,  
      #that are sourced only by the flows.tcl file and  don't actually exist in the code analyzed.  
      
      #First, form the unique list of files that could be implicitly sourced by RDT if they exist.  
      #In this case, the files sourced will have abbreviated names and would not contain paths.     
      my $flows_filename        = "$REPORTS_DIR/$TCL_DIR/flows.tcl";
      my $flows_abbrev_filename = &_GetAbbrevFile(\$flows_filename);
      my %implitly_sourced_files = ();
      foreach my $sourcee_file (@{$files{$flows_filename}{sources}}) {
        $implitly_sourced_files{$sourcee_file} = 1;
      }

      my $tcl_files_in_path_ref = &_GetAllTclFilesInPath();
      foreach my $sourcee_file (keys %implitly_sourced_files) {
        my $abbrev_file           = $sourcee_file;
        my $file_exists           = 0;
        my $sourced_by_flows_file = 0;
        my $sourced_by_other_file = 0;
        foreach my $tcl_file (sort @{$tcl_files_in_path_ref}) {
          if ($tcl_file =~/\/$abbrev_file$/) {
            $file_exists = 1;
          }
          foreach my $sourcer_file (@{$file_sourced_by{$abbrev_file}}) {
            if ($sourcer_file eq $flows_filename) {
              $sourced_by_flows_file = 1
            } else {
              $sourced_by_other_file = 1
            }
          }
        }
       
        if (!$file_exists && $sourced_by_flows_file && !$sourced_by_other_file) {
          print "DELETE (implicit unused): $sourcee_file\n" if $::DEBUG;
          delete $files_abbrev{$sourcee_file};
          delete $file_sourced_by{$sourcee_file};
          delete $file_all_abbrev{$sourcee_file};

          #The delete commands above are not sufficient.  We must remove sources from the generated 
          #flows file.  Rewrite the sources list with all references to the deleted file removed.   
          my @new_flows_file_sources  = ();
          my $sourcee_file0; 
          foreach $sourcee_file0 (@{$files{$flows_filename}{sources}}) {
            if ($sourcee_file0 ne $sourcee_file) {
              push(@new_flows_file_sources, $sourcee_file0)
            }
          }
          @{$files{$flows_filename}{sources}} = @new_flows_file_sources;
        
          @new_flows_file_sources  = ();
          foreach $sourcee_file0 (@{$files_abbrev{$flows_abbrev_filename}{sources}}) {
            if ($sourcee_file0 ne $sourcee_file) {
              push(@new_flows_file_sources, $sourcee_file0)
            }
          }
          @{$files_abbrev{$flows_abbrev_filename}{sources}} = @new_flows_file_sources;
        }
      }
    }

    $initialized  = 1;
    print "#" . &_GetTime() . "> Exiting  &_FileGarbageCollector().\n" if $::DEBUG;
    return;
  }
}

{
  my $initialized = 0;  #static variable
  sub _AnalyzeNonProcTclCode() {
    print "#" . &_GetTime() . "> Entering &_AnalyzeNonProcTclCode().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_AnalyzeNonProcTclCode().\n" if $::DEBUG;
      return;
    }

    &_ParseAllTclFilesInPath();

    foreach my $tcl_file (@{&_GetAllTclFilesInPath()}) { 
      my @non_proc_code_lines  = split "\n", $other_code{$tcl_file};
      my $namespace_count     = 0;
      my $live_count          = 0;
      my $setenv_count        = 0;
      my $getenv_count        = 0;
      my $lib_hardcode_count  = 0;
      my $fubp_count          = 0;
      my $proj_cond_count     = 0;
      my $tool_cond_count     = 0;
      my $def_proc_attr_count = 0;
      my $continue_line       = 0;
      my $curly_count         = 0;
      my %procs_called        = ();
      my $suppress_delta      = 0;
      foreach my $line (@non_proc_code_lines) {
        #Find procedure calls.
        foreach my $callee_proc (keys %procs) {
          if ((index($line, $callee_proc) != -1) || ($callee_proc =~/[:\/\\]/)) { #performance optimization
            if (&_IsProcFoundInLine(\$callee_proc, \$line)) {
              #Don't report these Perl keywords masquerading as procedure calls,
              #even if they are custom procedures defined, as being called by   
              #templates because the templates contain embedded Perl.           
              if (!(    ($tcl_file =~/\/template_[a-zA-Z0-9_]+\.tcl/)
                     && (_IsInList(\$callee_proc, \@perl_keywords)))) {
                $procs_called{$callee_proc} = 1;
              }
            }
          }
        }

        #Identify files sourced.
        if ($line =~/source/) { #Performance optimization
          my $sourcee_file = &_ExtractSourcedFileFromLine(\$line);
          if (    ($sourcee_file ne "")
               && !(&_IsInList(\$sourcee_file, \@ignore_list))) {
            #If we made it here, we have a valid sourcer and sourcee.
            my $sourcer_file        = $tcl_file;
            my $abbrev_sourcer_file = &_GetAbbrevFile(\$sourcer_file);
            if (!(exists $files{$sourcer_file}{sources})) {
              $files{$sourcer_file}{sources} = [];
            }
            push(@{$files{$sourcer_file}{sources}}, $sourcee_file);
            if (!(exists $files_abbrev{$abbrev_sourcer_file}{sources})) {
              $files_abbrev{$abbrev_sourcer_file}{sources} = [];
            }
            push(@{$files_abbrev{$abbrev_sourcer_file}{sources}},
              $sourcee_file);
        
            if (&_IsSourceFileTracked(\$sourcee_file)) {
              if (!(exists $file_sourced_by{$sourcee_file})) {
                $file_sourced_by{$sourcee_file} = [];
              }
              push(@{$file_sourced_by{$sourcee_file}}, $sourcer_file);
              #Add sourcee to the hash for all Tcl files. If sourcee was already
              #on the path, it does nothing.  However not all sourcee's can be  
              #found on the path.                                               
              $file_all_abbrev{$sourcee_file} = 1;
            }
          }
        }
  

        #Filter out non-procedure code lines that are benign.
        if (    !($line =~/^\s*source\s/)
             && !($line =~/^\s*$/)
             && !($line =~/^\s*global\s/)
             && !($line =~/^\s*set\s.*_cmd_grp\s/)
             && !($line =~/^\s*set\s.*_command_group\s/)
             && !($line =~/^\s*set\s.*_CMD_GRP\s/)
             && !($line =~/^\s*set\s.*_CMD_GROUP\s/)
             && !($line =~/^\s*set\s.*_COMMAND_GROUP\s/)
             && !($line =~/^\s*create_command_group\s/)
             && !($line =~/^\s*alias\s/)
             && !($line =~/^\s*echo\s+\"/)
             && !($line =~/^\s*print_info\s+\"/)
             && !($line =~/^\s*inform_p\s+\"/)) {

          #Count define_proc_attributes instances once, even if they span lines.
          if ($curly_count > 0) {
            $curly_count  +=  &_CurlyCount($line);
          } elsif (!$continue_line) {
            my $found_bucket  = 0;
            
            if (&_IsSettingEnvVars(\$line, 1)) {
              $setenv_count++;
              $found_bucket = 1;
            } 
            if (&_IsGettingEnvVars(\$line)) {
              $getenv_count++;
              $found_bucket = 1;
            }
            if (&_HasLibraryHardcoding(\$line)) {
              $lib_hardcode_count++;
              $found_bucket = 1;
            }
            if (&_HasFubpRelatedCode(\$line)) {
              $fubp_count++;
              $found_bucket = 1;
            }
            if (&_HasProjectSpecificSwitch(\$line)) {
              $proj_cond_count++;
              $found_bucket = 1;
            }
            if (&_HasVendorToolSwitch(\$line)) {
              $tool_cond_count++;
              $found_bucket = 1;
            }

            $suppress_delta += &_CalcSuppressDelta(\$line);
            
            if ($line =~/^[^#]*define_proc_(attributes|arguments)\s+/) {
              $curly_count  +=  &_CurlyCount($line);
              $def_proc_attr_count++;
              $found_bucket = 1;
            } elsif ($line =~/^\s*namespace\s+eval\s+/) {
              $namespace_count++;
              $found_bucket = 1;
            } 
            #if ($line =~/set\s+/) { #Performance optimization
            #  my $var_name = &_ExtractSetVariableFromLine($line);
            #  if ($var_name ne "") {
            #    if (exists $procs{$var_name}) {
            #      if (exists $procs{$var_name}{is_builtin}) {
            #        $var_builtin_coll_count++;
            #        $found_bucket = 1;
            #      } elsif (exists $procs{$var_name}{is_ven_proc}) {
            #        $var_ven_coll_count++;
            #        $found_bucket = 1;
            #      }
            #    }
            #  } 
            #}
            
            if (!$found_bucket) {
              $live_count++;
            }
          }
        }
        if ($line =~/\\$/) {
          $continue_line = 1;
        } else {
          $continue_line = 0;
        }
      }
   
      if ($live_count > 0) {
        $non_proc_violations{live}{$tcl_file} = $live_count;
      }
      if ($setenv_count > 0) {
        $non_proc_violations{setenv}{$tcl_file} = $setenv_count;
      }
      if ($getenv_count > 0) {
        $non_proc_violations{getenv}{$tcl_file} = $getenv_count;
      }
      if ($lib_hardcode_count > 0) {
        $non_proc_violations{lib_hardcode}{$tcl_file} = $lib_hardcode_count;
      }
      if ($fubp_count > 0) {
        $non_proc_violations{fubp}{$tcl_file} = $fubp_count;
      }
      if ($proj_cond_count > 0) {
        $non_proc_violations{proj_cond}{$tcl_file} = $proj_cond_count;
      }
      if ($tool_cond_count > 0) {
        $non_proc_violations{tool_cond}{$tcl_file} = $tool_cond_count;
      }
      if ($def_proc_attr_count > 0) {
        $non_proc_violations{def_proc_attr}{$tcl_file} = $def_proc_attr_count;
      }
      if ($namespace_count > 0) {
        $non_proc_violations{namespace}{$tcl_file}  = $namespace_count;
      }
      if ($suppress_delta != 0) {
        $non_proc_violations{uneven_suppress}{$tcl_file}  = $suppress_delta;
      }

      #Step through each procedure called by the file.
      foreach my $callee_proc (keys %procs_called) {
        #Add this file to the callee procedure's caller list.
        if (!(exists $procs{$callee_proc}{callers})) {
          my %caller_procs = ();
          $caller_procs{$tcl_file} = 1;
          $procs{$callee_proc}{callers} = \%caller_procs;
        } else {
          my $caller_procs_ref = \%{$procs{$callee_proc}{callers}};
          $caller_procs_ref->{$tcl_file} = 1;
        }
       
        #Add the procedure to this file's callee list.
        if (!(exists $files{$tcl_file}{proc_callees})) {
          my %procs_called              = ();
          $procs_called{$callee_proc}   = 1;
          $files{$tcl_file}{proc_callees} = \%procs_called;
        } else {
          my $proc_callees_ref = \%{$files{$tcl_file}{proc_callees}};
          $proc_callees_ref->{$callee_proc} = 1;
        }
      }
    }

    $initialized  = 1;
    print "#" . &_GetTime() . "> Exiting  &_AnalyzeNonProcTclCode().\n" if $::DEBUG;
    return;
  }
}

sub ReportNonProcTclCode($) {
  my $report_dead_code_too  = shift; 

  my $abbrev_filename       = $REPORT_NON_PROC_CODE;
  
  print "#" . &_GetTime() 
    . "> Entering &ReportNonProcTclCode($report_dead_code_too).\n" if $::DEBUG;
 
  &_GetOptionsAndReadConfigFile();
  &_CreateReportsDirectory();
  &_AnalyzeNonProcTclCode();

  my $filename  = $report_dead_code_too
    ? "$REPORTS_DIR\/$ALL_DIR\/$abbrev_filename"
    : "$REPORTS_DIR\/$PRUNED_DIR\/$abbrev_filename";
  print "Information: Writing file '$filename'.\n";

  open(REPORT, "> $filename") || die "(ReportNonProcTclCode():30) "
    . "Error: Can't open $filename for writing!\n";

  #Form the subset of all *.tcl files that aren't designated top of trees.  Why?
  #Because the top of trees are expected to consist primarily of non-proc code. 
  my @non_top_of_tree_tcl_files = ();
  foreach my $tcl_file (@{&_GetAllTclFilesInPath()}) {
    if (!(&_IsTopOfTreeFile(\$tcl_file))) {
      push(@non_top_of_tree_tcl_files, $tcl_file);
    }
  }
  
  print REPORT 
    "Warning: Ignoring Tcl files designated as being top of tree.\n\n";

  foreach my $violation_type (sort keys %non_proc_violations) {
    my $description = "with non-conforming define_proc_attribute calls";
    if ($violation_type eq "live") {
      $description  = "with meaningful code lines outside of procedures";
    } elsif ($violation_type eq "setenv") {
      $description  = "that set environment variables";
    } elsif ($violation_type eq "namespace") {
      $description  = "with namespace declarations";
    } elsif ($violation_type eq "no_procs") {
      $description  = "with no procedures defined";
    } elsif ($violation_type eq "getenv") {
      $description  = "that access environment variables";
    } elsif ($violation_type eq "fubp") {
      $description  = "with fubp-related code";
    } elsif ($violation_type eq "proj_cond") {
      $description  = "with project-specific switches";
    } elsif ($violation_type eq "tool_cond") {
      $description  = "with vendor tool-specific switches";
    } elsif ($violation_type eq "lib_hardcode") {
      $description  = "that have library hardcoding";
    } elsif ($violation_type eq "uneven_suppress") {
      $description  = "with unmatched suppress_message calls";
    } elsif ($violation_type ne "def_proc_attr") {
      print STDERR "Error: Unrecognized violation type '$violation_type.'\n";
      exit(1);
    }

    #Calculate the number of files with this violation and max violations.
    my $num_files       = 0;
    my $max_violations  = 0;
    foreach my $tcl_file (@non_top_of_tree_tcl_files) {
      if (    (    ($report_dead_code_too) 
                || !(&_IsDead(\$tcl_file))
                || (&_IsDoNotPrune(\$tcl_file)))
           && (exists $non_proc_violations{$violation_type}{$tcl_file})) {
        $num_files++;
        my $num_violations  = $non_proc_violations{$violation_type}{$tcl_file}; 
        if ($num_violations > $max_violations) {
          $max_violations = $num_violations;
        }
      }
    }

    print REPORT "Found: $num_files Tcl files $description.\n";
    print REPORT "----------------------------------";
    print REPORT "----------------------------------\n";

    #List the files sorted by the number violations in each.
    while ($max_violations >= 0) {
      foreach my $tcl_file (@non_top_of_tree_tcl_files) {
        if (    (    ($report_dead_code_too) 
                  || !(&_IsDead(\$tcl_file))
                  || (&_IsDoNotPrune(\$tcl_file)))
             && (exists $non_proc_violations{$violation_type}{$tcl_file})) {
          my $num_violations = $non_proc_violations{$violation_type}{$tcl_file};
          if ($num_violations == $max_violations) {
            print REPORT "$tcl_file: $num_violations\n";
          }
        }
      }
      $max_violations--;
    }
    print REPORT "\n";
  }
 
  &_PrintDivider(*REPORT);

  foreach my $tcl_file (@non_top_of_tree_tcl_files) { 
    if (    $report_dead_code_too 
         || !(&_IsDead(\$tcl_file))
         || (&_IsDoNotPrune(\$tcl_file))) {
      my $first_line_printed = 0;
      my @non_proc_code_lines  = split "\n", $other_code{$tcl_file};
      foreach my $line (@non_proc_code_lines) {
        #Filter out non-procedure code lines that are benign.
        if (    !($line =~/^\s*source\s/)
             && !($line =~/^\s*$/)
             && !($line =~/^\s*global\s/)
             && !($line =~/^\s*set\s.*_cmd_grp\s/)
             && !($line =~/^\s*set\s.*_command_group\s/)
             && !($line =~/^\s*set\s.*_CMD_GRP\s/)
             && !($line =~/^\s*set\s.*_CMD_GROUP\s/)
             && !($line =~/^\s*set\s.*_COMMAND_GROUP\s/)
             && !($line =~/^\s*create_command_group\s/)
             && !($line =~/^\s*alias\s/)
             && !($line =~/^\s*echo\s+\"/)
             && !($line =~/^\s*print_info\s+\"/)
             && !($line =~/^\s*inform_p\s+\"/)) {
          if (!$first_line_printed) { 
            print REPORT "File: $tcl_file\n";
            print REPORT "----------------------------------";
            print REPORT "----------------------------------\n";
            $first_line_printed = 1;
          }
          print REPORT "> $line\n"; 
        }
      }
      if ($first_line_printed) { 
        print REPORT "\n";
      }
    }
  } 
  print "#" . &_GetTime() 
    . "> Exiting  &ReportNonProcTclCode($report_dead_code_too).\n" if $::DEBUG;
  close REPORT;
}

#-------------------------------------------------------------------------------
# SUBROUTINE:  _AnalyzeTclProcDefinitions                                       
# INPUTS:      none                                                             
# OUTPUTS:     none                                                             
# DESCRIPTION: This subroutine steps through each of the custom Tcl procedures, 
#              calculating each procedure's callees (ie., the vendor commands
#              and/or custom Tcl prcoedures that it calls in its definition) and       
#              callers (ie., the custom Tcl procs and/or files that call it).   
# NOTE:        Callees can include both vendor commands and custom Tcl procedures.     
# NOTE:        Callers can include both custom Tcl procedures and files.        
#-------------------------------------------------------------------------------
{
  my $initialized = 0;
  sub _AnalyzeTclProcDefinitions() {
    print "#" . &_GetTime() . "> Entering &_AnalyzeTclProcDefinitions().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_AnalyzeTclProcDefinitions().\n" if $::DEBUG;
      return;
    }

    &_ParseAllTclFilesInPath();
  
    my $custom_procs_ref  = &_GetCustomProcs();

    foreach my $proc (@{$custom_procs_ref}) {
      my %procs_called    = ();
      my %vars_set        = ();
      my %files_sourced   = ();
      my %proc_defs       = %{$procs{$proc}{definitions}};
      my $line_count      = 0;
      my $suppress_delta  = 0;
      foreach my $def_file (keys %proc_defs) {  #Step through each definition.
        my @proc_code_lines = split "\n", $proc_defs{$def_file};
        $line_count +=  ((scalar @proc_code_lines) + 2);
        foreach my $line (@proc_code_lines) {
          #Does the procedure's logged label match its actual name?
          if ($line =~/set\s+(?:PROC|self)/) {
            if ($line =~/set\s+(?:PROC|self)\s+\"([\sa-zA-Z0-9_]+)\"/) {
              my $proc_label  = "$1";
              if ($proc_label ne $proc) {
                $procs{$proc}{mislabel} = 1;
              }
            } elsif ($line =~/set\s+(?:PROC|self)\s+([a-zA-Z0-9_]+)/) {
              my $proc_label  = $1;
              if ($proc_label ne $proc) {
                $procs{$proc}{mislabel} = 1;
              }
            }
          }

          #Does procedure contain a vendor tool-specific switch?
          if (&_HasVendorToolSwitch(\$line)) {
            $procs{$proc}{tool_cond} = 1;
          } 
         
          $suppress_delta += &_CalcSuppressDelta(\$line);

          #Does procedure contain a project-specific switch?
          if (&_HasProjectSpecificSwitch(\$line)) {
            $procs{$proc}{proj_cond} = 1;
          }

          #Does procedure contain fubp-related code?
          if (&_HasFubpRelatedCode(\$line)) {
            $procs{$proc}{fubp_code} = 1;
          }

          #Does procedure have library hardcoding?
          if (&_HasLibraryHardcoding(\$line)) {
            $procs{$proc}{lib_hardcode} = 1;
          }

          #Does procedure access environment variables?
          if (&_IsGettingEnvVars(\$line)) {
            $procs{$proc}{getenv} = 1;
          }

          #Does procedure set environment variables?
          if ($line =~/set/) { #Performance optimization
            if (&_IsSettingEnvVars(\$line, 0)) {
              $procs{$proc}{setenv} = 1;
            }
          }

          #Does procedure call other procedures?
          foreach my $callee_proc (keys %procs) {
            if ((index($line, $callee_proc) != -1) || ($callee_proc =~/[:\/\\]/)) { #performance optimization
              if (&_IsProcFoundInLine(\$callee_proc, \$line)) {
                $procs_called{$callee_proc} = 1;
              }
            }
          }
         
          #Does procedure source other Tcl files?
          if ($line =~/source/) { #Performance optimization
            my $sourcee_file = &_ExtractSourcedFileFromLine(\$line);
            if (    ($sourcee_file ne "")
                 && !(&_IsInList(\$sourcee_file, \@ignore_list))) {
              #If we made it here, we have a valid sourcer and sourcee.
              my $sourcer_file  = $def_file;
              $sourcer_file     =~s/\(\d+\)$//; #Remove uniqify suffix.
              my $abbrev_sourcer_file = &_GetAbbrevFile(\$sourcer_file);
             
              if (!(exists $files{$sourcer_file}{procs_sources}{$proc})) {
                $files{$sourcer_file}{procs_sources}{$proc} = [];
              }
              push(@{$files{$sourcer_file}{procs_sources}{$proc}},
                $sourcee_file);
              
              if (!(exists $files_abbrev{$abbrev_sourcer_file}{procs_sources}{$proc})) {
                $files_abbrev{$abbrev_sourcer_file}{procs_sources}{$proc} = [];
              }
              push(@{$files_abbrev{$abbrev_sourcer_file}{procs_sources}{$proc}},
                $sourcee_file);
        
              if (&_IsSourceFileTracked(\$sourcee_file)) {
                if (!(exists $file_sourced_by{$sourcee_file})) {
                  $file_sourced_by{$sourcee_file} = [];
                }
                push(@{$file_sourced_by{$sourcee_file}}, 
                  "$sourcer_file->$proc");
                #Add sourcee to the hash for all Tcl files.  If sourcee was     
                #already on the path, it does nothing. However not all sourcees 
                #are on the path.                                               
                $file_all_abbrev{$sourcee_file} = 1;
              }
              $files_sourced{$sourcee_file} = 1;
            }
          }
          if (($::TRACK_VARIABLES_SET) && ($line =~/set\s+/)) { #Performance optimization
            my $var_name = &_ExtractSetVariableFromLine($line);
            if ($var_name ne "") {
              $vars_set{$var_name} = 1;
            } 
          }
        }
      }
      my $num_defs    = (scalar keys %proc_defs);
      my $avg_length  = ($num_defs > 0) ? ($line_count / $num_defs) : 0;
      if ($suppress_delta != 0) {
        $procs{$proc}{uneven_suppress} = 1;
      }

      $procs{$proc}{callees}  = \%procs_called;
      $procs{$proc}{sourcees} = \%files_sourced;
      if ($::TRACK_VARIABLES_SET) {
        $procs{$proc}{vars_set} = \%vars_set;
      }
      $procs{$proc}{length}   = $avg_length; 

      foreach my $callee_proc (keys %procs_called) {
        if (!(exists $procs{$callee_proc}{callers})) {
          my %caller_procs = ();
          $caller_procs{$proc} = 1;
          $procs{$callee_proc}{callers} = \%caller_procs;
        } else {
          my $caller_procs_ref = \%{$procs{$callee_proc}{callers}};
          $caller_procs_ref->{$proc} = 1;
        }
      }
    }

    #Delete any procedures having no definition and no caller.  This corner-case was observed with  
    #callees of ignored procedures that weren't called anywhere else. These callees were initially  
    #found by the _FindAllTclProcs subroutine which parses the Tcl files flat without considering   
    #whether the calls were made from within an ignored procedure's definition.                     
    my $reset_custom_procs_list = 0; 
    foreach my $proc (keys %procs) {
      if (    (scalar keys %{$procs{$proc}{definitions}} == 0)
           && (scalar keys %{$procs{$proc}{callers}}     == 0)
           && ($procs{$proc}{is_ven_proc} == 0)
           && ($procs{$proc}{is_builtin}  == 0)) {
        delete $procs{$proc};
        print "DELETE (no definition or caller): $proc\n" if $::DEBUG;
        $reset_custom_procs_list = 1; 
      } 
    }
    #If we deleted any procedures above, we will need to refresh the custom procs list.
    if ($reset_custom_procs_list) {
        &_GetCustomProcs(1);
    }

    $initialized  = 1;
    print "#" . &_GetTime() . "> Exiting  &_AnalyzeTclProcDefinitions().\n" if $::DEBUG;
    return;
  }
}

sub _HasProjectSpecificSwitch($) {
  my ($lref)  = @_;

  my $ret_val = 0;
  if ($$lref =~/^[^#]*\s*if\s/) {
    foreach my $project_abbrev (@projects) {  
      if ($$lref =~/\"$project_abbrev\"/) {
        $ret_val  = 1;
      }
    }
  }

  return $ret_val;
}

{
  my $underscore  = "_";
  sub _HasProjectInName($) {
    my $pref    = shift;
  
    my $ret_val = 0;
    foreach my $project_abbrev (@projects) {  
    if (    ($$pref =~/^$project_abbrev$underscore/)
         || ($$pref =~/$underscore$project_abbrev$underscore/)
         || ($$pref =~/$underscore$project_abbrev$/)) {
      $ret_val  = 1;
    }
  }

  return $ret_val;
  }
}

sub _HasVendorToolSwitch($) {
  my ($lref) = @_;

  if (    (    (    ($$lref =~/^[^#]*\s*if\s/)
                 || ($$lref =~/^[^#]*\s*set\s.*regsub/))
            && (    ($$lref =~/\"dc\"/)
                 || ($$lref =~/\"DC\"/)
                 || ($$lref =~/\"dct\"/)
                 || ($$lref =~/\"DCT\"/)
                 || ($$lref =~/\"pc\"/)
                 || ($$lref =~/\"PC\"/)
                 || ($$lref =~/\"icc\"/)
                 || ($$lref =~/\"ICC\"/)
                 || ($$lref =~/\"astro\"/)
                 || ($$lref =~/\"Astro\"/)
                 || ($$lref =~/\"genus\"/)
                 || ($$lref =~/\"innovus\"/)))
       || ($$lref =~/^[^#]*global\s+synopsys_program_name/)
       || ($$lref =~/is_tool_dc/) 
       || ($$lref =~/is_tool_icc/)) {
    return  1;
  } else {
    return  0;
  }
}

sub _CalcSuppressDelta($) {
  my ($lref)  = @_;
  my $delta   = 0;
  if ($$lref =~/^[^#]*suppress_message\s/) {
    foreach my $cmd (split ";", $$lref) { 
      if ($cmd =~/^[^#]*suppress_message\s/) {
        if ($cmd =~/unsuppress_message\s/) {
          $delta = $delta - 1;
        } else {
          $delta = $delta + 1;
        }
      }
    }
  }
  return $delta;
}

sub _HasLibraryHardcoding($) {
  my ($lref) = @_;

  if (    ($$lref =~/[rR][0\*]0/) 
       || ($$lref =~/[vV][0\*][02]/)
       || ($$lref =~/[vV]8/)
       || ($$lref =~/[tT][0\*][02]/)
       || ($$lref =~/[ef]c0/)
       || ($$lref =~/[ef]0[58]/)
       || ($$lref =~/127[01234567]/)) {
    return  1;
  } else {
    return  0;
  }
}

sub _IsGettingEnvVars($) {
  my ($lref) = @_;

  if (    (    (    ($$lref =~/^[^#]+\$ENV_VAR::/)
                 || (    ($$lref =~/^[^#]+\sENV_VAR::/)
                      && !($$lref =~/set\s+ENV_VAR::/))
                 || ($$lref =~/^[^#]+\$\{ENV_VAR::/))
            && (    ($$lref =~/ENV_VAR::rls_env\(.*\)/)
                 || ($$lref =~/ENV_VAR::dcsv_is_fub\(.*\)/)
                 || ($$lref =~/ENV_VAR::[A-Z0-9_]+/)))
       || (    ($$lref =~/^[^#]+\srls_env\(.*\)/)
            && !($$lref =~/set\s+rls_env/))
       || ($$lref =~/^[^#]+set\s+[a-zA-Z0-9_]+\s+\$rls_env\(.*\)/)
       || ($$lref =~/^[^#]+get_unix_variable/)) {
    return  1;
  } else {
    return  0;
  }
}

sub _IsSettingEnvVars($$) {
  my ($lref, $non_proc_line) = @_;
  
  #Does this line set environment variables?
  if (    (    ($$lref =~/^[^#]*\sset\s+ENV_VAR::rls_env\(.*\)/)
            || ($$lref =~/^set\s+ENV_VAR::rls_env\(.*\)/))
       || (    ($$lref =~/^[^#]*\sunset\s+ENV_VAR::rls_env\(.*\)/)
            || ($$lref =~/^unset\s+ENV_VAR::rls_env\(.*\)/))
       || (    ($$lref =~/^[^#]*\sset\s+ENV_VAR::dcsv_is_fub\(.*\)/)
            || ($$lref =~/^set\s+ENV_VAR::dcsv_is_fub\(.*\)/))
       || (    ($$lref =~/^[^#]*\sunset\s+ENV_VAR::dcsv_is_fub\(.*\)/)
            || ($$lref =~/^unset\s+ENV_VAR::dcsv_is_fub\(.*\)/))
       || (    ($$lref =~/^[^#]*\sset\s+rls_env\(.*\)/)
            || ($$lref =~/^set\s+rls_env\(.*\)/))
       || (    ($$lref =~/^[^#]*\ssetenv\s/)
            || ($$lref =~/^setenv\s/))
       || (    ($$lref =~/^[^#]*redirect\s.*\s\{setenv\s/)
            || ($$lref =~/^redirect\s.*\s\{setenv\s/))
       || (    ($$lref =~/^[^#]*\sset\srls_env\(/)
            || ($$lref =~/^set\srls_env\(/))
       || (    ($$lref =~/^[^#]*\sset_synopsys_variables\s/)
            || ($$lref =~/^set_synopsys_variables\s/))
       || ($$lref =~/^\s*ENV_VAR::dcsv_set_env_var_p/)
       || (    ($non_proc_line)
            && (    ($$lref =~/^\s*set\s+/)
                 || ($$lref =~/^\s*lappend\s+/)))) {
    return 1;
  } else {
    return 0;
  }
}

{
  my $initialized = 0;
  my $static_proc = "";
  my $underscore  = "_";
  my $valid_log_proc_names_ref;
  sub _IsProcFoundInLine() {
    my $pref0 = shift;
    my $lref  = shift;
   
    my $regexp_safe_proc = &_GetRegExpSafeProc($pref0);
    my $pref  = \$regexp_safe_proc;
   
    if (!$initialized) {
      $valid_log_proc_names_ref = &_GetValidLogProcNames();
      $initialized = 1;
    }

    #Handle the corner-case where the proc name contains slashes.
    if ($$pref0 =~/[\/\\]/) {
      $static_proc  = &_GetRegExpSafeProc($pref0);
      $pref         = \$static_proc;
    }

    #Look for definitions of this procedure in addition to calls?
    my $definition_too  = (scalar @_ > 0) ? shift : 0;

    my $ret_val     = 0;

    #Does it look like it might be a procedure call?
    #grep -e
    my $first_level = 0;
    if (    ($$lref =~/$$pref[;\s\]]/)
         || ($$lref =~/set\s+[a-zA-Z0-9_]+\s+\"\s*$$pref\s*\"/)
         || ($$lref =~/$$pref$/)
         || (    ($$lref =~/\{\s*$$pref\s*\}/)
              && (    ($$lref =~/^[^#]*redirect\s[^#]*\{\s*$$pref\s*\}/)
                   || ($$lref =~/^[^#]*catch\s+\{\s*$$pref\s*\}/)
                   || ($$lref =~/^[^#]*display_err\s+\{\s*$$pref\s*\}/)
                   || ($$lref =~/^\s*\{\s*$$pref\s*\}/)))) {
      $first_level = 1;
    } elsif ($definition_too) {
      if ($$lref =~/^\s*proc\s+$$pref\s/) {
        $first_level = 1;
      } else {
        #If there is a namespace, the definition line may or may not include it.
        my $abbrev_proc = &_GetAbbrevProc($pref);
        if ($$lref =~/^\s*proc\s+$abbrev_proc\s/) {
          $first_level = 1;
        } 
      }
    }
 
    #grep -v -e ...
    my $second_level = 0;
    if ($first_level) {
      my $multiple_instances_of_proc  = 0;

      if (    (    ($$lref =~/[\s\[\{]$$pref[\s\]\};].*$$pref/) 
                || ($$lref =~/$$pref.*[\s\[\{]$$pref[\s\]\};]/)
                || ($$lref =~/$$pref.*[\s\[\{]$$pref$/))
      #Handle the corner-case where the procedure name is only 1 character
      #and the $multiple_instances_of_proc can be set to 1 too easily. For
      #example, it erroneously is set to 1 in the following line when the 
      #procedure name is "t":                                             
      #   foreach_in_collection t $terms {                                
           && (    ((length $$pref) > 1) 
                || !($$lref =~/\s$$pref\s/))) {
        $multiple_instances_of_proc  = 1;
      }
      
      if (    !($$lref =~/^[^#]*define_proc_(attributes|arguments)\s+$$pref/)
           && !($$lref =~/^[^#]*[gs]et_app_var\s+$$pref[\s\]]/)
           && (    ($$lref =~/^\s*$$pref\s/)
                || (    !($$lref =~/#.*$$pref/)                      
                     && !(    ($$lref =~/[a-zA-Z0-9_\.-]$$pref/)
                           && !($$lref =~/\"\\n$$pref/))
                     && !($$lref =~/\{\s*$$pref\s*\}[a-zA-Z0-9_:\.]/)
                     && !($$lref =~/[a-zA-Z0-9\$_:]\{\s*$$pref\s*\}/)
                     && !($$lref =~/\s\$$$pref/) 
                     && !($$lref =~/USAGE:\s+$$pref/)
                     && !($$lref =~/Usage\s*:\s+$$pref/)
                     && !($$lref =~/\"[a-zA-Z]+\s+$$pref\s+[a-zA-Z]+\s.*\"/)
                     && !($$lref =~/\".*\s[a-zA-Z]+\s+$$pref\s+[a-zA-Z]+\s.*\"/)
                     && !($$lref =~/[\s\[\{]info\s+exists\s+$$pref[\s\]\}]/)
                     && !($$lref =~/^info\s+exists\s+$$pref[\s\]\}]/)
                     && (    !($$lref =~/regexp/) 
                          || (    !($$lref =~/\[\s*regexp\s[-\{\}\"\$\sa-zA-Z0-9_]+\s$$pref\s*\]/)
                               && !($$lref =~/regexp\s+(\{.*\}|\".*]")\s+([^\;]+\s+)*$$pref/)))
                     && !($$lref =~/\[\s*get_attribute\s+\$[a-zA-Z0-9_]+\s$$pref\s*\]/)
                     && !($$lref =~/[\s\[]redirect\s+-variable\s+$$pref\s/)
                     && !($$lref =~/^redirect\s+-variable\s+$$pref\s/)
                     && !($$lref =~/awk\s+\'[^\']*$$pref.*\'/)
                     && !($$lref =~/\s+-[a-zA-Z0-9_]+\s+$$pref\s/))
                || $multiple_instances_of_proc)
           && !($$lref =~/^\s*\"[^\"]*$$pref.*\"/)
           && !(    ($$lref =~/^\s*set\s+$$pref\s/)
                 && !($$lref =~/^\s*set\s+$$pref.*$$pref/))
           && !(    ($$lref =~/set\s+(?:PROC|self)\s+/)
                 && (    ($$lref =~/set\s+(?:PROC|self)\s+\"\s*$$pref\s*\"/)
                      || ($$lref =~/set\s+(?:PROC|self)\s+$$pref\s*;/)
                      || ($$lref =~/set\s+(?:PROC|self)\s+$$pref\s*$/)))) {
        if (    ($definition_too)
             || (     !($$lref =~/^\s*proc\s+$$pref/)
                   && !($$lref =~/;\s*proc\s+$$pref/))) {
          $second_level = 1;
        }
      }

      #Grep out bogus hits.
      if (!$multiple_instances_of_proc) {
        if (    ($$lref =~/{$$pref\s/)  #Don't confuse arguments for procs.
             || ($$lref =~/$$pref$underscore/)
             || ($$lref =~/$underscore$$pref/)
             || ($$lref =~/\$$$pref/)
             || ($$lref =~/^\s*set\s+[a-zA-Z0-9_]+\s+\"?$$pref\"?/)
             || ($$lref =~/^\s*proc\s+\S+\s+\{(\S+\s+)*$$pref[\s\}]/)) {
          $second_level = 0;
        }
      } else {
        if (    ($$lref =~/\{-$$pref[^{^}]+$$pref/)  #define_proc_attributes line
             || ($$lref =~/^\s*set\s+[\$\(\)a-zA-Z0-9_]*$$pref[\$\(\)a-zA-Z0-9_]*\s+\[[a-zA-Z0-9_]+\s+[^\]]+$$pref/)
             || ($$lref =~/^[^\"]+$$pref$underscore[^\"]+[\s;]#.*$$pref/)
             || ($$lref =~/^[^\"]+$underscore$$pref[^\"]+[\s;]#.*$$pref/)) {
          $second_level = 0;
        }
      }
    }

    my $third_level = 0;
    if ($second_level) {
      #Ignore log and define_proc_attribute hits.
      if (    !($$lref =~/\s-[a-zA-Z0-9_]+\s+\"[^\"\[]*$$pref.*\"/)
           && !($$lref =~/^\s*help\s+-verbose\s+$$pref/)) {
        my $log_match = 0; 
        #Ignore obvious procedure calls enclosed in square brackets.
        if (!($$lref =~/\[\s*(::)?$$pref(\s+[\$\{\}\-_a-zA-Z0-9]+)*\s*\]/)) {
          #Step through each possible log/print procedure. 
          foreach my $log_proc (@{$valid_log_proc_names_ref}) {
            if (    ($$lref =~/$log_proc/)
                 && (    ($$lref =~/^\s*$log_proc\s+\"[^\"]*$$pref.*\"/)
                      || ($$lref =~/;\s*$log_proc\s+\"[^\"]*$$pref.*\"/)
                      || ($$lref =~/^\s*$log_proc\s+$$pref$;?/)
                      || ($$lref =~/;\s*$log_proc\s+$$pref$;?/))) {
              $log_match = 1;
            }
          }
        }
        if (!($log_match)) {
          $third_level = 1;
        }
      }
    }
    
    my $fourth_level  = 0;
    if ($third_level) {
      #Ignore occurrences where the procedure is being used as a print label.
      if (    (    !($$lref =~/echo/) 
                || (    !($$lref =~/echo\s+\"[^\"]*\s$$pref\s+:/)
                     && !($$lref =~/echo\s+\"[^\"]*$$pref.*\"/)
                     && !($$lref =~/echo\s+[\$a-zA-Z0-9_]+\s+\"[^\"]*$$pref.*\"/)))
           && (    !($$lref =~/puts/)
                || (    !($$lref =~/puts\s+\"[^\"]*$$pref.*\"/)
                     && !($$lref =~/puts\s+[\$a-zA-Z0-9_]+\s+\"[^\"]*$$pref.*\"/))))
      {
        $fourth_level  = 1;
      } elsif (    (    ($$lref =~/echo/) 
                     || ($$lref =~/puts/))
                && (    !($$lref =~/(echo|puts)\s+\"[\\n\s]*-[DIWE]-\s[^\[^\]]+$/)
                     && !($$lref =~/echo\s+\"\s+Usage:\s+$$pref/))) {
        #Try to catch obvious places where proc calls are embedded in quotes.
        if ($$pref =~/_/) {
          if (    ($$lref =~/echo\s+\"[^\"]*$$pref.*\"/)
               || ($$lref =~/echo\s+[\$a-zA-Z0-9_]+\s+\"[^\"]*$$pref.*\"/)
               || ($$lref =~/puts\s+\"[^\"]*$$pref.*\"/)
               || ($$lref =~/puts\s+[\$a-zA-Z0-9_]+\s+\"[^\"]*$$pref.*\"/)) {
            if (   !($$lref =~/\"[^\"]*\sby\s[^\"]*\"/)
                && !($$lref =~/\"[^\"]*\sand\s[^\"]*\"/)
                && !($$lref =~/\"[^\"]*\sa\s[^\"]*\"/)
                && !($$lref =~/\"[^\"]*\swith\s[^\"]*\"/)
                && !($$lref =~/\"[^\"]*\sthe\s[^\"]*\"/)) {
              $fourth_level = 1;
            }
          }
        } elsif (    ($$lref =~/echo\s+[\$a-zA-Z0-9_]+\s+\"[^\"]*\\\[\s+$$pref.*\"/)
                  || ($$lref =~/echo\s+\"[^\"]*\\\[$$pref.*\"/)
                  || ($$lref =~/puts\s+[\$a-zA-Z0-9_]+\s+\"[^\"]*\\\[\s+$$pref.*\"/)
                  || ($$lref =~/puts\s+\"[^\"]*\\\[$$pref.*\"/)) {
          $fourth_level = 1;
        } 
      }
    }

    if ($fourth_level) {
      if (    ($$pref ne "get") 
           || !(    ($$lref =~/array get/)
                 && !($$lref =~/array get.*get/))) {
        #If a procedure name doesn't have a namespace, don't count it if the call includes the namespace.
        if (    !($$lref =~/::/) 
             || ($$pref =~/::/)
             || (    !($$lref =~/[a-z0-9A-Z_]::$$pref[;\s\]]/)
                  && !($$lref =~/[a-z0-9A-Z_]::$$pref$/))) {
                $ret_val = 1;
        }
      }
    }
                    
    if ($DEBUG && (&_IsInList($pref, \@flagged_procs))) {
      my $regexp_safe_abbrev_proc  = &_GetAbbrevProc(\$regexp_safe_proc);
     
      chomp($$lref);
      my $mod_line = $$lref;
      $mod_line =~s/$regexp_safe_abbrev_proc/%%%%%%/;
      $mod_line =~s/$regexp_safe_abbrev_proc/%%%%%%/;
      $mod_line =~s/$regexp_safe_abbrev_proc/%%%%%%/;
      $mod_line =~s/$regexp_safe_abbrev_proc/%%%%%%/;
      if ($$lref =~/\{\s*$$pref\s*\}/) {
        print "X";
      }
      if ($ret_val) {
        print "HIT: ";
      } else {
        print "MISS: ";
      }
      print "\'$mod_line\'     PROC=$$pref, LINE=$$lref, DEF_TOO=$definition_too, L1=$first_level, L2=$second_level, L3=$third_level, L4=$fourth_level\n";
    }
    return $ret_val;
  }
}

{
  my %active_status = ();  #static variable
  sub _PrintCallBranch($$$$) {
    my ($fh, $object, $report_dead_code_too, $indentation) = @_;

    if (    !$report_dead_code_too 
         && (&_IsDead(\$object))
         && !(&_IsDoNotPrune(\$object))) {
      return;
    }

    if ($indentation >= $INDENT) {
      my $i = 0;
      while ($i < ($indentation - $INDENT)) {
        print $fh "|";
        my $j = 1;
        while ($j < $INDENT) {
          print $fh " ";
          $j++;
        }
        $i += $INDENT;
      }
      print $fh "|";
      my $j = 1;
      while ($j < $INDENT) {
        print $fh "-";
        $j++;
      }
    }
    print $fh &GetFormalName($object);
    if (&_IsDead(\$object)) {
      print $fh " $DEAD_STRING";
    } 
    if (&_IsDoNotPrune(\$object)) {
      print $fh " $DO_NOT_PRUNE_STRING";
    } 
    if (exists $procs{$object}) { #Don't report files as undefined.
      if ((scalar keys %{$procs{$object}{definitions}}) == 0) { 
        print $fh " $UNDEFINED_STRING";
      }
    }

    #Assume that the object is a file for the top-of-tree check.
    my $abbrev_file = &_GetAbbrevFile(\$object);
    if (&_IsTopOfTreeFile(\$abbrev_file)) {
      print $fh " $TOP_OF_TREE_STRING";
    } 

    print $fh "\n";

    if (    (exists $active_status{$object})
         && ($active_status{$object} == 1)) {
      print $fh "Warning: This procedure has a circular calling loop.\n";
      $proc_has_circular_call{$object} = 1;
    } else {
      $active_status{$object}  = 1;
      my %printed_procs = ();
      
      if (exists $procs{$object}) { #Is it a procedure?
        if (exists $procs{$object}{callees}) {
          my $callee_procs_ref = \%{$procs{$object}{callees}};
          foreach my $callee_proc (sort keys %{$callee_procs_ref}) {
            if (!(exists $printed_procs{$callee_proc})) {
              if (($procs{$callee_proc}{is_custom})) { #Custom procedure?
                &_PrintCallBranch($fh, $callee_proc, $report_dead_code_too,
                  $indentation+$INDENT);
                $printed_procs{$callee_proc} = 1;
              }
            }
          }
        }
      } else {
        #It is a file.
        my $callee_procs_ref = \%{$files{$object}{proc_callees}};
        foreach my $callee_proc (sort keys %{$callee_procs_ref}) {
          if (!(exists $printed_procs{$callee_proc})) {
            if (($procs{$callee_proc}{is_custom})) { #Custom procedure?
              &_PrintCallBranch(
                $fh, $callee_proc, $report_dead_code_too, $indentation+$INDENT);
              $printed_procs{$callee_proc} = 1;
            }
          }
        }
      }
      $active_status{$object}  = 0;
    } 
  }
}

{
  my %active_status = ();  #static variable
  sub _PrintSourceBranch($$$$) {
    my ($fh, $abbrev_sourcer_file, $report_dead_code_too, $indentation) = @_;

    if (    !$report_dead_code_too 
         && (&_IsDead(\$abbrev_sourcer_file))
         && !(&_IsDoNotPrune(\$abbrev_sourcer_file))) {
      return;
    }
    
    if ($indentation >= $INDENT) {
      my $i = 0;
      while ($i < ($indentation - $INDENT)) {
        print $fh "|";
        my $j = 1;
        while ($j < $INDENT) {
          print $fh " ";
          $j++;
        }
        $i += $INDENT;
      }
      print $fh "|";
      my $j = 1;
      while ($j < $INDENT) {
        print $fh "-";
        $j++;
      }
    }
    print $fh "$abbrev_sourcer_file";
    if (&_IsDead(\$abbrev_sourcer_file)) {
      print $fh " $DEAD_STRING";
    } 
    if (&_IsDoNotPrune(\$abbrev_sourcer_file)) {
      print $fh " $DO_NOT_PRUNE_STRING";
    } 
    if (!(exists $files_abbrev{$abbrev_sourcer_file}{paths})) { 
      print $fh " $UNDEFINED_STRING";
    }

    if (!(&_IsSourceFileTracked(\$abbrev_sourcer_file))) {
      print $fh " $NOT_TRACKED_STRING";
    }
    if ((&_IsTopOfTreeFile(\$abbrev_sourcer_file))) {
      print $fh " $TOP_OF_TREE_STRING";
    }
    print $fh "\n";

    if (    (exists $active_status{$abbrev_sourcer_file})
         && ($active_status{$abbrev_sourcer_file} == 1)) {
      print $fh "Warning: This source file has a circular sourcing loop.\n";
      $file_has_circular_source{$abbrev_sourcer_file} = 1;
    } else {
      $active_status{$abbrev_sourcer_file}  = 1;
      my %printed_files = ();
      my $sourced_files_ref = &_GetSourceeFiles(\$abbrev_sourcer_file); 
      foreach my $sourced_file (sort @{$sourced_files_ref}) {
        #Don't bother printing sourcees, sourced multiple times, more than once.
        if (!(exists $printed_files{$sourced_file})) {
          &_PrintSourceBranch(
            $fh, $sourced_file, $report_dead_code_too, $indentation+$INDENT);
        }
        $printed_files{$sourced_file} = 1;
      }
      $active_status{$abbrev_sourcer_file}  = 0;
    } 
  }
}

sub ReportCallTree($) {
  my $report_dead_code_too  = shift; 
  
  my $abbrev_filename       = $REPORT_CALL_TREE;
  
  print "#" . &_GetTime() 
    . "> Entering &ReportCallTree($report_dead_code_too).\n" if $::DEBUG;
  
  &_Initialize();
  
  my $filename  = $report_dead_code_too
    ? "$REPORTS_DIR\/$ALL_DIR\/$abbrev_filename"
    : "$REPORTS_DIR\/$PRUNED_DIR\/$abbrev_filename";
  print "Information: Writing file '$filename'.\n";

  open(REPORT, "> $filename") || die "(ReportCallTree():31) "
    . "Error: Can't open $filename for writing!\n";
  
  print REPORT "This report can generate any of the following warnings:\n"
    . "-------------------------------------------------------\n"
    . "1. This procedure has a circular calling loop.\n";
  
  _PrintDivider(*REPORT);

  #Print out live (ie. designated) tree tops first and dead tree tops second.
  for (my $i=0; $i<=1; $i++) { 
    foreach my $orphaned_caller (sort @{&_GetOrphanedProcCallers()}) {
      if (    (($i == 0) && !(&_IsDead(\$orphaned_caller)))
           || (($i == 1) && (&_IsDead(\$orphaned_caller)))) {
        &_PrintCallBranch(*REPORT, $orphaned_caller, $report_dead_code_too, 0);
        if (    $report_dead_code_too 
             || !(&_IsDead(\$orphaned_caller))
             || (&_IsDoNotPrune(\$orphaned_caller))) {
          print REPORT "\n";
        }
      }
    }
  }

  #Calculate the number of procedures.
  my $num_procs       = 0;
  foreach my $proc (@{&_GetCustomProcs()}) {
    if (    $report_dead_code_too 
         || !(&_IsDead(\$proc))
         || (&_IsDoNotPrune(\$proc))) {
      $num_procs++;
    }
  }

  my @procs_circ_call  = ();
  foreach my $proc (keys %proc_has_circular_call) {
    push(@procs_circ_call, $proc);
  } 
  
  _PrintDivider(*REPORT);

  print REPORT "Procs with circular calls: " 
    . join(", ", sort @procs_circ_call);
  print REPORT "\n";

  _PrintDivider(*REPORT);
  
  print REPORT "Summary\n-------\n";
  print REPORT "Found $num_procs Tcl procedures.\n";
  if ($num_procs > 0) {
    my $num_procs_circ_call  = scalar(@procs_circ_call);
    my $pcnt_procs_circ_call = 100 * $num_procs_circ_call / $num_procs;
    printf REPORT
      "   %3d (%4.1f", $num_procs_circ_call, $pcnt_procs_circ_call;
    print REPORT "%) with circular calls.\n";
  }
  print "#" . &_GetTime() 
    . "> Exiting  &ReportCallTree($report_dead_code_too).\n" if $::DEBUG;
}

sub ReportSourceTree($) {
  my $report_dead_code_too  = shift; 
  
  my $abbrev_filename       = $REPORT_SOURCE_TREE;
  
  print "#" . &_GetTime() 
    . "> Entering &ReportSourceTree($report_dead_code_too).\n" if $::DEBUG;
  
  &_Initialize();
  
  my $filename  = $report_dead_code_too
    ? "$REPORTS_DIR\/$ALL_DIR\/$abbrev_filename"
    : "$REPORTS_DIR\/$PRUNED_DIR\/$abbrev_filename";
  print "Information: Writing file '$filename'.\n";

  open(REPORT, "> $filename") || die "(ReportSourceTree():32) "
    . "Error: Can't open $filename for writing!\n";
  
  print REPORT "This report can generate any of the following warnings:\n"
    . "-------------------------------------------------------\n"
    . "1. This source file has a circular sourcing loop.\n";
  
  _PrintDivider(*REPORT);
    
  #A file is a tree top if no other files source it.
  my @tree_tops = ();
  
  foreach my $abbrev_sourcer_file (@{&_GetAllAbbrevTclFilesFound()}) {
    my $match_found = 0; 
    foreach my $key (keys %file_sourced_by) {
      if ($key eq $abbrev_sourcer_file) {
        $match_found = 1;
      }
    }
    if (!$match_found) {
      push(@tree_tops, $abbrev_sourcer_file);
    }
  }
    
  #Add in designated top of tree files, if they weren't already included.
  my $top_of_tree_files_ref = &_GetTopOfTreeFiles();
  foreach my $top_of_tree_file (@{$top_of_tree_files_ref}) {
    my $abbrev_top_of_tree_file = &_GetAbbrevFile(\$top_of_tree_file);
    if (!(&_IsInList(\$abbrev_top_of_tree_file, \@tree_tops))) {
      push(@tree_tops, $abbrev_top_of_tree_file);
    }
  }
   
  #Print out live (ie. designated) tree tops first and dead tree tops second.
  for (my $i=0; $i<=1; $i++) { 
    foreach my $tree_top (sort @tree_tops) {
      if (    (($i == 0) && !(&_IsDead(\$tree_top)))
           || (($i == 1) && (&_IsDead(\$tree_top)))) {
        &_PrintSourceBranch(*REPORT, $tree_top, $report_dead_code_too, 0);
        if (    $report_dead_code_too 
             || !(&_IsDead(\$tree_top))
             || (&_IsDoNotPrune(\$tree_top))) {
          print REPORT "\n";
        }
      }
    }
  }
 
  #Calculate the number of Tcl files.
  my $num_files       = 0;
  foreach my $tcl_file (@{&_GetAllAbbrevTclFilesFound()}) {
    if (    $report_dead_code_too 
         || !(&_IsDead(\$tcl_file))
         || (&_IsDoNotPrune(\$tcl_file))) {
      $num_files++;
    }
  }
  
  my @files_circ_src  = ();
  foreach my $abbrev_file (keys %file_has_circular_source) {
    push(@files_circ_src, $abbrev_file);
  } 
  
  _PrintDivider(*REPORT);

  print REPORT "Files with circular sourcing: " 
    . join(", ", sort @files_circ_src);
  print REPORT "\n";

  _PrintDivider(*REPORT);
  
  print REPORT "Summary\n-------\n";
  print REPORT "Found $num_files Tcl source files.\n";
  if ($num_files > 0) {
    my $num_files_circ_src  = scalar(@files_circ_src);
    my $pcnt_files_circ_src = 100 * $num_files_circ_src / $num_files;
    printf REPORT
      "   %3d (%4.1f", $num_files_circ_src, $pcnt_files_circ_src;
    print REPORT "%) with circular sourcing.\n";
  }
  print "#" . &_GetTime() 
    . "> Exiting  &ReportSourceTree($report_dead_code_too).\n" if $::DEBUG;
}

sub ReportSourceFiles($) {
  my $report_dead_code_too  = shift; 

  my $abbrev_filename       = $REPORT_SOURCE_FILES;
  
  print "#" . &_GetTime() 
    . "> Entering &ReportSourceFiles($report_dead_code_too).\n" if $::DEBUG;
 
  &_Initialize();

  my $filename  = $report_dead_code_too
    ? "$REPORTS_DIR\/$ALL_DIR\/$abbrev_filename"
    : "$REPORTS_DIR\/$PRUNED_DIR\/$abbrev_filename";
  print "Information: Writing file '$filename'.\n";
  
  open(REPORT, "> $filename") || die "(ReportSourceFiles():33) "
    . "Error: Can't open $filename for writing!\n";

  print REPORT "This report can generate any of the following warnings:\n"
    . "-------------------------------------------------------\n";

  my $warnings  = "";
  if ($vendor_checks_on) {
    $warnings =
        "This source file has no location.\n"
      . "This source file is the same as *.\n"
      . "This source file has * locations (identical contents).\n"
      . "This source file has * locations (different contents).\n"
      . "This source file is a unix script but is not executable.\n"
      . "This source file is executable but is not a unix script.\n"
      . "This source file is only used once.\n"
      . "This source file isn't used anywhere.\n"
      . "This source file has no procedure definitions.\n"
      . "This source file has meaningful code lines outside of procedures.\n"
      . "This source file is dead but defines procedures that aren't.\n"
      . "This source file is alive but all its procedures defined are dead.\n"
      . "This source file is alive but >80% of its code is dead.\n"
      . "This source file has unmatched opening and closing braces.\n"
      . "This source file has a project in its name.\n"
      . "This source file has namespace declarations.\n"
      . "This source file sets an environment variable (non-proc code).\n"
      . "This source file accesses an environment variable (non-proc code).\n"
      . "This source file has fubp-related code (non-proc code).\n"
      . "This source file has a project-specific switch (non-proc code).\n"
      . "This source file has library hardcoding (non-proc code).\n"
      . "This source file has non-conforming define_proc_attribute calls.\n"
      . "This source file has a vendor tool-specific switch "
      . "(non-proc code).\n"
      . "This source file has unmatched suppress_message calls "
      . "(non-proc code).\n"
      . "This source file has a callee that is a vendor abbreviated "
      . "command (non-proc code).\n"
      . "This source file has a callee that is a vendor ambiguous command "
      . "abbreviation (non-proc code).\n"
      . "This source file has a callee that is a custom abbreviated "
      . "procedure (non-proc code).\n"
      . "This source file has a callee that is a custom ambiguous procedure "
      . "abbreviation (non-proc code).\n"
      . "\n";
  } else {
    $warnings =
        "This source file has no location.\n"
      . "This source file is the same as *.\n"
      . "This source file has * locations (identical contents).\n"
      . "This source file has * locations (different contents).\n"
      . "This source file is a unix script but is not executable.\n"
      . "This source file is executable but is not a unix script.\n"
      . "This source file is only used once.\n"
      . "This source file isn't used anywhere.\n"
      . "This source file has no procedure definitions.\n"
      . "This source file has meaningful code lines outside of procedures.\n"
      . "This source file is dead but defines procedures that aren't.\n"
      . "This source file is alive but all its procedures defined are dead.\n"
      . "This source file is alive but >80\% of its code is dead.\n"
      . "This source file has unmatched opening and closing braces.\n"
      . "This source file has a project in its name.\n"
      . "This source file has namespace declarations.\n"
      . "This source file sets an environment variable (non-proc code).\n"
      . "This source file accesses an environment variable (non-proc code).\n"
      . "This source file has fubp-related code (non-proc code).\n"
      . "This source file has a project-specific switch (non-proc code).\n"
      . "This source file has library hardcoding (non-proc code)."
      . "This source file is a unix script but is not executable.\n"
      . "This source file is executable but is not a unix script.\n"
      . "\n";
  }
  my $i = 1;
  foreach my $warning (split "\n", $warnings) {
    printf REPORT "%2d. ", ($i++);
    print  REPORT "$warning\n";
  }

  &_PrintDivider(*REPORT);

  my @files_medium_usage                = ();
  my @files_one_usage                   = ();
  my @files_zero_usage                  = ();
  my @files_sans_loc                    = ();
  my @files_multi_loc                   = ();
  my @files_multi_loc_same              = ();
  my @files_multi_loc_diff              = ();
  my @files_unix_script_not_executable  = ();
  my @files_executable_not_unix_script  = ();
  my @files_dead                        = ();
  my @files_no_defs                     = ();
  my @files_not_tracked                 = ();
  my @files_top_of_tree                 = (); 
  my @files_undead_procs                = ();
  my @files_proj_name                   = ();
  my @files_def_proc_attr               = ();
  my @files_live                        = ();
  my @files_setenv                      = ();
  my @files_namespace                   = ();
  my @files_getenv                      = ();
  my @files_fubp                        = ();
  my @files_proj_cond                   = ();
  my @files_tool_cond                   = ();
  my @files_lib_hardcode                = ();
  my @files_with_twins                  = ();
  my @files_live_dead_procs             = ();
  my @files_live_much_dead              = ();
  my @files_uneven_braces               = ();
  my @files_do_not_prune                = ();
  my @files_uneven_suppress             = ();
  my @files_cus_abbrev_callee           = ();
  my @files_cus_ambigu_callee           = ();
  my @files_ven_abbrev_callee           = ();
  my @files_ven_ambigu_callee           = ();
  my $num_files                         = 0;
 
  my $tcl_files_in_path_ref = &_GetAllTclFilesInPath();

  #Print out files, sorted by descending usage.
  my $max_file_usage  = 0;
  my %files_by_usage  = ();
  foreach my $key (@{&_GetAllAbbrevTclFilesFound()}) {
    my $sourcer_files_ref = &_GetSourcerFiles(\$key); 
    my $sourcer_count     = 0;
    foreach my $sourced_by_file (sort @{$sourcer_files_ref}) {
      if (    $report_dead_code_too 
           || !(&_IsDead(\$sourced_by_file))
           || (&_IsDoNotPrune(\$sourced_by_file))) {
        $sourcer_count++;
      }
    }
    if ($sourcer_count > $max_file_usage) {
      $max_file_usage = $sourcer_count;
    }
    if (!(exists $files_by_usage{$sourcer_count})) {
      $files_by_usage{$sourcer_count} = [];
    }
    push(@{$files_by_usage{$sourcer_count}}, $key);
  }
  my $current_usage   = $max_file_usage;
  my $usage_target    = $report_dead_code_too ? 0 : 1; 
  while ($current_usage >= $usage_target) {
    if (!(exists $files_by_usage{$current_usage})) {
      $files_by_usage{$current_usage} = [];
    }
    foreach my $key (@{$files_by_usage{$current_usage}}) {
      my $file_is_dead = &_IsDead(\$key);
      if (    $report_dead_code_too 
           || !(&_IsDead(\$key))
           || (&_IsDoNotPrune(\$key))) {
        $num_files++;
        print REPORT "File: $key";
  
        if ($file_is_dead) {
          print REPORT " $DEAD_STRING";
          push(@files_dead, $key);
        }
        if (&_IsDoNotPrune(\$key)) {
          print REPORT " $DO_NOT_PRUNE_STRING";
          push(@files_do_not_prune, $key);
        }
        if (&_IsTopOfTreeFile(\$key)) {
          print REPORT " $TOP_OF_TREE_STRING";
          push(@files_top_of_tree, $key); 
        }
        print REPORT "\n";
  
        if (&_HasProjectInName(\$key)) {
          print REPORT "Warning: This source file has a project in its name.\n";
          push(@files_proj_name, $key);
        } 
  
        #Report the file's location.
        my $location_count                = 0;
        my @location_paths                = (); 
        my $num_lines                     = 0;
        my $is_unix_script_not_executable = 0;
        my $is_executable_not_unix_script = 0;
        my $has_def_proc_attr             = 0;
        my $has_live                      = 0;
        my $has_setenv                    = 0;
        my $has_namespace                 = 0;
        my $has_getenv                    = 0;
        my $has_fubp                      = 0;
        my $has_proj_cond                 = 0;
        my $has_tool_cond                 = 0;
        my $has_lib_hardcode              = 0;
        my $has_uneven_braces             = 0;
        my $has_uneven_suppress           = 0;
        my $contents_differ               = 0;
        my $first_location                = "";
        my @twin_file_list                = (); 
        my $has_ven_abbrev_callee         = 0;
        my $has_ven_ambigu_callee         = 0;
        my $has_cus_abbrev_callee         = 0;
        my $has_cus_ambigu_callee         = 0;

        foreach my $tcl_file (sort @{$tcl_files_in_path_ref}) {
          if ($tcl_file =~/\/$key$/) {
            print REPORT "|--location: $tcl_file\n";
            push(@location_paths, $tcl_file);
            $location_count++;
  
            if (exists $files{$tcl_file}{uneven_braces}) {
              $has_uneven_braces  = 1;
            }
            if ($location_count == 1) {
              $first_location = $tcl_file;
            } elsif (&_DoFilesDiffer(\$tcl_file, \$first_location)) {
              $contents_differ   = 1;
            }
            $num_lines = $num_lines + $files{$tcl_file}{length};
  
            if (exists $non_proc_violations{def_proc_attr}{$tcl_file}) {
              $has_def_proc_attr    = 1;
            }
            if (exists $non_proc_violations{live}{$tcl_file}) {
              $has_live             = 1;
            }
            if (exists $non_proc_violations{setenv}{$tcl_file}) {
              $has_setenv           = 1;
            }
            if (exists $non_proc_violations{getenv}{$tcl_file}) {
              $has_getenv           = 1;
            }
            if (exists $non_proc_violations{lib_hardcode}{$tcl_file}) {
              $has_lib_hardcode     = 1;
            }
            if (exists $non_proc_violations{fubp}{$tcl_file}) {
              $has_fubp             = 1;
            }
            if (exists $non_proc_violations{proj_cond}{$tcl_file}) {
              $has_proj_cond        = 1;
            }
            if (exists $non_proc_violations{tool_cond}{$tcl_file}) {
              $has_tool_cond        = 1;
            }
            if (exists $non_proc_violations{def_proc_attr}{$tcl_file}) {
              $has_def_proc_attr    = 1;
            }
            if (exists $non_proc_violations{namespace}{$tcl_file}) {
              $has_namespace        = 1;
            }
            if (exists $non_proc_violations{uneven_suppress}{$tcl_file}) {
              $has_uneven_suppress  = 1;
            }
            if (     (exists $files{$tcl_file}{unix_script}) 
                 && !(exists $files{$tcl_file}{executable})) {
              $is_unix_script_not_executable  = 1;
            } elsif (    !(exists $files{$tcl_file}{unix_script}) 
                      && (exists $files{$tcl_file}{executable})) {
              $is_executable_not_unix_script  = 1;
            }

            foreach my $other_tcl_file (sort @{$tcl_files_in_path_ref}) {
              if (!($other_tcl_file =~/\/$key$/)) {
                if (!(&_DoFilesDiffer(\$tcl_file,\$other_tcl_file))) {
                  if (!(&_IsInList(\$other_tcl_file, \@twin_file_list))) {
                    push(@twin_file_list, $other_tcl_file);
                    
                    #Only add this file once regardless of how many twins it has
                    if (scalar @twin_file_list == 1) { 
                      push(@files_with_twins, $key);
                    }
                  }
                }
              }
            }
          }
        }
  
        foreach my $twin_file (@twin_file_list) {
          print REPORT "Warning: This source file is the same as $twin_file.";
          if (&_IsDead(\$twin_file)) {
            print REPORT " $DEAD_STRING";
          }
          if (&_IsDoNotPrune(\$twin_file)) {
            print REPORT " $DO_NOT_PRUNE_STRING";
          }
          print REPORT "\n";
        }
  
        if ($location_count == 0) {
          print REPORT "|--location: $NA_STRING\n";
          print REPORT "Warning: This source file has no location.\n";
          push(@files_sans_loc, $key);
        } elsif ($location_count > 1) {
          print REPORT 
            "Warning: This source file has $location_count locations ";
          push(@files_multi_loc, $key);
          if ($contents_differ) {
            print REPORT "(different contents).\n";
            push(@files_multi_loc_diff, $key);
          } else {
            print REPORT "(identical contents).\n";
            push(@files_multi_loc_same, $key);
          }
        }

        if ($is_unix_script_not_executable) {
          print REPORT "Warning: This source file is a unix script but is not executable.\n";
          push(@files_unix_script_not_executable, $key);
        } 
        
        if ($is_executable_not_unix_script) {
          print REPORT "Warning: This source file is executable but is not a unix script.\n";
          push(@files_executable_not_unix_script, $key);
        }

        #Report procedures defined.
        print REPORT "|--definitions:";
        my $defs_count  = 0;
        my $dead_lines  = 0;
        my $alive_lines = 0;
        my $alive_procs = 0;
        foreach my $location_path (sort @location_paths) {
          if (exists $files{$location_path}{proc_definitions}) {
            foreach my $defined_proc (sort @{$files{$location_path}{proc_definitions}}) {
              if (!(&_IsInList(\$defined_proc, \@ignore_list))) {
                print REPORT "\n   |--" . &GetFormalName($defined_proc);
                if (&_IsDead(\$defined_proc)) {
                  print REPORT " $DEAD_STRING";
                  $dead_lines   += $procs{$defined_proc}{length};
                } else {
                  $alive_lines  += $procs{$defined_proc}{length};
                  $alive_procs++;
                }
                if (&_IsDoNotPrune(\$defined_proc)) {
                  print REPORT " $DO_NOT_PRUNE_STRING";
                }
                $defs_count++;
              }
            }
          }
        }
        if ($location_count == 0) { 
          print REPORT " $UNDEFINED_STRING";
        } elsif ($defs_count == 0) {
          print REPORT " $NA_STRING\n";
          print REPORT 
            "Warning: This source file has no procedure definitions.";
          push(@files_no_defs, $key);
        } elsif (($alive_procs == 0) && !($file_is_dead)) {
          print REPORT "\nWarning: This source file is alive but "
            . "all its procedures defined are dead.";
          push(@files_live_dead_procs, $key); 
        }
        print REPORT "\n";
    
        #Report the file's length.
        print REPORT "|--length:";
        if ($location_count == 0) {
          print REPORT " $UNDEFINED_STRING";
        } else {
          my $avg_length = $num_lines / $location_count;
          printf REPORT " %d", $avg_length;
          if ($location_count > 1) {
            print REPORT " (average)";
          }
          if ($avg_length > 0) {
            if ($file_is_dead) {
              my $pcnt_dead_lines 
                = (100.0 * ($avg_length - $alive_lines)) / $avg_length;
              #Keep the percentage within the range of 0-100%. 
              if ($pcnt_dead_lines < 0.0) {
                $pcnt_dead_lines  = 0;
              } elsif ($pcnt_dead_lines > 100.0) {
                $pcnt_dead_lines  = 100.0;
              }
              printf REPORT ", %1.0f", $pcnt_dead_lines;
              print  REPORT "% dead"; 
              if ($alive_lines > 0) {
                print REPORT "\nWarning: This source file is dead but defines "
                  . "procedures that aren't.";
                push(@files_undead_procs, $key);
              }
            } elsif ($dead_lines > 0) {
              my $pcnt_dead_lines = (100.0 * $dead_lines / $avg_length);
              #Keep the percentage within the range of 0-100%. 
              if ($pcnt_dead_lines < 0.0) {
                $pcnt_dead_lines  = 0;
              } elsif ($pcnt_dead_lines > 100.0) {
                $pcnt_dead_lines  = 100.0;
              }
              printf REPORT ", %1.0f", $pcnt_dead_lines;
              print  REPORT "% dead"; 
              if (    ($pcnt_dead_lines >  80.0)
                   && ($pcnt_dead_lines < 100.0)) {
                print REPORT "\nWarning: This source file is alive but "
                  . ">80% of its code is dead.";
                push(@files_live_much_dead, $key); 
              }
  
            }
          }
        }
        print REPORT "\n";
      
        if ($has_def_proc_attr) {
          print REPORT "Warning: This source file has non-conforming "
            . "define_proc_attribute calls.\n";
          push(@files_def_proc_attr, $key);
        }
        if ($has_namespace) {
          print REPORT 
            "Warning: This source file has namespace declarations.\n";
          push(@files_namespace, $key);
        }
        if ($has_live) {
          print REPORT "Warning: This source file has meaningful code lines "
            . "outside of procedures.\n";
          push(@files_live, $key);
        }      
        if ($has_uneven_braces) {
          print REPORT "Warning: This source file has unmatched opening and "
            . "closing braces.\n";
          push(@files_uneven_braces, $key);
        }
        if ($has_proj_cond) {
          print REPORT 
            "Warning: This source file has a project-specific switch "
            . "(non-proc code).\n";
          push(@files_proj_cond, $key);
        }
        if ($has_fubp) {
          print REPORT "Warning: This source file has fubp-related code "
            . "(non-proc code).\n";
          push(@files_fubp, $key);
        }
        if ($has_lib_hardcode) {
          print REPORT "Warning: This source file has library hardcoding "
            . " (non-proc code).\n";
          push(@files_lib_hardcode, $key);
        }
        if ($has_getenv) {
          print REPORT "Warning: This source file accesses an environment "
            . "variable (non-proc code).\n";
          push(@files_getenv, $key);
        }
        if ($has_uneven_suppress) {
          print REPORT "Warning: This source file has unmatched "
            . "(un)suppress_messsage calls (non-proc code).\n";
          push(@files_uneven_suppress, $key);
        }
        if ($has_setenv) {
          print REPORT "Warning: This source file sets an environment variable "
            . "(non-proc code).\n";
          push(@files_setenv, $key);
        }
        if ($has_tool_cond) {
          print REPORT "Warning: This source file has a vendor tool-specific "
            . "switch (non-proc code).\n";
          push(@files_tool_cond, $key);
        }
        
        #Print out files's callee procs.
        print REPORT "|--(outside of proc definition) callees: ";
        my %callee_procs  = (); 
        foreach my $location_path (sort @location_paths) {
          if (exists $files{$location_path}{proc_callees}) {
            my $callee_procs_ref = \%{$files{$location_path}{proc_callees}};
            foreach my $callee_proc (keys %{$callee_procs_ref}) {
              $callee_procs{$callee_proc} = 1; 
            }
          }  
        }
        my $callee_count    = 0;
        my $custom_count    = 0;
        my $vendor_count  = 0;
        my $builtin_count   = 0;

        #Organize callee procedures into custom, vendor, and builtins.
        my %custom_callees    = (); 
        my %ven_proc_callees  = (); 
        my %builtin_callees   = (); 
        foreach my $callee_proc (keys %callee_procs) {
          if ($procs{$callee_proc}{is_custom}) {
            $custom_callees{$callee_proc} = 1;
          }
          if ($procs{$callee_proc}{is_ven_proc}) {
            $ven_proc_callees{$callee_proc} = 1;
          } 
          if ($procs{$callee_proc}{is_builtin}) {
            $builtin_callees{$callee_proc} = 1;
          }
          $callee_count++;
        }
                
        #List custom procedure callees first.
        foreach my $callee_proc (sort keys %custom_callees) {
          $custom_count++;
          print REPORT "\n   |--$callee_proc";  

          if (exists $procs{$callee_proc}{cus_ambigu}) {
            print REPORT " $CUSTOM_AMBIG_STRING";
          } elsif (exists $procs{$callee_proc}{cus_abbrev}) {
            print REPORT " $CUSTOM_ABBREV_STRING";
          } elsif(scalar keys %{$procs{$callee_proc}{definitions}} == 0) {
            print REPORT " ($UNDEFINED_STRING)";
          }

          if (&_IsDead(\$callee_proc)) {
            print REPORT " $DEAD_STRING";
          }
          if (&_IsDoNotPrune(\$callee_proc)) {
            print REPORT " $DO_NOT_PRUNE_STRING";
          }

          if (exists $procs{$callee_proc}{cus_abbrev}) {
            $has_cus_abbrev_callee  = 1;
          }
          if (exists $procs{$callee_proc}{cus_ambigu}) {
            $has_cus_ambigu_callee  = 1;
          }
        }
              
        #List vendor command callees next.
        foreach my $callee_proc (sort keys %ven_proc_callees) {
          if (    ($vendor_count == 0) 
               && ($custom_count > 0)) {
            print REPORT "\n   |";  
          }
          $vendor_count++;
          print REPORT "\n   |--$callee_proc"; 
          if (exists $procs{$callee_proc}{ven_ambigu}) {
            print REPORT " $VENDOR_AMBIG_STRING";
          } else {
            my $ven_bucket_name = &_GetVendorProcBucketName($callee_proc);
            print REPORT " (Vendor $ven_bucket_name command)";
          }
          if (exists $procs{$callee_proc}{ven_abbrev}) {
            $has_ven_abbrev_callee  = 1;
          }
          if (exists $procs{$callee_proc}{ven_ambigu}) {
            $has_ven_ambigu_callee  = 1;
          }
        }
  
        #Finally list Tcl builtin callees.
        foreach my $callee_proc (sort keys %builtin_callees) {
          if (    ($builtin_count == 0) 
               && (    ($custom_count   > 0)
                    || ($vendor_count > 0))) {
            print REPORT "\n   |";  
          }
          $builtin_count++;
          print REPORT "\n   |--$callee_proc (Tcl builtin)";  
        }
        if ($location_count == 0) {
          print REPORT "$UNDEFINED_STRING";
        } elsif ($callee_count == 0) {
          print REPORT "$NA_STRING";
        }
        print REPORT "\n";
 
        if ($has_ven_abbrev_callee) { 
          print REPORT "Warning: This source file has a callee that is a "
            . "vendor abbreviated command (non-proc code).\n";
          push(@files_ven_abbrev_callee, $key);
        }
        if ($has_ven_ambigu_callee) { 
          print REPORT "Warning: This source file has a callee that is a "
            . "vendor ambiguous command abbreviation (non-proc code).\n";
          push(@files_ven_ambigu_callee, $key);
        }
        if ($has_cus_abbrev_callee) { 
          print REPORT "Warning: This source file has a callee that is a "
            . "custom abbreviated procedure (non-proc code).\n";
          push(@files_cus_abbrev_callee, $key);
        }
        if ($has_cus_ambigu_callee) { 
          print REPORT "Warning: This source file has a callee that is a "
            . "custom ambiguous procedure abbreviation (non-proc code).\n";
          push(@files_cus_ambigu_callee, $key);
        }

        print REPORT "|--sourcees: ";
