          foreach my $sourced_file (sort @{$sourced_files_ref}) {
            if (&_IsSourceFileTracked(\$sourced_file)) {
              print REPORT "\n   |--$sourced_file";
              if (&_IsDead(\$sourced_file)) {
                print REPORT " $DEAD_STRING";
              }
