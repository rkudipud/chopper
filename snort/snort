{  
  my $initialized         = 0;  #static variable
  my @all_file_extensions = (); #static variable
  sub _GetAllFileExtensions() {
    print "#" . &_GetTime() . "> Entering &_GetAllFileExtensions().\n" if $::DEBUG;

    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_GetAllFileExtensions().\n" if $::DEBUG;
      return \@all_file_extensions;
    }

    &_GetOptionsAndReadConfigFile();

    #Add and verify Tcl file extensions.
    foreach my $file_extension (@tcl_file_extensions) {
      if (!($file_extension =~/^\.[a-zA-Z0-9_]+$/)) {
        die "(_GetAllFileExtensions():1) "
          . "Error: Invalid Tcl file extension '$file_extension'!\n";
      }
      #Make sure that the user isn't trying to read object-oriented Tcl files. 
      if ($file_extension eq ".itcl") {
        die "(_GetAllFileExtensions():2) Error: Tcl file extension "
          . "'$file_extension' isn't supported.\n";
      } 

      push(@all_file_extensions, $file_extension);  
    }  
    (scalar @all_file_extensions > 0) || die "(_GetAllFileExtensions():3) "
      . "Error: No Tcl file extensions specified!\n";
    
    #Add and verify non-Tcl file extensions.
    foreach my $file_extension (@non_tcl_file_extensions) {
      if (!($file_extension =~/^\.[a-zA-Z0-9_]+$/)) {
        die "(_GetAllFileExtensions():4) "
          . "Error: Invalid non-Tcl file extension '$file_extension'!\n";
      }
      if (&_IsInList(\$file_extension, \@all_file_extensions)) {
        die "(_GetAllFileExtensions:5) Error: File extension '$file_extension' "
          . "can't be designated as both Tcl and non-Tcl.\n";
      }
      push(@all_file_extensions, $file_extension);  
    }  
          
    $initialized  = 1;
    print "#" . &_GetTime() . "> Exiting  &_GetAllFileExtensions().\n" if $::DEBUG;
    return \@all_file_extensions;
  }
}


sub _IsTclFile($) {
  my $fref    = shift;
  my $ret_val = 0;
  foreach my $tcl_file_extension (@tcl_file_extensions) {
    my $regexp_tcl_file_extension = "\\" . $tcl_file_extension;
    if ($$fref =~/$regexp_tcl_file_extension$/) {
      $ret_val = 1;
    }
  }
  return  $ret_val;
}

sub _DoFilesDiffer($$) {
  my $fref1 = shift;
  my $fref2 = shift;

  my @diff_output = `diff --brief $$fref1 $$fref2`;
  if (scalar @diff_output > 0) {
    return  1;
  } else {
    return  0;
  }
}

sub _GetDefineProcAttributesProcName($) {
  my $proc  = shift;
  
  #Strip off the define_proc_attributes procedure and trailing whitespace.
  $proc =~s/^.*define_proc_(attributes|arguments)\s+//;

  #Strip off optional switches that could be confused for procedure names.
  if ($proc =~/-/) { 
    $proc =~s/-permanent\s*//;
    $proc =~s/-hide_body\s*//;
    $proc =~s/-hidden\s*//;
    $proc =~s/-dont_abbrev\s*//;
    $proc =~s/-obsolete\s*//;
    $proc =~s/-deprecated\s*//;

    my @non_boolean_args   = (
      "-info", "-define_args", "-define_arg_groups", "-command_group", "-return"
    );
    foreach my $arg (@non_boolean_args) {
      $proc =~s/$arg\s+\"[^\"]+\"\s*//;
      $proc =~s/$arg\s+\"[^\"]*$//;
      $proc =~s/$arg\s+\{[^\}]+\}\s*//;
      $proc =~s/$arg\s+\{[^\}]*$//;
      $proc =~s/$arg\s+\S+//;
    }
  }
  
  #Strip off ^M return carriage character.
  $proc =~s/\r$//;

  #Strip off trailing slash to extend the line.
  $proc =~s/\\$//;
 
  #Strip off trailing whitespace at the end of the line.
  $proc =~s/\s+$//;
  
  chomp($proc);
  return  $proc;
}

sub _GetFullProcName($$) {
  my $namespace = shift;
  my $proc      = shift;

  if (    ($namespace ne "")
       && !($proc =~/::/)) {
    $proc = $namespace . "::" . $proc;
  }
  $proc =~s/^:://;  #Get rid of global namespace override prefix.
  
  return $proc;
}

sub _PruneFile($) {
  my $file  = shift;
  print "#" . &_GetTime() . "> Entering &_PruneFile($file).\n" if $::DEBUG;

  #Create the trash directory.
  my $file_dir  = $file;
  $file_dir     =~s/\/[^\/]+$//;
  my $trash_dir = "$file_dir\/$TRASH_DIR";
  if (!(-d $trash_dir)) {
    mkpath ($trash_dir) 
      || die "(_PruneFile():6) Error: Can't create directory $trash_dir!\n";
    if (    ($SVN) 
         && (system("svn add $trash_dir") != 0)) {
      die "(_PruneFile():7) Error: Can't add directory $trash_dir in svn!\n";
    }
  }

  #Move the file to the trash.
  my $abbrev_file = &_GetAbbrevFile(\$file);
  my $trash_file  = "$trash_dir\/$abbrev_file";
  if (!$SVN) {
    if ($P4) {
      if (system("cp $file $trash_file") != 0) {
        die "(_PruneFile():8) Error: Can't copy file $file to $trash_file!\n";
      }
      if (system("p4 add $trash_file") != 0) {
        die "(_PruneFile():9) Error: Can't add file $trash_file in p4!\n";
      }
      if (system("p4 delete $file") != 0) {
        die "(_PruneFile():10) Error: Can't delete file $file in p4!\n";
      }
    } else {
      if (system("mv $file $trash_file") != 0) {
        die "(_PruneFile():11) Error: Can't move $file to $trash_file!\n";
      }
    }
  } else {
    if (system("svn mv $file $trash_file") != 0) {
      die "(_PruneFile():12) Error: Can't move $file to $trash_file in svn!\n";
    }
  }
  
  print "#" . &_GetTime() . "> Exiting  &_PruneFile($file).\n" if $::DEBUG;
  return;
}

{
  my $prune_point_id;       #static variable
