      }
      if (exists $files{$$fref}{procs_sources}) {
        foreach my $proc (keys %{$files{$$fref}{procs_sources}}) {
          if (1 || !(&_IsDead(\$proc))) {
            foreach my $sourcee_file (@{$files{$$fref}{procs_sources}{$proc}}) {
