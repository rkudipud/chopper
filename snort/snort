{
  my $cmd = "current_design_name";  #static variable
  sub _HasFubpRelatedCode($) {
    my ($lref) = @_;

    if (    (    ($$lref =~/^[^#]*regsub/)
              && (    ($$lref =~/regsub\s+p\$\s+\[\s*$cmd\s*\]\s+\"\"\s/)
                   || ($$lref =~/regsub\s+"p\$\"\s+\[\s*$cmd\s*\]\s+\"\"\s/)
                   || ($$lref =~/regsub\s+p\$\s+\$[a-zA-Z0-9_]+\s+\"\"\s/)
                   || ($$lref =~/regsub\s+"p\$\"\s+\$[a-zA-Z0-9_]+\s+\"\"\s/)))
         || (    ($$lref =~/^[^#]*regexp/)
              && (    ($$lref =~/regexp\s+\{\(\\S\+\)p\}\s+\[\s*$cmd\s*\]\s+null\s/)
                   ||  ($$lref =~/regexp\s+\{\(\\S\+\)p\}\s+\$[a-zA-Z0-9_]+\s+null\s/)
                   ||  ($$lref =~/regexp\s+\{\(\.\*\)p\}\s+\$[a-zA-Z0-9_]+\s+null\s/)))
         || (    ($$lref =~/^[^#]*fubp/)
              && (    ($$lref =~/fubp_cell[\s=]/)
                   || ($$lref =~/fubp_net[\s=]/)
                   || ($$lref =~/^\s*dcsv_dont_touch_genfubp_p/)))) {
      return  1;
    } else {
      return  0;
    }
  }
}

sub _MarkDeadProcs() {
  print "#" . &_GetTime() . "> Entering &_MarkDeadProcs().\n" if $::DEBUG;
  my $marked_dead_count = 0;

  foreach my $orphaned_caller (@{&_GetOrphanedProcCallers()}) {
    $marked_dead_count += &_RecursiveFindDeadProcs(\$orphaned_caller);
  }
    
  print "#" . &_GetTime() . "> Exiting  &_MarkDeadProcs() after "
    . "marking $marked_dead_count procedures dead.\n" if $::DEBUG;
  return $marked_dead_count;
}

sub _RecursiveFindDeadProcs($) {
  my $pref              = shift;
  my $marked_dead_count = 0;
  if (exists $procs{$$pref}) { #Is it a procedure?
    #If the procedure in question has already been marked as dead, we're done.  
    if (!(&_IsDead($pref))) {
      #It wasn't marked dead already but it could be dead. Determine if it is.
      my $num_living_parents  = 0;      
    
      if (exists $procs{$$pref}{callers}) {
        my $caller_procs_ref = \%{$procs{$$pref}{callers}};
        foreach my $parent (keys %{$caller_procs_ref}) {
          #Ignore recursive calls. This proc's status is still being evaluated. 
          if ($parent ne $$pref) {
            if (!(&_IsDead(\$parent))) {
              $num_living_parents++;
            }
          }
        }
      }

      my %definitions       = %{$procs{$$pref}{definitions}};
      my @definition_files  = ();
      foreach my $definition_file (sort keys %definitions) {
        $definition_file =~s/\(\d+\)$//;  #Remove uniqify suffix.
        push(@definition_files, $definition_file);
      }

      #The procedure is considered to be dead if it either...                   
      #  1a. has no living parents and it isn't defined in a top-of-tree file   
      #     -OR-                                                                
      #  1b. has one or more definitions but all of them are in dead files      
      #     -AND-                                                               
      #  2a. is not on the do not prune list                                    
      #     -AND-                                                               
      #  2b. has no definitions in files that are on the do not prune list      
      
      #Condition 1a test.
      my $cond_1a = 0; 
      if ($num_living_parents == 0) {
        my $top_of_tree_definition  = 0; 
        foreach my $definition_file (@definition_files) {
          if ((&_IsTopOfTreeFile(\$definition_file)) ) {
            $top_of_tree_definition  = 1; 
          }
        }
        if (!$top_of_tree_definition) {
          $cond_1a = 1;
        }
      }
      
      #Condition 1b test.
      my $cond_1b = 0; 
      {
        my $one_or_more_defs_alive  = 0; 
        my $defs_count              = 0; 
        foreach my $definition_file (@definition_files) {
          $defs_count++;
          if (!(&_IsDead(\$definition_file)) ) {
            $one_or_more_defs_alive  = 1; 
          }
        }
        if ($defs_count && !$one_or_more_defs_alive) {
          $cond_1b = 1;
        }
      }

      #Condition 2a test.
      my $cond_2a = 1; 
      if (&_IsDoNotPrune($pref)) {
        $cond_2a = 0;
      }
     
      #Condition 2b test.
      my $cond_2b = 1; 
      foreach my $definition_file (@definition_files) {
        if (&_IsDoNotPrune(\$definition_file)) {
          $cond_2b = 0;
        }
      }

      my $dead_status  = ($cond_1a || $cond_1b) && ($cond_2a && $cond_2b);

      #RDT can implicitly call individual outputs and reports procedures, but Snort can't track it.
      if ($dead_status && $RDT_OUTPUTS_AND_REPORTS && ($$pref =~/^(syn|sd)_(outputs|reports)_/)) {
        print "Information: Marking procedure '$$pref' as do not prune because it could be called by RDT through a variable.\n";
        $dead_status = 0;
        push(@do_not_prune_list, $$pref);
      }

      #If the procedure or file can't be marked as dead right now, then we are  
      #done. However if it can be marked as dead, recursively call its children 
      #to see if they are dead too.                                             
      if ($dead_status) {
        $marked_dead_count++;
        $num_dead_procs++;
        $procs{$$pref}{dead} = 1;
        if (exists $procs{$$pref}{callees}) {
          my $callee_procs_ref = \%{$procs{$$pref}{callees}};
          foreach my $child (keys %{$callee_procs_ref}) {
            if (($procs{$child}{is_custom})) { #Custom procedure?
              $marked_dead_count  += &_RecursiveFindDeadProcs(\$child); 
            }
          }
        }
      }
    }
  } else {
    #It is a file.
    if (&_IsDead($pref)) {
      my $callee_procs_ref = \%{$files{$$pref}{proc_callees}};
      foreach my $child (keys %{$callee_procs_ref}) {
        if (($procs{$child}{is_custom})) { #Custom procedure?
          $marked_dead_count  += &_RecursiveFindDeadProcs(\$child); 
        }
      } 
    }
  }

  return $marked_dead_count;
}

sub _MarkDeadFiles() {
  print "#" . &_GetTime() . "> Entering &_MarkDeadFiles().\n" if $::DEBUG;
  my $marked_dead_count = 0;

  #A file is considered dead if it isn't sourced through a designated           
  #top-of-tree file and isn't a designated top-of-tree file.                    

  #Generate the set of orphaned files with no parents/sourcers that also are not
  #top-of-tree files.                                                           
  my @orphaned_abbrev_files = ();
  foreach my $abbrev_file (@{&_GetAllAbbrevTclFilesFound()}) {
    if (!(&_IsTopOfTreeFile(\$abbrev_file))) { 
      my $caller_files_ref = &_GetSourcerFiles(\$abbrev_file); 
      my $num_parents       = scalar (@{$caller_files_ref});
      if ($num_parents == 0) {
        push(@orphaned_abbrev_files, $abbrev_file);
      } else {
      }
    } else {
    }
  }

  #Add in designated top of tree files, if they weren't already included.
  my $top_of_tree_files_ref = &_GetTopOfTreeFiles();
  foreach my $top_of_tree_file (@{$top_of_tree_files_ref}) {
    my $abbrev_top_of_tree_file = &_GetAbbrevFile(\$top_of_tree_file);
    if (!(&_IsInList(\$abbrev_top_of_tree_file, \@orphaned_abbrev_files))) {
      push(@orphaned_abbrev_files, $abbrev_top_of_tree_file);
    }
  }

  foreach my $orphaned_abbrev_file (@orphaned_abbrev_files) {
    $marked_dead_count += &_RecursiveFindDeadFiles(\$orphaned_abbrev_file);
  }
      
  print "#" . &_GetTime() . "> Exiting  &_MarkDeadFiles() after marking "
    . "$marked_dead_count files dead.\n" if $::DEBUG;
  return $marked_dead_count;
}

sub _RecursiveFindDeadFiles($) {
  my $aref              = shift;
  my $marked_dead_count = 0;
  #If the file in question has already been marked as dead, then we're done.
  if (!(&_IsDead($aref))) {
    #It wasn't marked dead already but it could be dead. Determine if it is.
    my $num_living_parents  = 0;      
   
    my $caller_files_ref = &_GetSourcerFiles($aref); 
    foreach my $parent (@{$caller_files_ref}) {
      my $abbrev_parent = &_GetAbbrevFile(\$parent);
      if (!(&_IsDead(\$abbrev_parent))) {
        $num_living_parents++;
      }
    }

    #If the procedure can't be marked as dead right now, we're done.  However if
    #it can be marked as dead, recursively call its children to see if they are 
    #dead too.
    if (    ($num_living_parents == 0)
         && !(&_IsTopOfTreeFile($aref))
         && !(&_IsDoNotPrune($aref))) { 
      $file_dead_abbrev{$$aref} = 1; 
      $marked_dead_count++;
      $num_dead_files++;
      my $sourced_files_ref = &_GetSourceeFiles($aref); 
      foreach my $child (@{$sourced_files_ref}) {
        if (&_IsSourceFileTracked(\$child)) { #Ignore untracked source files.
          $marked_dead_count += &_RecursiveFindDeadFiles(\$child); 
        }
      }
    }
  }

  return $marked_dead_count;
}

#-------------------------------------------------------------------------------
# SUBROUTINE:  _IsDead                                                          
# INPUTS:      procedure or Tcl file name                                       
# OUTPUTS:     int                                                              
# DESCRIPTION: Given a procedure or Tcl file name, this procedure returns       
#              whether it is dead.                                              
#-------------------------------------------------------------------------------
sub _IsDead($) {
  my $aref = shift;

    #Is the argument a procedure (or a Tcl file)?  Make sure that the argument is a procedure, and  
    #not a Tcl file, before testing if it's dead.  Otherwise Tcl file callers will be inadvertantly 
    #added to the %procs hash.                                                  
  if (     (exists $procs{$$aref}) 
       && !(exists $files_abbrev{$$aref})
       && !(exists $files{$$aref})) {
    return (exists $procs{$$aref}{dead});
  } else {
    my $abbrev_file = &_GetAbbrevFile($aref);
    return (exists $file_dead_abbrev{$abbrev_file});
  }
}

sub _IsDoNotPrune($) {
  my $aref    = shift;
  my $ret_val = 0;

  if (exists $procs{$$aref}) { #Is the argument a procedure (or a Tcl file)?
    #Is the procedure explicitly marked as do not prune?
    if (&_IsInList($aref, \@do_not_prune_list)) {
      $ret_val  = 1;
    } else {
      #Are all of its definitions marked as do not prune?
      my %definitions       = %{$procs{$$aref}{definitions}};
      my $dont_prune_count  = 0;
      my $def_count         = 0;
      foreach my $definition_file (sort keys %definitions) {
        $def_count++;
        my $abbrev_definition_file = &_GetAbbrevFile(\$definition_file);
        if (&_IsInList(\$abbrev_definition_file, \@do_not_prune_list)) {
          $dont_prune_count++; 
        }
      }
      if (    ($def_count > 0) 
           && ($dont_prune_count == $def_count)) {
        $ret_val  = 1;
      }
    }
  } else { 
    my $abbrev_file = &_GetAbbrevFile($aref);
    $ret_val  = &_IsInList(\$abbrev_file, \@do_not_prune_list);
  }
  
  return $ret_val;
}

