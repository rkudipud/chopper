sub ReportPruneEstimate() {
  my $abbrev_filename  = $REPORT_PRUNE_ESTIMATE;
  
  print "#" . &_GetTime() . "> Entering &ReportPruneEstimate().\n" if $::DEBUG;
  
  &_Initialize(); 
  my $filename  = "$REPORTS_DIR\/$abbrev_filename";
  print "Information: Writing file '$filename'.\n";
  
  open(REPORT, "> $filename") || die "(ReportPruneEstimate():37) "
    . "Error: Can't open $filename for writing!\n";
  
  my $num_lines_actual      = 0;
  my $num_lines             = 0;
  my $tcl_files_in_path_ref = &_GetAllTclFilesInPath();
  my $num_files             = (scalar @{$tcl_files_in_path_ref});
  my $num_dead_files0       = 0; 
  my $num_dead_lines0       = 0; 
  foreach my $tcl_file (@{$tcl_files_in_path_ref}) {
    $num_lines_actual   +=  `grep -c ^ $tcl_file`;
    $num_lines          += $files{$tcl_file}{length};
    if (&_IsDead(\$tcl_file)) {
      $num_dead_lines0  += $files{$tcl_file}{length};
      $num_dead_files0++;
    }
  }
  
  my $scaling_factor    = ($num_lines > 0) ? ($num_lines_actual / $num_lines)
    : 0;
  my $custom_procs_ref  = &_GetCustomProcs();
  my $num_procs         = (scalar @{$custom_procs_ref});
  my $num_dead_procs1   = 0; 
  my $num_dead_lines1   = 0; 
  foreach my $proc (@{$custom_procs_ref}) {
    if (&_IsDead(\$proc)) {
      my %definitions = %{$procs{$proc}{definitions}};
      my $added_once  = 0;
      my $def_count   = 0;
      foreach my $definition_file (sort keys %definitions) {
        $def_count++;
        $definition_file =~s/\(\d+\)$//;  #Remove uniqify suffix.
        #Don't double count dead lines if the file with the definition is dead. 
        if (!(&_IsDead(\$definition_file))) {
          $num_dead_lines1  += $procs{$proc}{length};
          #Only count the procedure once even if it has multiple definitions.
          if (!$added_once) {
            $num_dead_procs1++;
            $added_once = 1;
          }
        }
      }
      #Also count procs with no definitions so that the additional dead procs   
      #count agrees with the total number of dead procs in the case where there 
      #are no dead files.                                                       
      if ($def_count == 0) {
        $num_dead_procs1++;
      }
    }
  }

  my $pcnt_dead_files = ($num_files > 0) 
    ? (100.0 * $num_dead_files0 / $num_files) : 0;
  my $pcnt_dead_procs = ($num_procs > 0) 
    ? (100.0 * $num_dead_procs / $num_procs) : 0;
  my $pcnt_char = "%";

  printf REPORT "There are $num_lines_actual ($num_lines "
    . "non-comment/blank) total lines across $num_files Tcl files.\n";
  printf REPORT "Scaling factor = $num_lines_actual / $num_lines = ";
  printf REPORT "%4.2f.\n\n", $scaling_factor;
  printf REPORT "Found %d dead Tcl files (%4.1f%s of %d) ",
    $num_dead_files0, $pcnt_dead_files, $pcnt_char, $num_files;
  printf REPORT "and %d dead procedures (%4.1f%s of %d).\n\n",
    $num_dead_procs, $pcnt_dead_procs, $pcnt_char, $num_procs;

  my $num_dead_lines    = $num_dead_lines0 + $num_dead_lines1;

  my $num_dead_lines_estimated  = $num_dead_lines * $scaling_factor;
  my $pcnt_dead_lines_estimated = ($num_lines_actual > 0)
    ? (100.0 * $num_dead_lines_estimated / $num_lines_actual) : 0;

  printf REPORT "  %6d ;# of lines from %d dead Tcl files\n",
    $num_dead_lines0, $num_dead_files0;
  printf REPORT "+ %6d ;# of lines from %d additional dead procedures "
    . "(live Tcl files)\n", $num_dead_lines1, $num_dead_procs1;
  printf  REPORT "--------\n";
  
  printf REPORT "  %6d\n", $num_dead_lines;
  printf REPORT "*   %4.2f\n", $scaling_factor;
  printf REPORT "--------\n";
  printf REPORT "  %6d ;# of estimated lines (%4.1f", $num_dead_lines_estimated,
    $pcnt_dead_lines_estimated;
  printf REPORT "%s) that can be safely removed from Tcl files.\n",
    $pcnt_char;

  close REPORT;
  print "#" . &_GetTime() . "> Exiting  &ReportPruneEstimate().\n" if $::DEBUG;
}

