    }

    my $dest_arr_ref  = $keep ? (\@keep_lines) : (\@drop_lines);

    if ((scalar @comment_cache) > 0) {
      if (    ($kept_prev_line) 
           && (    ($sticky_bit)
                || !($keep))) {
        #my $msg = "#------------------------------ PRUNE POINT #"
        #  . (sprintf "%4d", $prune_point_id)
        #  . " ------------------------------\n";
        #push(@keep_lines, $msg);
        #$msg = "#------------------------------ PRUNE BEGIN #"
        #  . (sprintf "%4d", $prune_point_id)
        #  . " ------------------------------\n";
        #push(@drop_lines, $msg);
      } elsif (    !($kept_prev_line) 
                && !($sticky_bit)
                && ($keep)) {
        $prune_point_id++;
      }

      if ($sticky_bit) { 
        push(@drop_lines, @comment_cache); 
        $kept_prev_line = 0;
      } else { 
        push(@{$dest_arr_ref}, @comment_cache); 
        $kept_prev_line = $keep;
      }
      @comment_cache  = ();
    } 

    if (    ($kept_prev_line) 
         && !($keep)) {
      #my $msg = "#------------------------------ PRUNE POINT #"
      #  . (sprintf "%4d", $prune_point_id) 
      #  . " ------------------------------\n";
      #push(@keep_lines, $msg);
      #$msg = "#------------------------------ PRUNE BEGIN #"
      #  . (sprintf "%4d", $prune_point_id)
      #  . " ------------------------------\n";
      #push(@drop_lines, $msg);
    } elsif (    !($kept_prev_line) 
              && ($keep)) {
      $prune_point_id++;
    }

    push(@{$dest_arr_ref}, $line); 
    $sticky_bit     = 0; 
    $kept_prev_line = $keep;
  }
}

sub _PruneProcDefsFromFile($$) {
  my $procs_to_remove_ref = shift;
  my $file                = shift;
  
  print "#" . &_GetTime() . "> Entering &_PruneProcDefsFromFile("
    . "$procs_to_remove_ref, $file).\n" if $::DEBUG;
  
  my $open_count      = 0;      #Number of curly braces that are currently open.
  my $namespace       = ""; 
  my $namespace_level = -1;
  my $proc            = "";
  my $proc_level      = -1;
  @comment_cache      = ();
  @drop_lines         = ();
  @keep_lines         = ();
  $sticky_bit         = 0;

  my $line_number     = 0;

  open(ORIG_FILE, "<$file") || die "(_PruneProcDefsFromFile():9) "
    . "Error: Can't open $file for reading!\n";
  #Step through entire file.
  while (<ORIG_FILE>) {
    $line_number++;
    study;

    #Set namespace only if we're not already inside of a procedure or namespace.
    if (    ($_ =~/^namespace\s+eval\s.*\s\{/) 
         && ($proc eq "")
         && ($namespace eq "")) {
      my ($curly_delta, $curly_found) = &_CurlyCount2($_);
      #Don't record namespace if it's declared only for a single line.
      if ($curly_found && ($curly_delta != 0)) {  
        $namespace        = &_ExtractNamespaceFromLine($_);
        $namespace_level  = $open_count;
      } 
      $open_count += $curly_delta;
      
      &_KeepOrDropCodeLine($_, 1);
    } elsif (    (m/^\s*proc\s+([^\s^\{^\(]+)/i) #Start of procedure definition?
              && ($proc eq "")) {
      #Form the procedure's full name.
      $proc       = &_GetFullProcName($namespace, $1); 
      $proc_level = $open_count;

      $open_count += &_CurlyCount($_);
      &_KeepOrDropCodeLine($_, !&_IsInList(\$proc, $procs_to_remove_ref));
    } elsif (    ($namespace ne "")   #Inside of a namespace?
              || ($proc ne "")) {     #Inside of a procedure definition?
      #If we're already inside a procedure or namespace, count the curly braces.
      $open_count += &_CurlyCount($_);

      #Store the entire namespace or procedure definition, excluding comments   
      #and whitespace, except for last line.  Are we still in the definition?   
      if (    (    ($namespace ne "") 
                && ($open_count > $namespace_level)
                && ($proc eq ""))
           || (    ($proc ne "") 
                && ($open_count > $proc_level))) {
        &_KeepOrDropCodeLine($_, !&_IsInList(\$proc, $procs_to_remove_ref));
      } else {
         #If we're here, we've exited the namespace or procedure definition.
          
        #Should the namespace be reset?
        if ($open_count <= $namespace_level) {
          $namespace        = ""; 
          $namespace_level  = -1;
        }

        #The current line read in is the closing brace.
        &_KeepOrDropCodeLine($_, !&_IsInList(\$proc, $procs_to_remove_ref));
       
        #Reset the procedure, unconditionally.  If we just exited a namespace   
        #and not a procedure, this action is harmless.                          
        $proc         = "";
        $proc_level   = -1;

        #Look for the optional define_proc_attributes.
        $_ = <ORIG_FILE>;
        $line_number++;
        while ($_ && !m/^[^#]*define_proc_(attributes|arguments)\s+/ && !m/^\s*proc/ && !m/^[^#]*parseOpt::cmdSpec\s+/ && !m/^\s*proc/) {
          my ($curly_delta, $curly_found) = &_CurlyCount2($_);
          #Set the namespace only if we're not already inside of a namespace.
          if (    ($_ =~/^namespace\s+eval\s.*\s\{/) 
               && ($namespace eq "")) {
            #Don't record namespace if it's declared only for a single line.
            if ($curly_found && ($curly_delta != 0)) {  
              $namespace        = &_ExtractNamespaceFromLine($_);
              $namespace_level  = $open_count;
            } 
          }
          $open_count += $curly_delta;

          #Should the namespace be reset?
          if ($open_count <= $namespace_level) {
            $namespace        = ""; 
            $namespace_level  = -1;
          }
         
          #Keep previously existing prune points for reference.
          if ($_ =~/PRUNE POINT/) {
            &_KeepOrDropCodeLine($_, 1);
          } else {
            push(@comment_cache, $_);
          }
          
          $_ = <ORIG_FILE>;
          $line_number++;
        }

        #Check if end of file was reached.
        last if (!$_);
       
        #At this point, there should be a new proc or the definition.
        if (m/^\s*proc\s+([^\s^\{^\(]+)/i) {
          #Form the procedure's full name and then add it to the hash.
          $proc       = &_GetFullProcName($namespace, $1); 
          $proc_level = $open_count;
          $open_count += &_CurlyCount($_);

          &_KeepOrDropCodeLine($_, !&_IsInList(\$proc, $procs_to_remove_ref));
          
        } else {
          #We've just begun a define_proc_attributes definition. Read all of it.
          #Also the define_proc_attributes might not necessarily be the same as 
          #the procedure that was just defined.                                 
          $proc = &_GetDefineProcAttributesProcName($_);
          $proc = &_GetFullProcName($namespace, $proc);

          &_KeepOrDropCodeLine($_, !&_IsInList(\$proc, $procs_to_remove_ref));
          
          my $curly_count = &_CurlyCount($_);
          my $quote_count = &_QuoteCount($_);
          $open_count     += $curly_count;
          while ((m/\s*\\\s*$/ || $curly_count > 0 || $quote_count % 2 != 0) && ($_ = <ORIG_FILE>)) {
            $line_number++;
            my $curly_delta = &_CurlyCount($_);
            $curly_count  += $curly_delta;
            $open_count   += $curly_delta;
            $quote_count  += &_QuoteCount($_);
            &_KeepOrDropCodeLine($_, !&_IsInList(\$proc, $procs_to_remove_ref));
          }

          $proc = "";
        }
      }

      #Otherwise pull the line into an other lines var.
    } else {
      #Non-procedure code line.
      $open_count += &_CurlyCount($_);
      if (&_IsInList(\$proc, $procs_to_remove_ref)) {
        push(@drop_lines, $_);
      } else {
        #If we've hit real code, flush the comment cache to the save file first.
        if (&_IsNonBlankLine($_)) {
          &_KeepOrDropCodeLine($_, 1);
        } else {
          #If we've run into a commented procedure definition, drop it too.
          if ($_ =~/^#\s*proc\s+[a-zA-Z_0-9]+\s+\{.*\}\s+\{$/) { 
            &_KeepOrDropCodeLine($_, 0);
            $sticky_bit = 1;
          } else {
            #Keep previously existing prune points for reference.
            if ($_ =~/PRUNE POINT/) {
              &_KeepOrDropCodeLine($_, 1);
            } else {
              push(@comment_cache, $_);
            }
          }
        }
      }
    }
  }
  push(@keep_lines, @comment_cache);  #Flush the comment cache buffer.
  @comment_cache  = ();
  close ORIG_FILE;

  #Only create the trash file if something was actually pruned to begin with.
  if (scalar @drop_lines > 0) {
    if (    ($P4) 
         && (system("p4 edit $file") != 0)) {
      die "(_PruneFile():13) Error: Can't edit $file in p4!\n";
    }

    open(KEEP_FILE, ">$file") || die "(_PruneProcDefsFromFile():10) "
      . "Error: Can't open $file for writing!\n";
    foreach my $line (@keep_lines) {
      print KEEP_FILE $line;
    }
    close KEEP_FILE;

    my $file_dir  = $file;
    $file_dir     =~s/\/[^\/]+$//;
    my $trash_dir = "$file_dir\/$TRASH_DIR";

    if (!(-d $trash_dir)) {
      mkpath ($trash_dir) || die "(_PruneProcDefsFromFile():11) "
        . "Error: Can't create directory $trash_dir!\n";
      if (    ($SVN) 
           && (system("svn add $trash_dir") != 0)) {
        die "(_PruneFile():14) Error: Can't add directory $trash_dir in svn!\n";
      }
    }

    my $abbrev_file = &_GetAbbrevFile(\$file);
    my $trash_file  = "$trash_dir\/$abbrev_file";
    open(DROP_FILE, ">>$trash_file") || die "(_PruneProcDefsFromFile():13) "
      . "Error: Can't open $trash_file for writing!\n";
    foreach my $line (@drop_lines) {
      print DROP_FILE $line;
    }
    close DROP_FILE;
    if (    ($SVN) 
         && (system("svn add $trash_file") != 0)) {
      die "(_PruneFile():15) Error: Can't add file $trash_dir in svn!\n";
    }
    if (    ($P4) 
         && (system("p4 add $trash_file") != 0)) {
      if (system("p4 edit $trash_file") != 0) {
        die "(_PruneFile():16) Error: Can't add or edit file $trash_dir in p4!\n";
      }
    }
  }

  print "#" . &_GetTime() . "> Exiting  &_PruneProcDefsFromFile("
    . "$procs_to_remove_ref, $file).\n" if $::DEBUG;
  return;  
}

{
  my $initialized     = 0;
  my @orphans         = ();
  sub _GetOrphanedProcCallers() {
    print "#" . &_GetTime() . "> Entering &_GetOrphanedProcCallers().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_GetOrphanedProcCallers().\n" if $::DEBUG;
      return \@orphans;
    }

    #Generate set of orphaned procs with no parents/callers and file callers. 
    my $custom_procs_ref  = &_GetCustomProcs();
    foreach my $proc (@{$custom_procs_ref}) {
      my $num_parents = 0;      
      if (exists $procs{$proc}{callers}) {
        my $callers = \%{$procs{$proc}{callers}};

        foreach my $caller (sort keys %{$callers}) {
          #Ignore recursive calls back to itself.
          if ($caller eq $proc) {
            next; 
          }
          $num_parents++;
          #If the caller is a file, then it's an orphan by definition. 
          if (!(exists $procs{$caller})) {
            if (!(&_IsInList(\$caller, \@orphans))) { #Only add it once to list.
              push(@orphans, $caller);
            }
          }
        }
      }
      if ($num_parents == 0) {
        push(@orphans, $proc);
      }
    }

    $initialized  = 1;
    print "#" . &_GetTime() . "> Exiting  &_GetOrphanedProcCallers().\n" if $::DEBUG;
    return \@orphans;
  }
}

sub _IsNonBlankLine($) {
  my $line        = shift;
  
  #A line is blank if it has no meaningful code in it besides comments.
  if (    !($line =~/^\s*\#/)
       && !($line =~/^\s*$/)) {
    return  1;
  } else {
    return  0;
  }
}

sub _CurlyCount($) {
  my $line        = shift;
  my $line0       = $line;

  my $delta_count = 0;
  #Remove open braces, prefixed by backslashes, that shouldn't be counted.
  while ($line =~/\{\\\{/) {
    $line =~s/\{\\\{/\{/;
  }
  while ($line =~/([^\\])\\\{/) {
    $line =~s/([^\\])\\\{/$1/;
  } 
  while ($line =~/\{/) {
    $delta_count++;
    $line =~s/^[^\{]*\{//;
  }

  #Remove closing braces, prefixed by backslashes, that shouldn't be counted.
  while ($line0 =~/\}\\\}/) {
    $line0 =~s/\}\\\}/\}/;
  } 
  while ($line0 =~/[^\\]\\\}/) {
    $line0 =~s/([^\\])\\\}/$1/;
  } 
  while ($line0 =~/\}/) {
    $delta_count--;
    $line0 =~s/^[^\}]*\}//;
  }

  return $delta_count;
}

sub _CurlyCount2($) {
  my $line          = shift;
  my $line0         = $line;

  my $delta_count   = 0;
  my $braces_found  = 0;
  #Remove open braces, prefixed by backslashes, that shouldn't be counted.
  while ($line =~/\{\\\{/) {
    $line =~s/\{\\\{/\{/;
  }
  while ($line =~/[^\\]\\\{/) {
    $line =~s/([^\\])\\\{/$1/;
  } 
  while ($line =~/\{/) {
    $delta_count++;
    $braces_found = 1;
    $line =~s/^[^\{]*\{//;
  }

  #Remove closing braces, prefixed by backslashes, that shouldn't be counted.
  while ($line0 =~/\}\\\}/) {
    $line0 =~s/\}\\\}/\}/;
  } 
  while ($line0 =~/[^\\]\\\}/) {
    $line0 =~s/([^\\])\\\}/$1/;
  } 
  while ($line0 =~/\}/) {
    $delta_count--;
    $braces_found = 1;
    $line0 =~s/^[^\}]*\}//;
  }

  return ($delta_count, $braces_found);
}

sub _ExtractNamespaceFromLine($) {
  my $namespace = shift;
  $namespace =~s/^namespace\s+eval\s+//;
  $namespace =~s/\s.*$//;
  chomp($namespace);
  $namespace =~s/::$//; 
  $namespace =~s/^:://; 
  
  return $namespace;
}

sub _QuoteCount($) {
  my $line        = shift;

  #Performance optimization.
  if (!$line =~/\"/) {
    return  0;
  }

  #Ignore quotes embedded in obvious comment lines.
  $line =~s/^\s*#.*//;
  $line =~s/;\s*#.*/;/;

  #Don't count escaped quotes.
  while ($line =~/\\\"/) {
    $line =~s/\\\"//;
  }

  my $quote_count = 0;
  while ($line =~/\"/) {
    $quote_count++;
    $line =~s/^[^\"]*\"//;
  }
  return  $quote_count;
}

{
  my $initialized = 0;
  my $initial_hour;
  my $initial_count;
  sub _GetTime() {
    my $time_string = (localtime);
    $time_string =~s/\s20\d\d$//; #Strip off year
    $time_string =~s/^.*\s//;   #Strip off day
    my $hours       = $time_string;
    $hours  =~s/:.*//;
    my $minutes     = $time_string;
    $minutes  =~s/^..://;
    $minutes  =~s/:..$//;
    my $seconds     = $time_string;
    $seconds  =~s/^.*://;
   
    my $num_seconds = (3600 * $hours) + (60 * $minutes) + $seconds;
    if (!$initialized) {
      $initial_hour   = $hours;
      $initial_count  = $num_seconds;
      $initialized    = 1;
    } else {
      if ($hours < $initial_hour) {
        $num_seconds += 86400;
      }
    }
    my $delta_seconds = $num_seconds - $initial_count;
    my $delta_hours   = $delta_seconds / 3600;
    $delta_hours      =~s/\..*//; 
    if ($delta_hours < 10) {
      $delta_hours = "0" . $delta_hours;
    }
    $delta_seconds    -= (3600 * $delta_hours);
    my $delta_minutes = $delta_seconds / 60;
    $delta_minutes    =~s/\..*//; 
    if ($delta_minutes < 10) {
      $delta_minutes = "0" . $delta_minutes;
    }
    $delta_seconds    -= (60 * $delta_minutes);
    if ($delta_seconds < 10) {
      $delta_seconds = "0" . $delta_seconds;
    }
    my $ret_val       = "$delta_hours:$delta_minutes:$delta_seconds"; 
    return $ret_val;
  }
}

{
  my $initialized = 0;  #static variable
  sub _CalcPrunedUsage() {
    print "#" . &_GetTime() . "> Entering &_CalcPrunedUsage().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_CalcPrunedUsage().\n" if $::DEBUG;
      return;
    }
    
    &_Initialize();

    my @proc_names = sort (keys %procs);
    foreach my $proc (@proc_names) {
      my $file_usage_ref  = $procs{$proc}{file_usage}; 
      my $pruned_usage  = 0;
      foreach my $key (keys %{$file_usage_ref}) {
        if (!(&_IsDead(\$key))) { 
          $pruned_usage += $$file_usage_ref{$key};
        }
      }
      $procs{$proc}{pruned_usage} = $pruned_usage;
    }

    $initialized  = 1;
    print "#" . &_GetTime() . "> Exiting  &_CalcPrunedUsage().\n" if $::DEBUG;
    return; 
  }
}

{
  my $initialized = 0;  #static variable
  sub _Initialize() {
    print "#" . &_GetTime() . "> Entering &_Initialize().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_Initialize().\n" if $::DEBUG;
      return;
    }

    &_GetOptionsAndReadConfigFile();
    &_CreateReportsDirectory();
    #The _GetAllAbbrevTclFilesFound subroutine is executed here solely for its  
    #side-effects, and its returned value is discarded.                         
    &_GetAllAbbrevTclFilesFound();
   
    #Keep iterating, marking files and procs dead, until there is nothing left. 
    my $first_iter  = 1;
    my $dead_count  = 0;
    my $max_iter    = 10000;
    my $iter_count  = 0; 
    while ($first_iter || (($dead_count > 0) && ($iter_count <= $max_iter))) {
      $dead_count = 0;
      $dead_count += &_MarkDeadFiles();
      $dead_count += &_MarkDeadProcs();
      $first_iter = 0;
      $iter_count++;
    }

    if ($iter_count > $max_iter) {
        die "(_Initialize():1) " . "Error: The recursive dead files/procs code is in an infinite loop!  Aborting after $max_iter iterations.\n";
    }

    $initialized  = 1;
    print "#" . &_GetTime() . "> Exiting  &_Initialize().\n" if $::DEBUG;
    return;
  }
}

#-------------------------------------------------------------------------------
# SUBROUTINE:  _GetAllAbbrevTclFilesFound                                       
# INPUTS:      none                                                             
# OUTPUTS:     none                                                             
# DESCRIPTION: This subroutine returns the list of abbreviated names (ie., sans 
#              paths) of all Tcl source code files found. The list is a superset
#              of what _GetAllTclFilesInPath returns, because some of the files 
#              returned might have been sourced somewhere but not actually exist
#              in the path.                                                     
#                                                                               
#              Calling this subroutine also has many desirable side-effects,    
#              including analyzing all Tcl procedures and non-procedure code    
#              and constructing the Tcl file sourcing tree.                     
#-------------------------------------------------------------------------------
{
  my @abbrev_tcl_files  = (); #static variable
  my $initialized       = 0;  #static variable
  sub _GetAllAbbrevTclFilesFound() {
    print "#" . &_GetTime() . "> Entering &_GetAllAbbrevTclFilesFound().\n" if $::DEBUG;
    if ($initialized) {
      print "#" . &_GetTime() . "> Exiting  &_GetAllAbbrevTclFilesFound().\n" if $::DEBUG;
      return  \@abbrev_tcl_files;
    }

    #First populate the hash with all the Tcl files found on the path provided. 
    foreach my $tcl_file (@{&_GetAllTclFilesInPath()}) {
      my $abbrev_tcl_file = &_GetAbbrevFile(\$tcl_file);
      $file_all_abbrev{$abbrev_tcl_file} = 1;
      
      if (!(exists $files_abbrev{$abbrev_tcl_file}{paths})) {
        $files_abbrev{$abbrev_tcl_file}{paths} = [];
      }
      push(@{$files_abbrev{$abbrev_tcl_file}{paths}}, $tcl_file);
    }

    #Next add to the hash any Tcl files, not found on the path, that are sourced
    #by Tcl files either outside of or inside of procedure definitions.         
    &_AnalyzeNonProcTclCode();
    &_AnalyzeTclProcDefinitions();
    &_FileGarbageCollector();

    #Finally add to the hash any remaining Tcl files, not found on the path,    
    #that are sourced by non-Tcl files on the path.                             
    my $all_files_ref = &_GetAllFilesInPath();
    foreach my $sourcer_file (@{$all_files_ref}) {
      if (!(&_IsTclFile(\$sourcer_file))) { 
        my @grep_out = ();
        open(IN, "<$sourcer_file") || die "(_GetAllAbbrevTclFilesFound():15) "
          . "Error: Can't open $sourcer_file for reading!\n";

        while (<IN>) {
          if (     (    ($_ =~/source\s/) 
                     && !(    ($_ =~/[a-zA-Z0-9]source\s/)
                     && !($_ =~/source\s.*source\s/)))
                || (    ($::RDT)
                     && (    ($_ =~/rdt_source_if_exists\s/)
                          || ($_ =~/source_pkg_file\s/)))
                || (    ($::CTH)
                     && ($_ =~/iproc_source\s/))
                || (    ($::CTH && $::CTH_iproc_source_distributed)
                     && ($_ =~/iproc_source_distributed\s/))
                || (    ($::CTH && $::CTH_stack_files)
                     && ($_ =~/(Ifc_shell|Ipt_shell)\s(.*\s)?-f(ile)?\s+[\/a-zA-Z0-9\.\-_]+/))) { 
            push(@grep_out, "$sourcer_file:$_");
          }
        }
        close IN;
        foreach my $line (@grep_out) {
          chomp($line);
          my $sourcee_file = &_ExtractSourcedFileFromLine(\$line);
          
          #Eliminate trailing return carriage if derived from a print statement.
          $sourcee_file =~s/\\n$//;
          
          if (    ($sourcee_file ne "")
               && !(&_IsInList(\$sourcee_file, \@ignore_list))) {
            #If we made it here, we have a valid sourcer and sourcee.
            my $abbrev_sourcer_file = &_GetAbbrevFile(\$sourcer_file);
            if (!(exists $files{$sourcer_file}{sources})) {
              $files{$sourcer_file}{sources} = [];
            }
            push(@{$files{$sourcer_file}{sources}}, $sourcee_file);
            if (!(exists $files_abbrev{$abbrev_sourcer_file}{sources})) {
              $files_abbrev{$abbrev_sourcer_file}{sources} = [];
            }
            push(@{$files_abbrev{$abbrev_sourcer_file}{sources}},
              $sourcee_file);
      
            if (&_IsSourceFileTracked(\$sourcee_file)) {
              if (!(exists $file_sourced_by{$sourcee_file})) {
                $file_sourced_by{$sourcee_file} = [];
              }
              push(@{$file_sourced_by{$sourcee_file}}, $sourcer_file);
              #Add sourcee to the hash for all Tcl files.
              $file_all_abbrev{$sourcee_file} = 1;
            }
          }
        }
      }
    }

    #We've identified all the abbreviated Tcl files' names, so build the array. 
    foreach my $abbrev_tcl_file (sort keys %file_all_abbrev) {
      push(@abbrev_tcl_files, $abbrev_tcl_file);
    }

    $initialized  = 1;
    print "#" . &_GetTime() . "> Exiting  &_GetAllAbbrevTclFilesFound().\n" if $::DEBUG;
    return  \@abbrev_tcl_files;
  }
}

sub _GetAbbrevFile($) {
  my $fref        = shift; 
  my $abbrev_file = $$fref;
  $abbrev_file    =~s/^\.?\/.*\///;
  chomp($abbrev_file); 
  return  $abbrev_file;
}

{
